{
  "$schema": "./appsettings.schema.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DataProtection": {
    "ApplicationName": "Odasoft.XBOL.AdminPortal"
  },
  "AdminSession": {
    "CookieName": "__Secure-xbol_admin_session",
    "Domain": null,
    "Path": "/",
    "SameSite": "Lax",
    "Secure": true,
    "Lifetime": "5.00:00:00",
    "RecentSignInWindow": "00:05:00",
    "CheckRevoked": false
  }
}
