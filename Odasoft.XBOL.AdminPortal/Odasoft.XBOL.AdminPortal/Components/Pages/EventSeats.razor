@page "/events/{Id:long}/seats"
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.AdminPortal.Configs
@using Microsoft.Extensions.Options
@using Odasoft.XBOL.Business

@implements IDisposable
@inject CartState CartState
@inject ISnackbar Snackbar
@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@inject IOptions<SeatsIo> SeatsOptions
@inject IStringLocalizer<Events> Localizer

<PageTitle>@_eventName</PageTitle>

<LoadingContainer 
    IsLoading="_loading" 
    HasError="_error"
    ErrorMessage="Error al cargar el evento"
    OnRetry="LoadEventData">
    <MudContainer>
        <MudGrid>
            <MudItem xs="7">
                <SeatingChart @ref="_seatingChart" SecretKey="@_secretKey" EventKey="@_eventKey" EventId="Id" Prices="_eventInfo?.Prices" />
            </MudItem>
            <MudItem xs="5">
                <MudStack Spacing="4">
                    <OrderSummary Chart="_seatingChart" />
                    <MudButton Variant="Variant.Filled"
                               DropShadow="false"
                               StartIcon="@Icons.Material.Outlined.Save"
                               Color="Color.Tertiary"
                               Disabled="@(CartState.IsHoldCallsInProgress || CartState.SelectedSeats.Count == 0)"
                               @onclick="Submit">
                        @(_holdProcessing? Localizer["Seats_HoldProcessing"] : Localizer["Seats_Buy"])
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudContainer>
</LoadingContainer>

@code {
    [Parameter]
    public long Id { get; set; }

    private SeatingChart? _seatingChart;
    private string _secretKey = string.Empty;
    private string _eventKey = string.Empty;
    private string _eventName = string.Empty;
    private bool _loading = true;
    private bool _holdProcessing => CartState.IsHoldCallsInProgress;
    private bool _error = false;

    private EventInfoDTO? _eventInfo;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += StateHasChanged;
        await LoadEventData();
    }

    private async Task LoadEventData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _eventInfo = await AdminClient.GetEventByIdAsync(Id);
            _eventName = _eventInfo.Name ?? string.Empty;
            _eventKey = _eventInfo.ExternalEventKey ?? string.Empty;
            _secretKey = SeatsOptions.Value.SecretKey;

            CartState.SetEvent(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading event data: {ex.Message}");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task Submit()
    {
        if (CartState.IsHoldCallsInProgress)
        {
            Snackbar.Add(Localizer["Seats_ConfirmingStatus"], Severity.Warning);
            return;
        }

        var token = CartState.HoldToken;

        if (string.IsNullOrEmpty(token))
        {
            Snackbar.Add(Localizer["Seats_SessionExpired"], Severity.Error);
            return;
        }

        var request = new BookingRequest
        {
            Seats = CartState.SelectedSeats.Select(x => x.SeatId).ToList(),
            HoldToken = token,
            EventId = _eventKey
        };

        try
        {
            var result = await AdminClient.BookSeatsAsync(request);

            Snackbar.Add(Localizer["Seats_PaymentSuccess"], configure: c =>
            {
                c.SnackbarVariant = Variant.Text;
                c.Icon = Icons.Custom.Uncategorized.AlertSuccess;
                c.IconColor = Color.Success;
            });

            Navigation.NavigateTo("/events");
        }
        catch (Exception)
        {
            Snackbar.Add(Localizer["Seats_PaymentError"], Severity.Error);
        }
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }
}
