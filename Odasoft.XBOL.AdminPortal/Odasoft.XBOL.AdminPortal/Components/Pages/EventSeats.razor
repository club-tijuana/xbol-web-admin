@page "/events/{Id:long}/seats"
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.AdminPortal.Configs
@using Microsoft.Extensions.Options
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.Business

@implements IDisposable
@inject CartState CartState
@inject ISnackbar Snackbar
@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@inject IOptions<SeatsIo> SeatsOptions
@inject AppLocalizer<Events> L

<PageTitle>@_eventName</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => GoToEvents())"
                        Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">Regresar</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer 
    IsLoading="_loading" 
    HasError="_error"
    ErrorMessage="Error al cargar el evento"
    OnRetry="LoadEventData">
    <ImageHeroBanner Banner="_banner"></ImageHeroBanner>
    <MudPaper Class="pa-6" Elevation="3">   
            @if (_currentStep == 1)
            {
                <MudGrid Justify="Justify.SpaceBetween">
                    <MudItem xs="12" Class="d-flex justify-space-between">
                        <MudText Typo="Typo.h5">Asientos</MudText>
                        <MudButton Variant="Variant.Filled"
                                    DropShadow="false"
                                    EndIcon="@Icons.Material.Filled.NavigateNext"
                                    Color="Color.Primary"
                                    Disabled="@(CartState.IsHoldCallsInProgress || CartState.SelectedSeats.Count == 0)"
                                    @onclick="NextStep">
                                @(_holdProcessing? L["Seats_HoldProcessing"] : "MÉTODO DE PAGO")
                        </MudButton>
                    </MudItem>
                    <MudItem xs="7">
                        <SeatingChart @ref="_seatingChart" SecretKey="@_secretKey" EventKey="@_eventKey" EventId="Id" Prices="_eventInfo?.Prices" SelectedSeats="@CartState.SelectedSeatsKeys" />
                    </MudItem>
                    <MudItem xs="4" Class="mt-8">
                        <OrderSummary Chart="_seatingChart" />
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <EventCheckout OnReturn="PreviousStep" EventKey="@_eventKey"></EventCheckout>
            }
    </MudPaper>
</LoadingContainer>

@code {
    [Parameter]
    public long Id { get; set; }

    private SeatingChart? _seatingChart;
    private ImageHeroBannerViewModel _banner = new();
    private string _secretKey = string.Empty;
    private string _eventKey = string.Empty;
    private string _eventName = string.Empty;
    private bool _loading = true;
    private bool _holdProcessing => CartState.IsHoldCallsInProgress;
    private bool _error = false;

    private int _currentStep = 1;

    private EventInfoDTO? _eventInfo;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += StateHasChanged;
        CartState.ClearCart();
        await LoadEventData();
    }

    private async Task LoadEventData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _eventInfo = await AdminClient.GetEventByIdAsync(Id);
            _eventName = _eventInfo.Name ?? string.Empty;
            _eventKey = _eventInfo.ExternalEventKey ?? string.Empty;
            _secretKey = SeatsOptions.Value.SecretKey;

            _banner = new()
            {
               Title = _eventInfo.Name,
               Subtitle = _eventInfo.Subtitle,
               StartDateTime = _eventInfo.ScheduledStartDate?.UtcDateTime,
               EndDateTime = _eventInfo.ScheduledEndDate?.UtcDateTime,
               ImageUrl = _eventInfo.BannerImageUrl,
               Venue = _eventInfo.VenueName,
            };

            CartState.SetEvent(Id);
            CartState.ClearToken();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading event data: {ex.Message}");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void NextStep()
    {
        if(_currentStep < 2)
        {
            _currentStep++;
        }
    }

    private void PreviousStep()
    {
        if(_currentStep > 1)
        {
            _currentStep--;
        }
    }

    private void GoToEvents()
    {
        Navigation.NavigateTo("/events");
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }
}
