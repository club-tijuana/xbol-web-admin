@page "/events"
@page "/events/{Tab}"
@using Odasoft.XBOL.Auth
@attribute [RequireAnyPermission(AdminPermissions.Events.Read, AdminPermissions.Events.ReadCurrent)]

@using Odasoft.XBOL.AdminPortal.Components
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.Services
@using Odasoft.XBOL.AdminPortal.ViewModels
@using Odasoft.XBOL.Business

@inject AppLocalizer<Events> L
@inject IEventService EventService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject ILogger<Events> Logger

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudToggleGroup T="string" Value="@_selectedTab" ValueChanged="OnTabChanged" CheckMark="false"
                            Class="border-secondary-lighten" Color="Color.Secondary">
                <MudToggleItem Value="@UpcomingTab" Text="@L["TabUpcoming"]"
                               Class="@($"px-4 {(_selectedTab == UpcomingTab ? "bg-secondary-darken" : "")}")" />
                <MudToggleItem Value="@PassesTab" Text="@L["TabPasses"]"
                               Class="@($"px-4 {(_selectedTab == PassesTab ? "bg-secondary-darken" : "")}")" />
                <MudToggleItem Value="@PackagesTab" Text="@L["TabPackages"]"
                               Class="@($"px-4 {(_selectedTab == PackagesTab ? "bg-secondary-darken" : "")}")" />
                <MudToggleItem Value="@PastTab" Text="@L["TabPast"]"
                               Class="@($"px-4 {(_selectedTab == PastTab ? "bg-secondary-darken" : "")}")" />
            </MudToggleGroup>
        </LeftContent>
        <RightContent>
            <MudStack Row Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           Href="./events/create">
                    @L["NewEvent"]
                </MudButton>
                <MudMenu Label="@L["NewBundle"]"
                         Variant="Variant.Filled"
                         Color="Color.Primary"
                         StartIcon="@Icons.Material.Outlined.LibraryAdd"
                         EndIcon="@Icons.Material.Filled.ArrowDropDown">
                    <MudMenuItem Icon="@Icons.Material.Outlined.Layers"
                                 IconColor="Color.Secondary"
                                 OnClick="@(() => Navigation.NavigateTo("./events/bundles/basic/create"))">
                        @L["NewPackage"]
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.ConfirmationNumber"
                                 IconColor="Color.Secondary"
                                 OnClick="@(() => Navigation.NavigateTo("./events/bundles/season-pass/create"))">
                        @L["NewSeasonPass"]
                    </MudMenuItem>
                </MudMenu>
            </MudStack>
        </RightContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer IsLoading="_loading">
    @if (_selectedTab == UpcomingTab)
    {
        <MudGrid Spacing="4">
            @if (_catalogItems.Count == 0)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info">@L["NoEventsFound"]</MudAlert>
                </MudItem>
            }
            else
            {
                @foreach (var item in _catalogItems)
                {
                    <MudItem xs="12" sm="6" lg="4" xl="3">
                        <EventCard Event="item"
                                   ShowActions
                                   OnClick="@(() => OpenCatalogItem(item))" />
                    </MudItem>
                }

                @if (PageCount(_catalogTotalItems, CatalogPageSize) > 1)
                {
                    <MudItem xs="12" Class="d-flex justify-center mt-4">
                        <MudPagination Color="Color.Primary"
                                       Count="@PageCount(_catalogTotalItems, CatalogPageSize)"
                                       Selected="@_catalogPage"
                                       SelectedChanged="OnCatalogPageChanged" />
                    </MudItem>
                }
            }
        </MudGrid>
    }
    else if (_selectedTab == PassesTab)
    {
        @RenderBundleRows(_seasonPassBundles, L["PassesTitle"], _seasonPassTotalItems, _seasonPassPage, OnSeasonPassPageChanged)
    }
    else if (_selectedTab == PackagesTab)
    {
        @RenderBundleRows(_basicBundles, L["PackagesTitle"], _basicTotalItems, _basicPage, OnBasicPageChanged)
    }
    else
    {
        <MudCard Elevation="2">
            <EventCatalogDataGrid Title="@L["PastEvents"]"
                                  Upcoming="false" />
        </MudCard>
    }
</LoadingContainer>

    @code {
    [Parameter] public string? Tab { get; set; }

    private const string UpcomingTab = "upcoming";
    private const string PassesTab = "passes";
    private const string PackagesTab = "packages";
    private const string PastTab = "past";
    private const int BundleRowHeight = 330;
    private const int CatalogPageSize = 12;
    private const int BundlePageSize = 10;

    private string _selectedTab = UpcomingTab;
    private bool _loading;
    private int _catalogPage = 1;
    private int _catalogTotalItems;
    private int _seasonPassPage = 1;
    private int _seasonPassTotalItems;
    private int _basicPage = 1;
    private int _basicTotalItems;
    private List<EventViewModel> _catalogItems = [];
    private List<EventViewModel> _seasonPassBundles = [];
    private List<EventViewModel> _basicBundles = [];

    protected override async Task OnParametersSetAsync()
    {
        var nextTab = Tab?.ToLowerInvariant() switch
        {
            PassesTab => PassesTab,
            PackagesTab => PackagesTab,
            PastTab => PastTab,
            _ => UpcomingTab
        };

        if (_selectedTab != nextTab || ShouldLoad(nextTab))
        {
            _selectedTab = nextTab;
            await LoadSelectedTabAsync();
        }
    }

    private void OnTabChanged(string tab)
    {
        Navigation.NavigateTo($"./events/{tab}", replace: true);
    }

    private bool ShouldLoad(string tab)
    {
        return tab switch
        {
            UpcomingTab => _catalogItems.Count == 0,
            PassesTab => _seasonPassBundles.Count == 0,
            PackagesTab => _basicBundles.Count == 0,
            _ => false
        };
    }

    private async Task LoadSelectedTabAsync()
    {
        if (_selectedTab == PastTab)
        {
            return;
        }

        _loading = true;
        try
        {
            if (_selectedTab == UpcomingTab)
            {
                var result = await LoadCatalogItemsAsync(null, _catalogPage, CatalogPageSize);
                _catalogItems = result.Items.ToList();
                _catalogTotalItems = result.TotalItems;
            }
            else if (_selectedTab == PassesTab)
            {
                var result = await LoadCatalogItemsAsync(BundleType.SeasonPass, _seasonPassPage, BundlePageSize);
                _seasonPassBundles = result.Items.ToList();
                _seasonPassTotalItems = result.TotalItems;
            }
            else if (_selectedTab == PackagesTab)
            {
                var result = await LoadCatalogItemsAsync(BundleType.Basic, _basicPage, BundlePageSize);
                _basicBundles = result.Items.ToList();
                _basicTotalItems = result.TotalItems;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load events tab {Tab}", _selectedTab);
            Snackbar.Add(L["ErrorLoadingEvents"], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<GridData<EventViewModel>> LoadCatalogItemsAsync(BundleType? bundleType, int page, int pageSize)
    {
        return await EventService.GetEventCatalogAsync(
            page: page - 1,
            pageSize: pageSize,
            sortColumn: "startDate",
            sortDescending: false,
            itemType: bundleType is null ? null : EventCatalogItemType.Bundle,
            bundleType: bundleType,
            upcoming: true);
    }

    private void OpenCatalogItem(EventViewModel item)
    {
        var url = BuildCatalogItemUrl(item);
        Navigation.NavigateTo(url);
    }

    private string BuildCatalogItemUrl(EventViewModel item)
    {
        var bundleSegment = item.IsBundle ? item.Status == AdminEventStatus.Published ? "/bundles" : $"/bundles/{item.BundleType?.ToString().ToLower()}" : string.Empty;
        var workflowSegment = item.Status == AdminEventStatus.PendingReview ? "/review"
            : item.Status == AdminEventStatus.ChangesRequested ? "/edit"
            : item.Status == AdminEventStatus.Draft ? "/edit"
            : item.Status == AdminEventStatus.Approved ? "/edit"
            : string.Empty;

        return $"./events{bundleSegment}/{item.Id}{workflowSegment}";
    }

    private async Task OnCatalogPageChanged(int page)
    {
        _catalogPage = page;
        await LoadSelectedTabAsync();
    }

    private async Task OnSeasonPassPageChanged(int page)
    {
        _seasonPassPage = page;
        await LoadSelectedTabAsync();
    }

    private async Task OnBasicPageChanged(int page)
    {
        _basicPage = page;
        await LoadSelectedTabAsync();
    }

    private static int PageCount(int totalItems, int pageSize)
    {
        return (int)Math.Ceiling((double)totalItems / pageSize);
    }

    private RenderFragment RenderBundleRows(
        IReadOnlyCollection<EventViewModel> items,
        string title,
        int totalItems,
        int selectedPage,
        Func<int, Task> pageChanged) => @<MudStack Spacing="4">
        @if (items.Count == 0)
        {
            <MudAlert Severity="Severity.Info">@L["NoEventsFound"]</MudAlert>
        }
        else
        {
            @foreach (var bundle in items)
            {
                <MudCard Elevation="2" Class="mb-2">
                    <MudGrid Spacing="0">
                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Elevation="0" Class="rounded-0 border-r" Style="border-color: var(--mud-palette-gray-lighter);">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                            @(string.IsNullOrWhiteSpace(bundle.Code) ? title : bundle.Code)
                                        </MudText>
                                        <MudText Typo="Typo.subtitle2">@bundle.EventName</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Secondary" Disabled />
                                    </CardHeaderActions>
                                </MudCardHeader>

                                @if (string.IsNullOrEmpty(bundle.PosterImageUrl) && string.IsNullOrEmpty(bundle.BannerImageUrl))
                                {
                                    <ImagePlaceholder Height="@(BundleRowHeight + "px")" />
                                }
                                else
                                {
                                    <MudCardMedia Image="@(bundle.PosterImageUrl ?? bundle.BannerImageUrl)" Height="@BundleRowHeight" />
                                }
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="9">
                            <BundleSchedulesDataGrid BundleId="@bundle.Id"
                                                     Height="@((BundleRowHeight - 55) + "px")"
                                                     Dense
                                                     HideTitle />
                        </MudItem>
                    </MudGrid>
                </MudCard>
            }

            @if (PageCount(totalItems, BundlePageSize) > 1)
            {
                <MudStack Row Justify="Justify.Center" Class="mt-4">
                    <MudPagination Color="Color.Primary"
                                   Count="@PageCount(totalItems, BundlePageSize)"
                                   Selected="@selectedPage"
                                   SelectedChanged="@(async (int nextPage) => await pageChanged(nextPage))" />
                </MudStack>
            }
        }
    </MudStack>;
}
