@page "/suites/settings"

@using Odasoft.XBOL.AdminPortal.Extensions;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants
@using Odasoft.XBOL.Models.Parameters;
@using Odasoft.XBOL.Models.ViewModels;

@inject CatalogsService _catalogsService;
@inject SuitesService _suitesService;
@inject ISnackbar _snackbar;
@inject NavigationManager _navigationManager;
@inject IDialogService _dialogService;

<PageTitle>Palcos - Configuración</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <RightContent>
            <MudButton StartIcon="@Icons.Material.Outlined.Add" OnClick="@(() => CreateSuite())"
                    Color="Color.Primary" Variant="Variant.Filled" Class="text-uppercase">Nuevo Palco</MudButton>
        </RightContent>
    </PageActionBar>
</SectionContent>

<MudCard Elevation="3">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="SuitesViewModel" @ref="_dataGrid" ServerData="ServerReloadAsync" Loading="_loading" Filterable="false"
                     FilterMode="DataGridFilterMode.Simple" Hover="true" Elevation="0">
            <ToolBarContent>
                <MudGrid Class="align-center">
                    <MudItem xs="12" sm="6" lg="8">
                        <MudText Class="pl-lg-4" Typo="Typo.h5">Palcos - Configuración</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="4">
                        <MudStack Row AlignItems="AlignItems.Center">
                            <!-- Search field -->
                            <MudTextField @bind-Value="_searchTerm"
                                          @bind-Value:after="@(() => _dataGrid.ReloadServerData())" Placeholder="Buscar"
                                          Adornment="Adornment.Start" Immediate="true" Variant="Variant.Outlined"
                                          AdornmentAriaLabel="Buscar" AdornmentIcon="@Icons.Material.Filled.Search"
                                          IconSize="Size.Medium" Margin="Margin.Dense" Typo="Typo.body2" Class="flex-grow-1"
                                          DebounceInterval="500" />

                            <!-- Level multi-select -->
                            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <ActivatorContent>
                                    <MudIconButton Icon="@Icons.Material.Outlined.FilterAlt" Color="Color.Secondary" />
                                </ActivatorContent>
                                <ChildContent>
                                    <MudStack Spacing="3" Class="pa-4" Style="width:375px">
                                        <!-- Venue multi-select -->
                                        <MudSelect T="string" Label="Nivel" MultiSelection="true"
                                                   Margin="Margin.Dense" @bind-SelectedValues="_selectedSuiteLevels"
                                                   Variant="Variant.Outlined" ShrinkLabel>
                                            @foreach (var level in _suiteLevels)
                                            {
                                                <MudSelectItem T="string" Value="@level.Name">
                                                    <MudText Typo="Typo.body2">@level.Name</MudText>
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        <MudStack Row Justify="Justify.SpaceBetween" Spacing="2" Class="mt-2">
                                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Reorder"
                                                       Class="mud-no-activator" OnClick="ClearFiltersAsync">
                                                Limpiar
                                            </MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Tertiary"
                                                       StartIcon="@Icons.Material.Filled.Search" OnClick="ApplyFiltersAsync">
                                                Aplicar
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                </ChildContent>
                            </MudMenu>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Title="Nivel" Property="x => x.Level" Sortable="true" Filterable="false" InitialDirection="SortDirection.Ascending">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="pl-lg-4">@context.Item.Level</MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Title="Palco" Property="x => x.Name" Sortable="true" Filterable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @context.Item.Name
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Title="Asientos" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @context.Item.Seats
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Filterable="false" Sortable="false">
                    <CellTemplate>
                        <MudStack Row>
                            <MudTooltip Text="Editar" Placement="Placement.Top">
                                <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Medium"
                                               OnClick="@(() => _navigationManager.NavigateTo($"/suites/{context.Item.Id}/update"))" />
                            </MudTooltip>

                            <MudTooltip Text="Borrar" Placement="Placement.Top">
                                <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Medium"
                                               OnClick="@(() => DeleteSuiteAsync(context.Item.Id))" />
                            </MudTooltip>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>
                <CustomMudDataGridPager T="SuitesViewModel" />
            </PagerContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private bool _loading = false;
    private string _searchTerm = "";

    private MudDataGrid<SuitesViewModel> _dataGrid = default!;

    private SuitesFilterParameters _filters = new SuitesFilterParameters();

    private List<ListItem> _suiteLevels = [];
    private IEnumerable<string> _selectedSuiteLevels = new HashSet<string>();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _suiteLevels = await _catalogsService.GetSuiteLevelsAsync();

        StateHasChanged();
    }

    private async Task<GridData<SuitesViewModel>> FetchFromServerAsync(GridState<SuitesViewModel> state)
    {
        var sortDefinition = state.SortDefinitions.FirstOrDefault();

        _filters = new SuitesFilterParameters
        {
            Levels = _selectedSuiteLevels.ToList(),
            SearchTerm = _searchTerm,
            SortBy = sortDefinition?.SortBy ?? "",
            Descending = sortDefinition?.Descending ?? false,
            Page = state.Page,
            PageSize = state.PageSize
        };

        SuiteResultPagedResponse result = await _suitesService.GetSuitesAsync(_filters);

        return new GridData<SuitesViewModel>
        {
            TotalItems = result.TotalCount,
            Items = result.Items.Select(suite => new SuitesViewModel
            {
                Id = suite.Id,
                Name = suite.Name,
                Level = suite.SuiteLevelName,
                Seats = suite.Seats
            }).ToArray() ?? []
        };
    }

    private async Task<GridData<SuitesViewModel>> ServerReloadAsync(GridState<SuitesViewModel> state)
    {
        _loading = true;

        try
        {
            var data = await FetchFromServerAsync(state);
            return data;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching suites: {ex.Message}");

            _snackbar.Add("Error al cargar los palcos. Por favor, inténtalo de nuevo más tarde.", Severity.Error);

            return new GridData<SuitesViewModel>
            {
                TotalItems = 0,
                Items = new List<SuitesViewModel>()
            };

        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        await _dataGrid.ReloadServerData();
    }

    private async Task ClearFiltersAsync()
    {
        _filters = new SuitesFilterParameters();
        _selectedSuiteLevels = new HashSet<string>();
        await _dataGrid.ReloadServerData();
    }

    private void CreateSuite()
    {
        _navigationManager.NavigateTo(SitePages.SUITES_CREATE);
    }

    private async Task DeleteSuiteAsync(long suiteId)
    {
        bool dialogResult = await DialogServiceExtensions.ShowConfirmDeleteAsync(_dialogService,
                             "Eliminar Palco",
                              "Esta acción no se puede deshacer. ¿Está seguro de que desea eliminar este palco?");

        if (dialogResult)
        {
            try
            {
                bool result = await _suitesService.DeleteSuiteAsync(suiteId);
                if (result)
                {
                    _snackbar.Add("Palco eliminado exitosamente.", Severity.Success);
                    await _dataGrid.ReloadServerData();
                }
                else
                {
                    _snackbar.Add("Error al eliminar el palco.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting suite: {ex.Message}");
                _snackbar.Add("Error al eliminar el palco.", Severity.Error);
            }
        }
    }
}
