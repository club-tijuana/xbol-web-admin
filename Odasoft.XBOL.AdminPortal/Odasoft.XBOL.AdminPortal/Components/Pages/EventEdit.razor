    private async Task LoadPrices()
    {
        if(ScheduleId == null || _selectedVenueMap == null)
        {
            InitializeEmptyPrices();
            return;
        }

        try
        {
            PricesResponse priceResponse = await PriceService.GetPricesByScheduleAndVenueAsync(ScheduleId.Value, _selectedVenueMap.Id);

            _prices = priceResponse.Prices.Select(x => new PriceForm
            {
                Id = x.Id,
                BaseZoneId = x.BaseZoneId,
                BaseSectionId = x.BaseSectionId,
                BaseRowId = x.BaseRowId,
                BaseSeatId = x.BaseSeatId,
                ItemPrice = x.ItemPrice,
                PriceTypes = x.PriceTypes.ToDictionary(pt => pt.Name, pt => pt.Price)
            }).ToList();

            foreach (var priceType in priceResponse.PriceTypes)
            {
                if (!PriceTypes.Contains(priceType.Name))
                {
                    PriceTypes.Add(priceType.Name);
                }
            }
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode == StatusCodes.Status404NotFound)
            {
                InitializeEmptyPrices();
            }
        }
    }

    private void InitializeEmptyPrices()
    {
        if (_layout.Zones is not null && _layout.Zones.Count > 0)
        {
            _prices.Clear();
            foreach (var zone in _layout.Zones)
            {
                _prices.Add(new PriceForm
                {
                   BaseZoneId = zone.Id
                });
            }
        }
    }

    private void AddPriceType(string type)
    {
        if (!string.IsNullOrWhiteSpace(type) && !PriceTypes.Contains(type))
        {
            PriceTypes.Add(type);
        }
    }

    private void EditPriceType(string oldName, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName) || PriceTypes.Contains(newName))
        {
            return;
        }
        int index = PriceTypes.IndexOf(oldName);
        if (index != -1)
        {
            PriceTypes[index] = newName;
            foreach (var price in _prices)
            {
                if (price.PriceTypes.ContainsKey(oldName))
                {
                    decimal? value = price.PriceTypes[oldName];
                    price.PriceTypes.Remove(oldName);
                    price.PriceTypes[newName] = value;
                }
            }
        }
    }

    private async Task DeletePriceType()
    {
        PriceTypes.Remove(_priceTypeName);

        foreach (var price in _prices)
        {
            if (price.PriceTypes.ContainsKey(_priceTypeName))
