        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode != StatusCodes.Status404NotFound)
            {
                EventState.AdditionalChargesInfo.AdditionalCharges = [];
            }
            _additionalChargesHaveChanges = false;
        }
    }

