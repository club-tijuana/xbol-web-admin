        }
    }

    private async Task SaveHorizontalImageAsync()
    {
        try
        {
            if (_horizontalImage == null)
            {
                return;
            }

            if (_horizontalImage.Id.HasValue && _horizontalImage.TempFile != null)
            {
                await EventService.UpdateEventImageAsync(_horizontalImage.Id.Value, ImageType.HorizontalPoster, 0, new FileParameter(
                _horizontalImage.TempFile.OpenReadStream(_maxFileSize),
                _horizontalImage.TempFile.Name,
                _horizontalImage.TempFile.ContentType));
            }
            else if (_horizontalImage.Id.HasValue == false && _horizontalImage.TempFile != null)
            {
                _horizontalImage.Id = await EventService.UploadEventImageAsync(EventId, ImageType.HorizontalPoster, 0, new FileParameter(
                     _horizontalImage.TempFile.OpenReadStream(_maxFileSize),
                    _horizontalImage.TempFile.Name,
                    _horizontalImage.TempFile.ContentType));
            }
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode != StatusCodes.Status201Created
                && apiEx.StatusCode != StatusCodes.Status204NoContent)
            {
                throw;
            }
        }
    }

