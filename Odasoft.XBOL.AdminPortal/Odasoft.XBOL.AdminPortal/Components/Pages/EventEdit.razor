                                <MudItem xs="12">
                                    <MudStack>
                                        <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight: 600;">@L["GalleryPreview"]</MudText>
                                        @if (!EventState.ImagesInfo.GalleryImages.Any())
                                        {
                                            <ImagePlaceholder Class="rounded-lg" Height="200px" Width="355px" />
                                        }
                                        else
                                        {
                                            <MudCarousel
                                            @ref="_carousel"
                                            ItemsSource="EventState.ImagesInfo.GalleryImages"
                                            Style="height:200px; width: 355px;"
                                            ShowArrows
                                            ShowBullets>
                                                <ItemTemplate>
                                                    <MudImage Src="@context.Src"
                                                    Class="rounded-lg"
                                                    ObjectFit="ObjectFit.Cover"
                                                    ObjectPosition="ObjectPosition.Center"
                                                    Height="200"
                                                    Width="355" />
                                                </ItemTemplate>
                                            </MudCarousel>
                                        }
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                </ChildContent>
                <ActionContent Context="stepperContext">
                    <MudSpacer />
                    @if (_activeIndex < _maxIndex)
                    {
                        <MudButton OnClick="ValidateAndGoNextAsync"
                                   EndIcon="@Icons.Material.Filled.ChevronRight"
                                   Variant="Variant.Text"
                                   Color="MudBlazor.Color.Primary">
                            @L["Next"]
                        </MudButton>
                    }
                    else if (_activeIndex == _maxIndex && !_isReview)
                    {
                        <MudButton OnClick="SubmitAsync"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Outlined.Save"
                                   Color="MudBlazor.Color.Tertiary">
                            @L["Save"]
                        </MudButton>
                    }
                </ActionContent>
            </MudStepper>
        </MudCardContent>
    </MudCard>
</LoadingContainer>

@code {
    [Parameter] public long? EventId { get; set; }
    [Parameter] public long? ScheduleId { get; set; }

    private long? _priceReferenceId = null;

    private string _pageTitle = "";
    private bool _loading = true;
    private bool _error = false;
    private bool _isEdit = false;
    private bool _isReview = false;
    private bool _canCopyPrices;

    private MudStepper _stepper = null!;
    private int _activeIndex = 0;
    private int _maxIndex = 4;
    private HashSet<int> _visitedSteps = new();

    private EventFormModel EventState { get; set; } = new();

    private EventInfoModel _originalEventInfo = new();
    private ScheduleInfoModel _originalScheduleInfo = new();
    private HashSet<long> _dirtyPriceIds = new();
    private bool _pricesHaveChanges = false;
    private bool _additionalChargesHaveChanges = false;
    private bool _imageHasChanges = false;

    private MudForm _descriptionForm = default!;
    private bool _descriptionFormValid = true;
    private bool _descriptionFormCompleted = false;
    private EventInfoValidator<EventEdit> _eventInfoValidator;
    private FormContext _descriptionFormContext = default!;

    private MudForm _scheduleForm = default!;
    private bool _scheduleValid = true;
    private bool _scheduleCompleted = false;
    private ScheduleInfoValidator<EventEdit> _scheduleValidator;
    private FormContext _scheduleFormContext = default!;

    private MudForm _pricesForm = default!;
    private bool _pricesValid = true;
    private bool _pricesCompleted = false;
    private PricesInfoValidator<EventEdit> _pricesValidator;
    private FormContext _pricesFormContext = default!;

    private MudForm _additionalChargesForm = default!;
    private bool _additionalChargesValid = true;
    private bool _additionalChargesCompleted = false;
    private AdditionalChargesInfoValidator<EventEdit> _additionalChargesInfoValidator;
    private AdditionalChargeInfoValidator<EventEdit> _additionalChargeInfoValidator;
    private FormContext _additionalChargesFormContext = default!;
    private MudDataGrid<AdditionalChargeInfoModel> _additionalChargesGrid = default!;

    private MudForm _imagesForm = default!;
    private bool _imagesValid = true;
    private bool _imagesCompleted = false;
    private ImagesInfoValidator<EventEdit> _imagesValidator;
    private FormContext _imagesFormContext = default!;

    private bool IsFormReadyToSubmit => _descriptionFormValid && _scheduleValid && _pricesValid && _imagesValid && _additionalChargesValid;

    private IReadOnlyList<DateTimelineStep> EventTimelineSteps =>
    [
        new(L["EventDatesTimelinePublishLabel"].Value, L["EventDatesTimelinePublishDescription"].Value),
        new(L["EventDatesTimelinePreSaleLabel"].Value, L["EventDatesTimelinePreSaleDescription"].Value),
        new(L["EventDatesTimelineSaleLabel"].Value, L["EventDatesTimelineSaleDescription"].Value),
        new(L["EventDatesTimelineAccessLabel"].Value, L["EventDatesTimelineAccessDescription"].Value),
        new(L["EventDatesTimelineEventLabel"].Value, L["EventDatesTimelineEventDescription"].Value)
    ];

    private List<AdminEventCategoryResult> _eventCategories = [];
    private List<AgeRestriction> _ageRestrictions = Enum.GetValues<AgeRestriction>().ToList();
    private List<FeeType> _feeTypes = Enum.GetValues<FeeType>().ToList();
    private List<ChargeCategory> _chargeCategories = Enum.GetValues<ChargeCategory>().ToList();
    private List<VenueResponse> _venues = [];
    private List<VenueMapResponse> _venueMaps = [];
    private List<ListItem> _organizers = [];

    private MudFileUpload<IBrowserFile> _bannerImageUpload = null!;
    private MudFileUpload<IBrowserFile>[] _sponsorUploads = new MudFileUpload<IBrowserFile>[2];
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _galleryUpload = null!;
    private MudCarousel<ImageModel> _carousel = null!;

    private readonly long _maxFileSize = 10 * 1024 * 1024; // 10 MB
    private readonly int _minWidth = 1920;
    private readonly int _minHeight = 1080;

    private const string DefaultDragClass = "relative d-flex flex-column p-r gap-2 rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full";
    private string _dragClass = DefaultDragClass;
    private bool _dragging = false;

    private AdminEventStatus? _eventStatus;

    private long? _currentPricesMapId;
    private string _searchPrices = string.Empty;
    private TableGroupDefinition<PriceInfoModel> _groupDefinition = new()
    {
        GroupName = "Zone",
        Indentation = true,
        Expandable = false,
        Selector = (e) => e.BaseZoneId,
        IsInitiallyExpanded = true
    };

    private Dictionary<string, bool> PriceTypes { get; set; } = new Dictionary<string, bool> { { "General", true } };
    private string _priceTypeName = string.Empty;

    private VenueMapLayoutResponse _layout;

    private string? _venueAddress;
    private string? _venueCoordinates;

    private static readonly DialogOptions _dialogOptions = new() { CloseButton = true };

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _descriptionFormContext.SetForm(_descriptionForm);
            await InitializeForm();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _descriptionFormContext = new FormContext(StateHasChanged);
        _scheduleFormContext = new FormContext(StateHasChanged);
        _pricesFormContext = new FormContext(StateHasChanged);
        _additionalChargesFormContext = new FormContext(StateHasChanged);
        _imagesFormContext = new FormContext(StateHasChanged);

        // TODO: Change to use user permissions instead of URL to determine read-only mode
        if (Navigation.Uri.Contains("/review"))
        {
            _isReview = true;
        }

        _eventInfoValidator = new(L);
        _scheduleValidator = new(L);
        _pricesValidator = new(L);
        _additionalChargesInfoValidator = new(L);
        _additionalChargeInfoValidator = new(L);
        _imagesValidator = new(L);

        if (AuthenticationStateTask is not null)
        {
            var authState = await AuthenticationStateTask;
            _canCopyPrices = authState.User.HasClaim(AdminClaimTypes.Role, AdminRoles.Debug.Admin);
        }
    }

    private async Task InitializeForm()
    {
        _loading = true;
        _error = false;
        StateHasChanged();
        try
        {
            await LoadCatalogs();
            if (EventId.HasValue && EventId.Value > 0)
            {
                _isEdit = true;
                await LoadData();
                _pageTitle = EventState.EventInfo.Name;
            }
            else
            {
                _pageTitle = L["CreateEvent"];
                _isEdit = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCatalogs()
    {
        var venueTask = CatalogsService.GetVenuesAsync();
        var catTask = EventService.GetCategoriesAsync();
        var organizersTask = OrganizersService.GetOrganizersCatalogAsync();

        await Task.WhenAll(venueTask, catTask, organizersTask);

        _venues = await venueTask;
        _eventCategories = (await catTask).Where(c => c.IsActive == true).ToList();
        _organizers = (await organizersTask).ToList();
    }

    private async Task LoadData()
    {
        if(EventId is null || EventId <= 0)
        {
            return;
        }

        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            var eventResult = await EventService.GetEventByIdAsync(EventId.Value);

            ScheduleId = ScheduleId ?? eventResult.Schedules?.First().Id;

            var schedule = eventResult.Schedules?.FirstOrDefault(s => s.Id == ScheduleId);

            EventState.EventInfo.Name = eventResult.Name;
            EventState.EventInfo.Subtitle = eventResult.Subtitle;
            EventState.EventInfo.ShortDescription = eventResult.ShortDescription;
            EventState.EventInfo.LongDescription = eventResult.LongDescription;
            EventState.EventInfo.AgeRestriction = eventResult.AgeRestriction;
            EventState.EventInfo.SecurityPolicies = eventResult.SecurityPolicies;
            EventState.EventInfo.AdditionalComments = eventResult.AdditionalComments;
            EventState.EventInfo.SelectedCategories = eventResult.Categories.ToList();
            EventState.EventInfo.OrganizerId = eventResult.OrganizerId;
            _eventStatus = eventResult.Status;

            await OnVenueSelected(_venues.FirstOrDefault(v => v.Id == eventResult.VenueId));
            await OnVenueMapSelected(_venueMaps.FirstOrDefault(m => m.Id == eventResult.VenueMapId));

            if (schedule is not null)
            {
                EventState.ScheduleInfo.StartDate = DateTimeHelpers.ToNullableDateTime(schedule?.StartDateTime, LocalizationOptions.Value);
                EventState.ScheduleInfo.StartTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.StartDateTime, LocalizationOptions.Value);
                EventState.ScheduleInfo.EndDate = DateTimeHelpers.ToNullableDateTime(schedule?.EndDateTime, LocalizationOptions.Value);
                EventState.ScheduleInfo.EndTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.EndDateTime, LocalizationOptions.Value);
                EventState.ScheduleInfo.PreSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleStartDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.PreSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleStartDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.PreSaleEndDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleEndDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.PreSaleEndTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleEndDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.OnSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OnSaleDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.OnSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OnSaleDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.OffSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OffSaleDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.OffSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OffSaleDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.PublishedDate = DateTimeHelpers.ToNullableDateTime(schedule?.PublishedDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.PublishedTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PublishedDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.GateOpenDate = DateTimeHelpers.ToNullableDateTime(schedule?.GateOpenDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.GateOpenTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.GateOpenDate, LocalizationOptions.Value);
                EventState.ScheduleInfo.HoldExpirationInMinutes = schedule.HoldExpirationInMinutes;
                EventState.ScheduleInfo.ExternalEventKey = schedule.ExternalEventKey;
            }

            _layout = await VenueMapsService.GetVenueMapLayoutByIdAsync(EventState.EventInfo.SelectedVenueMap?.Id ?? 0);

            await LoadPrices();
            await LoadAdditionalCharges();
            await LoadEventMediaAsync();

            _originalEventInfo = EventState.EventInfo with { };
            _originalScheduleInfo = EventState.ScheduleInfo with { };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            await ValidateForm();
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadEventMediaAsync()
    {
        if (EventId is null || EventId <= 0)
        {
            return;
        }

        var media = await MediaService.GetEventMediaAsync(EventId.Value);

        EventState.ImagesInfo.BannerImage = ToImageModel(media.Banner, AdminMediaType.Banner);
        EventState.ImagesInfo.SponsorImages = new ImageModel?[2];
        EventState.ImagesInfo.GalleryImages = [];

        foreach (var sponsor in (media.Sponsors ?? []).OrderBy(s => s.Order ?? int.MaxValue))
        {
            var order = sponsor.Order ?? 0;
            if (order < 0 || order >= EventState.ImagesInfo.SponsorImages.Length)
            {
                continue;
            }

            EventState.ImagesInfo.SponsorImages[order] = ToImageModel(sponsor, AdminMediaType.Sponsor, order);
        }

        foreach (var (index, image) in (media.Gallery ?? []).OrderBy(g => g.Order ?? int.MaxValue).Index())
        {
            var imageModel = ToImageModel(image, AdminMediaType.Gallery, index);
            if (imageModel is not null)
            {
                imageModel.Order = index;
                EventState.ImagesInfo.GalleryImages.Add(imageModel);
            }
        }
    }

    private ImageModel? ToImageModel(MediaResponse? media, AdminMediaType mediaType, int order = 0)
    {
        if (media is null || !media.Id.HasValue)
        {
            return null;
        }

        return new ImageModel
        {
            Id = media.Id,
            Name = GetMediaName(media),
            ContentType = media.ContentType ?? string.Empty,
            Src = MediaUrlResolver.Resolve(media.Url) ?? string.Empty,
            Order = media.Order ?? order,
            MediaType = mediaType
        };
    }

    private static string GetMediaName(MediaResponse media)
        => !string.IsNullOrWhiteSpace(media.FileName)
            ? media.FileName
            : media.Title ?? string.Empty;

    private async Task OnVenueSelected(VenueResponse? venueSelected)
    {
        EventState.EventInfo.SelectedVenue = venueSelected;
        EventState.EventInfo.SelectedVenueMap = null;

        if (EventState.EventInfo.SelectedVenue is null)
        {
            _venueMaps = [];
            _venueAddress = null;
            _venueCoordinates = null;
            return;
        }

        LoadingState.Show();
        try
        {
            _venueMaps = await CatalogsService.GetVenueMapsByVenueId(EventState.EventInfo.SelectedVenue.Id);

            _venueAddress = $"{EventState.EventInfo.SelectedVenue.StreetAddress} {EventState.EventInfo.SelectedVenue.ExtNum}, {EventState.EventInfo.SelectedVenue.Neighborhood}, {EventState.EventInfo.SelectedVenue.ZipCode} {EventState.EventInfo.SelectedVenue.City}, {EventState.EventInfo.SelectedVenue.State}";
            _venueCoordinates = $"{EventState.EventInfo.SelectedVenue.Latitude}, {EventState.EventInfo.SelectedVenue.Longitude}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load venue");
            Snackbar.Add(L["ErrorLoadingVenue"], MudBlazor.Severity.Error);
        }
        finally
        {
            LoadingState.Hide();
        }
    }

    private async Task OnVenueMapSelected(VenueMapResponse? venueMap)
    {
        EventState.EventInfo.SelectedVenueMap = venueMap;
    }

    private async Task OnPreviewInteraction(StepperInteractionEventArgs arg)
    {
        bool isCurrentStepValid = false;
        switch (_activeIndex)
        {
            case 0:
                _descriptionFormContext.SetForm(_descriptionForm);
                isCurrentStepValid = await _descriptionFormContext.ValidateAsync();
                _descriptionFormValid = isCurrentStepValid;
                _descriptionFormCompleted = isCurrentStepValid;
                break;
            case 1:
                _pricesFormContext.SetForm(_pricesForm);
                isCurrentStepValid = await _pricesFormContext.ValidateAsync();
                _pricesValid = isCurrentStepValid;
                _pricesCompleted = isCurrentStepValid;
                break;
            case 2:
                _additionalChargesFormContext.SetForm(_additionalChargesForm);
                isCurrentStepValid = await _additionalChargesFormContext.ValidateAsync();
                _additionalChargesValid = isCurrentStepValid;
                _additionalChargesCompleted = isCurrentStepValid;
                break;
            case 3:
                _scheduleFormContext.SetForm(_scheduleForm);
                isCurrentStepValid = await _scheduleFormContext.ValidateAsync();
                _scheduleValid = isCurrentStepValid;
                _scheduleCompleted = isCurrentStepValid;
                break;
            case 4:
                _imagesFormContext.SetForm(_imagesForm);
                isCurrentStepValid = await _imagesFormContext.ValidateAsync();
                _imagesValid = isCurrentStepValid;
                _imagesCompleted = isCurrentStepValid;
                break;
            default:
                break;
        }

        if (_activeIndex == 0)
        {
            if (EventState.EventInfo.SelectedVenueMap is not null && _currentPricesMapId != EventState.EventInfo.SelectedVenueMap.Id)
            {
                _layout = await VenueMapsService.GetVenueMapLayoutByIdAsync(EventState.EventInfo.SelectedVenueMap.Id);
                await LoadPrices();
                _currentPricesMapId = EventState.EventInfo.SelectedVenueMap.Id;
            }
        }
    }

    private async Task HandleStepNavigation(int newIndex)
    {
        _visitedSteps.Add(_activeIndex);

        _activeIndex = newIndex;

        await Task.Yield();

        if (_visitedSteps.Contains(newIndex))
        {
            switch (newIndex)
            {
                case 0:
                    _descriptionFormContext.SetForm(_descriptionForm);
                    await _descriptionFormContext.ValidateAsync();
                    break;
                case 1:
                    _pricesFormContext.SetForm(_pricesForm);
                    await _pricesFormContext.ValidateAsync();
                    break;
                case 2:
                    _additionalChargesFormContext.SetForm(_additionalChargesForm);
                    await _additionalChargesFormContext.ValidateAsync();
                    break;
                case 3:
                    _scheduleFormContext.SetForm(_scheduleForm);
                    await _scheduleFormContext.ValidateAsync();
                    break;
                case 4:
                    _imagesFormContext.SetForm(_imagesForm);
                    await _imagesFormContext.ValidateAsync();
                    break;
            }
        }
    }

    private async Task GoBackAsync()
    {
        bool eventChanged = _originalEventInfo != EventState.EventInfo;
        bool scheduleChanged = _originalScheduleInfo != EventState.ScheduleInfo;
        bool pricesChanged = _pricesHaveChanges;
        bool additionalChargesChanged = _additionalChargesHaveChanges;
        bool imagesChanged = _imageHasChanges;

        bool changed = eventChanged || scheduleChanged || pricesChanged || additionalChargesChanged || imagesChanged;

        if (changed)
        {
            var result = await DialogService.ShowMessageBoxAsync(
                L["UnsavedChangesTitle"],
                L["UnsavedChangesMessage"],
                yesText: L["UnsavedChangesConfirm"],
                cancelText: L["UnsavedChangesCancel"]);

            if (result is not true) return;
        }

        Navigation.NavigateTo("./events");
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", CtrlKey: true })
        {
            if (_activeIndex < _maxIndex)
            {
                await ValidateAndGoNextAsync();
            }
            else if (_activeIndex == _maxIndex)
            {
                await SubmitAsync();
            }
        }
    }

    private async Task ValidateAndGoNextAsync()
    {
        await _stepper.NextStepAsync();
    }

    private async Task ValidateForm()
    {
        var eventInfoResult = await _eventInfoValidator.ValidateAsync(EventState.EventInfo);
        _descriptionFormValid = eventInfoResult.IsValid;
        _descriptionFormCompleted = _descriptionFormValid;

        var pricesResult = await _pricesValidator.ValidateAsync(EventState.PricesInfo);
        _pricesValid = pricesResult.IsValid;
        _pricesCompleted = _pricesValid;

        var additionalChargesResult = await _additionalChargesInfoValidator.ValidateAsync(EventState.AdditionalChargesInfo);
        _additionalChargesValid = additionalChargesResult.IsValid;
        _additionalChargesCompleted = _additionalChargesValid;

        var scheduleResult = await _scheduleValidator.ValidateAsync(EventState.ScheduleInfo);
        _scheduleValid = scheduleResult.IsValid;
        _scheduleCompleted = _scheduleValid;

        var imagesResult = await _imagesValidator.ValidateAsync(EventState.ImagesInfo);
        _imagesValid = imagesResult.IsValid;
        _imagesCompleted = _imagesValid;

        _visitedSteps.UnionWith(Enumerable.Range(1, _maxIndex));
    }

    private async Task SubmitAsync()
    {
        await ValidateForm();

        _imagesFormContext.SetForm(_imagesForm);
        if (!await _imagesFormContext.ValidateAsync() || !IsFormReadyToSubmit)
        {
            Snackbar.Add(L["InvalidForm"], MudBlazor.Severity.Warning);
            return;
        }

        _imagesFormContext.SetSaving(true);
        LoadingState.Show();
        try
        {
            var pricesChanged = _pricesHaveChanges;
            var additionalChargesChanged = _additionalChargesHaveChanges;

            await SaveEventAsync();

            if (_originalScheduleInfo != EventState.ScheduleInfo)
            {
                await SaveEventScheduleAsync();
            }
            if (_pricesHaveChanges)
            {
                await SavePricesAsync(force: false);
            }

            if (_additionalChargesHaveChanges)
            {
                await SaveAdditionalChargesAsync();
            }

            if (_imageHasChanges)
            {
                await SaveEventMediaAsync();
            }

            await RegeneratePublishedPriceListIfNeededAsync(pricesChanged, additionalChargesChanged);

            if (_eventStatus == AdminEventStatus.ChangesRequested)
            {
                await EventService.ResubmitEventAsync(EventId.Value);
            }

            Snackbar.Add(L["UpdateSuccess", L["Event"]], MudBlazor.Severity.Success);
            Navigation.NavigateTo("./events");
        }
        catch (ApiException<ValidationProblemDetails> ex)
        {
            Snackbar.Add(ex.Result.Title ?? L["ErrorSavingEvent"], MudBlazor.Severity.Error);
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _imagesFormContext.HandleApiException(ex);
            _imagesValidator.LoadServerErrors(ex);
            await _imagesFormContext.ValidateAsync();
            Snackbar.Add(ex.Result.Title ?? L["ErrorSavingEvent"], MudBlazor.Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save event");
            Snackbar.Add(L["ErrorSavingEvent"], MudBlazor.Severity.Error);
        }
        finally
        {
            _imagesFormContext.SetSaving(false);
            LoadingState.Hide();
        }
    }

    private async Task RegeneratePublishedPriceListIfNeededAsync(bool pricesChanged, bool additionalChargesChanged)
    {
        if (_eventStatus != AdminEventStatus.Published || EventId is null || (!pricesChanged && !additionalChargesChanged))
        {
            return;
        }

        await PriceReferenceService.GeneratePriceListAsync(AdminSaleType.Event, EventId.Value);
    }

    private async Task SaveEventAsync()
    {
        var request = new EventRequest
        {
            Name = EventState.EventInfo.Name,
            Subtitle = EventState.EventInfo.Subtitle,
            CategoryIds = EventState.EventInfo.SelectedCategories.Where(c => c.Id.HasValue).Select(c => c.Id!.Value).ToList(),
            ShortDescription = EventState.EventInfo.ShortDescription,
            LongDescription = EventState.EventInfo.LongDescription,
            VenueMapId = EventState.EventInfo.SelectedVenueMap?.Id,
            SecurityPolicies = EventState.EventInfo.SecurityPolicies,
            AdditionalComments = EventState.EventInfo.AdditionalComments,
            AgeRestriction = EventState.EventInfo.AgeRestriction,
            OrganizerId = EventState.EventInfo.OrganizerId
        };
        try
        {
            if (_isEdit || EventId.HasValue)
            {
                await EventService.UpdateEventAsync(EventId.Value, request);
            }
            else
            {
                EventResult result = await EventService.CreateEventAsync(request);
                EventId = result.Id;
            }
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _eventInfoValidator.LoadServerErrors(ex);

            if (_descriptionForm != null)
            {
                _descriptionFormContext.SetForm(_descriptionForm);
                await _descriptionFormContext.ValidateAsync();
            }

            var validationResult = await _eventInfoValidator.ValidateAsync(EventState.EventInfo);
            _descriptionFormValid = validationResult.IsValid && !_eventInfoValidator.ServerErrors.Any();
            StateHasChanged();
            throw;
        }
    }

    private async Task SaveEventScheduleAsync()
    {
        var request = new EventScheduleRequest
        {
            EventId = EventId,
            StartDateTime = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.StartDate, EventState.ScheduleInfo.StartTime, LocalizationOptions.Value),
            EndDateTime = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.EndDate, EventState.ScheduleInfo.EndTime, LocalizationOptions.Value),
            PreSaleDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.PreSaleDate, EventState.ScheduleInfo.PreSaleTime, LocalizationOptions.Value),
            PreSaleEndDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.PreSaleEndDate, EventState.ScheduleInfo.PreSaleEndTime, LocalizationOptions.Value),
            OnSaleDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.OnSaleDate, EventState.ScheduleInfo.OnSaleTime, LocalizationOptions.Value),
            OffSaleDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.OffSaleDate, EventState.ScheduleInfo.OffSaleTime, LocalizationOptions.Value),
            PublishedDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.PublishedDate, EventState.ScheduleInfo.PublishedTime, LocalizationOptions.Value),
            GateOpenDate = DateTimeHelpers.ToDateTimeOffset(EventState.ScheduleInfo.GateOpenDate, EventState.ScheduleInfo.GateOpenTime, LocalizationOptions.Value),
            HoldExpirationInMinutes = EventState.ScheduleInfo.HoldExpirationInMinutes
        };

        try
        {
            if (_isEdit || ScheduleId.HasValue)
            {
                await ScheduleService.UpdateScheduleAsync(ScheduleId.Value, request);
            }
            else
