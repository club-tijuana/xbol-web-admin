    private async Task SaveImageAsync(ImageModel? image)
    {
        try
        {
            if (image == null)
            {
                return;
            }

            if (image.Id.HasValue && image.TempFile != null)
            {
                await MediaService.UpdateMediaAsync(image.Id.Value, new FileParameter(
                image.TempFile.OpenReadStream(_maxFileSize),
                image.TempFile.Name,
                image.TempFile.ContentType), image.MediaType, image.Order);
            }
            else if (image.Id.HasValue == false && image.TempFile != null)
            {
                image.Id = await MediaService.UploadMediaAsync(EventId.Value, AdminSaleType.Event, image.MediaType, image.Order, new FileParameter(
                     image.TempFile.OpenReadStream(_maxFileSize),
                    image.TempFile.Name,
                    image.TempFile.ContentType));
            }
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode != StatusCodes.Status201Created
                && apiEx.StatusCode != StatusCodes.Status204NoContent)
            {
                throw;
            }
        }
    }

    private async Task SaveGalleryImagesAsync()
    {
        try
        {
            foreach (var(index, image) in _galleryImages.Values.Index())
            {
                if (image.Id.HasValue && image.TempFile != null)
                {
                    await MediaService.UpdateMediaAsync(image.Id.Value, new FileParameter(
                        image.TempFile.OpenReadStream(_maxFileSize),
                        image.TempFile.Name,
                        image.TempFile.ContentType), image.MediaType, index);
                }
                else if (image.TempFile != null)
                {
                    image.Id = await MediaService.UploadMediaAsync(EventId.Value, AdminSaleType.Event, image.MediaType, index, new FileParameter(
                        image.TempFile.OpenReadStream(_maxFileSize),
                        image.TempFile.Name,
                        image.TempFile.ContentType
                    ));
                }
            }
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode != StatusCodes.Status201Created
                && apiEx.StatusCode != StatusCodes.Status204NoContent)
            {
                throw;
            }
        }
    }

