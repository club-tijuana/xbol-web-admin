                                        </MudPaper>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>
                        </MudGrid>
                    </MudStep>
                </ChildContent>
                <ActionContent Context="stepperContext">
                    <MudSpacer />
                    @if (_activeIndex < _maxIndex)
                    {
                        <MudButton OnClick="ValidateAndGoNextAsync"
                                   EndIcon="@Icons.Material.Filled.ChevronRight"
                                   Variant="Variant.Text"
                                   Color="MudBlazor.Color.Primary">
                            @L["Next"]
                        </MudButton>
                    }
                    else if (_activeIndex == _maxIndex)
                    {
                        <MudButton OnClick="SubmitAsync"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Outlined.Save"
                                   Color="MudBlazor.Color.Tertiary">
                            @L["Save"]
                        </MudButton>
                    }
                </ActionContent>
            </MudStepper>
        </MudCardContent>
    </MudCard>
</LoadingContainer>

@code {
    [Parameter] public long EventId { get; set; }
    [Parameter] public long? ScheduleId { get; set; }

    private bool _loading = true;
    private bool _error = false;

    private MudStepper _stepper = null!;
    private int _activeIndex = 0;
    private int _highestUnlockedStep = 0;
    private int _maxIndex = 3;

    private MudForm _descriptionForm = default!;
    private bool _descriptionFormValid;
    private FormContext _descriptionFormContext = default!;

    private MudForm _datesAndSalePoliciesForm = default!;
    private bool _datesAndSalePoliciesValid;
    private FormContext _datesAndSalePoliciesFormContext = default!;

    private MudForm _pricesForm = default!;
    private bool _pricesValid;
    private FormContext _pricesFormContext = default!;

    private List<EventCategoryResult> _eventCategories = [];
    private IReadOnlyCollection<EventCategoryResult> _selectedCategories = [];
    private List<AgeRestriction> _ageRestrictions = Enum.GetValues<AgeRestriction>().ToList();
    private List<VenueResponse> _venues = [];
    private List<VenueMapResponse> _venueMaps = [];

    private MudFileUpload<IBrowserFile> _horizontalImageUpload = null!;
    private ImageModel? _horizontalImage;
    private MudFileUpload<IBrowserFile> _verticalImageUpload = null!;
    private ImageModel? _verticalImage;
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _galleryUpload = null!;
    private Dictionary<string, ImageModel> _galleryImages = [];

    private readonly long _maxFileSize = 10 * 1024 * 1024; // 10 MB
    private readonly int _minWidth = 1920;
    private readonly int _minHeight = 1080;

    private const string DefaultDragClass = "relative d-flex flex-column p-r gap-2 rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full";
    private string _dragClass = DefaultDragClass;
    private bool _dragging = false;


    private string? _name;
    private string? _subtitle;
    private string? _shortDescription;
    private string? _longDescription;
    private DateTime? _startDate;
    private TimeSpan? _startTime;
    private DateTime? _endDate;
    private TimeSpan? _endTime;
    private DateTime? _preSaleDate;
    private TimeSpan? _preSaleTime;
    private DateTime? _presaleEndDate;
    private TimeSpan? _preSaleEndTime;
    private DateTime? _onSaleDate;
    private TimeSpan? _onSaleTime;
    private DateTime? _offSaleDate;
    private TimeSpan? _offSaleTime;
    private DateTime? _publishedDate;
    private TimeSpan? _publishedTime;
    private DateTime? _gateOpenDate;
    private TimeSpan? _gateOpenTime;
    private AgeRestriction? _ageRestriction;
    private string? _securityPolicies;
    private string? _additionalComments;
    private string _externalEventKey;

    private List<PriceForm> _prices = [];
    private string _searchPrices = string.Empty;
    private TableGroupDefinition<PriceForm> _groupDefinition = new()
    {
        GroupName = "Zone",
        Indentation = true,
        Expandable = false,
        Selector = (e) => e.BaseZoneId,
        IsInitiallyExpanded = true
    };

    private List<string> PriceTypes { get; set; } = new();
    private string _priceTypeName = string.Empty;

    private VenueMapLayoutResponse _layout;

    private string? _venueAddress;
    private string? _venueCoordinates;

    private VenueResponse? _selectedVenue;
    private VenueMapResponse? _selectedVenueMap;

    private static readonly DialogOptions _dialogOptions = new() { CloseButton = true };

    protected override async Task OnInitializedAsync()
    {
        _descriptionFormContext = new FormContext(StateHasChanged);
        _datesAndSalePoliciesFormContext = new FormContext(StateHasChanged);
        _pricesFormContext = new FormContext(StateHasChanged);
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            var venueTask = CatalogsService.GetVenuesAsync();
            var catTask = EventService.GetCategoriesAsync();
            var eventTask = EventService.GetEventByIdAsync(EventId);
            await Task.WhenAll(venueTask, catTask, eventTask);

            _venues = await venueTask;
            _eventCategories = (await catTask).Where(c => c.IsActive == true).ToList();

            var eventResult = await eventTask;

            ScheduleId = ScheduleId ?? eventResult.Schedules?.First().Id;

            var schedule = eventResult.Schedules?.FirstOrDefault(s => s.Id == ScheduleId);

            _name = eventResult.Name;
            _subtitle = eventResult.Subtitle;
            _shortDescription = eventResult.ShortDescription;
            _longDescription = eventResult.LongDescription;
            _ageRestriction = eventResult.AgeRestriction;
            _securityPolicies = eventResult.SecurityPolicies;
            _additionalComments = eventResult.AdditionalComments;
            _selectedCategories = eventResult.Categories.ToList();

            await OnVenueSelected(_venues.FirstOrDefault(v => v.Id == eventResult.VenueId));
            await OnVenueMapSelected(_venueMaps.FirstOrDefault(m => m.Id == eventResult.VenueMapId));

            if (schedule is not null)
            {
                _startDate = DateTimeHelpers.ToNullableDateTime(schedule?.StartDateTime);
                _startTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.StartDateTime);
                _endDate = DateTimeHelpers.ToNullableDateTime(schedule?.EndDateTime);
                _endTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.EndDateTime);
                _preSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleStartDate);
                _preSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleStartDate);
                _presaleEndDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleEndDate);
                _preSaleEndTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleEndDate);
                _onSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OnSaleDate);
                _onSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OnSaleDate);
                _offSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OffSaleDate);
                _offSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OffSaleDate);
                _publishedDate = DateTimeHelpers.ToNullableDateTime(schedule?.PublishedDate);
                _publishedTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PublishedDate);
                _gateOpenDate = DateTimeHelpers.ToNullableDateTime(schedule?.GateOpenDate);
                _gateOpenTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.GateOpenDate);
                _externalEventKey = schedule.ExternalEventKey;
            }

            _layout = await VenueMapsService.GetVenueMapLayoutByIdAsync(_selectedVenueMap.Id);

            try
            {
                PricesResponse priceResponse = await PriceService.GetPricesByScheduleAndVenueAsync(ScheduleId.Value, _selectedVenueMap.Id);

                _prices = priceResponse.Prices.Select(x => new PriceForm
                    {
                        Id = x.Id,
                        BaseZoneId = x.BaseZoneId,
                        BaseSectionId = x.BaseSectionId,
                        BaseRowId = x.BaseRowId,
                        BaseSeatId = x.BaseSeatId,
                        ItemPrice = x.ItemPrice,
                        PriceTypes = x.PriceTypes.ToDictionary(pt => pt.Name, pt => pt.Price)
                    }).ToList();

                foreach (var priceType in priceResponse.PriceTypes)
                {
                    if (!PriceTypes.Contains(priceType.Name))
                    {
                        PriceTypes.Add(priceType.Name);
                    }
                }
            }
            catch (ApiException apiEx)
            {
                if (apiEx.StatusCode == StatusCodes.Status404NotFound)
                {
                    InitializePrices();
                }
            }

            ICollection<EventImageResponse> horizontalImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.HorizontalPoster);
            var horizontal = horizontalImages.FirstOrDefault();

            if (horizontal != null && horizontal.Id.HasValue)
            {
                _horizontalImage = new ImageModel
                {
                    Id = horizontal.Id,
                    Name = horizontal.Title
                };
            }

            ICollection<EventImageResponse> verticalImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.VerticalPoster);
            var vertical = verticalImages.FirstOrDefault();

            if (vertical != null && vertical.Id.HasValue)
            {
                _verticalImage = new ImageModel
                {
                    Id = vertical.Id,
                    Name = vertical.Title
                };
            }

            ICollection<EventImageResponse> galleryImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.Gallery);

            foreach (var image in galleryImages)
            {

                if (string.IsNullOrWhiteSpace(image.Title))
                {
                    continue;
                }

                _galleryImages.Add(image.Title, new ImageModel
                {
                    Id = image.Id,
                    Name = image.Title
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _descriptionFormContext.SetForm(_descriptionForm);
        }
    }

    private async Task OnVenueSelected(VenueResponse? venueSelected)
    {
        _selectedVenue = venueSelected;
        _selectedVenueMap = null;

        if (_selectedVenue is null)
        {
            _venueMaps = [];
            _venueAddress = null;
            _venueCoordinates = null;
            return;
        }

        LoadingState.Show();
        try
        {
            _venueMaps = await CatalogsService.GetVenueMapsByVenueId(_selectedVenue.Id);

            _venueAddress = $"{_selectedVenue.StreetAddress} {_selectedVenue.ExtNum}, {_selectedVenue.Neighborhood}, {_selectedVenue.ZipCode} {_selectedVenue.City}, {_selectedVenue.State}";
            _venueCoordinates = $"{_selectedVenue.Latitude}, {_selectedVenue.Longitude}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load venue");
            Snackbar.Add(L["ErrorLoadingVenue"], Severity.Error);
        }
        finally
        {
            LoadingState.Hide();            
        }
    }

    private async Task OnVenueMapSelected(VenueMapResponse? venueMap)
    {
        _selectedVenueMap = venueMap;
    }

    private async Task OnPreviewInteraction(StepperInteractionEventArgs arg)
    {
        bool isAttemptingNextStep = arg.Action == StepAction.Activate && arg.StepIndex == _activeIndex + 1;
        if (arg.Action == StepAction.Complete || isAttemptingNextStep)
        {
            bool isCurrentStepValid = false;

            switch (_activeIndex)
            {
                case 0:
                    _descriptionFormContext.SetForm(_descriptionForm);
                    isCurrentStepValid = await _descriptionFormContext.ValidateAsync();
                    break;
                case 1:
                    _pricesFormContext.SetForm(_pricesForm);
                    isCurrentStepValid = await _pricesFormContext.ValidateAsync();
                    break;
                case 2:
                    _datesAndSalePoliciesFormContext.SetForm(_datesAndSalePoliciesForm);
                    isCurrentStepValid = await _datesAndSalePoliciesFormContext.ValidateAsync();
                    break;
                default:
                    isCurrentStepValid = true;
                    break;
            }

            if (!isCurrentStepValid)
            {
                arg.Cancel = true;
                return;
            }
            else
            {
                if (_activeIndex >= _highestUnlockedStep)
                {
                    _highestUnlockedStep = _activeIndex + 1;
                }
            }
        }
        else if (arg.Action == StepAction.Activate)
        {
            if (arg.StepIndex > _highestUnlockedStep)
            {
                arg.Cancel = true;

                Snackbar.Add(L["CompletePreviousStepsWarning"], Severity.Warning);
            }
        }
    }

    private async Task GoBackAsync()
    {
        if ((_descriptionForm is not null && _descriptionForm.IsTouched) || (_datesAndSalePoliciesForm is not null && _datesAndSalePoliciesForm.IsTouched) || (_pricesForm is not null && _pricesForm.IsTouched))
        {
            var result = await DialogService.ShowMessageBoxAsync(
                L["UnsavedChangesTitle"],
                L["UnsavedChangesMessage"],
                yesText: L["UnsavedChangesConfirm"],
                cancelText: L["UnsavedChangesCancel"]);

            if (result is not true) return;
        }

        Navigation.NavigateTo("./events");
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", CtrlKey: true })
        {
            if (_activeIndex < _maxIndex)
            {
                await ValidateAndGoNextAsync();
            }
            else if (_activeIndex == _maxIndex)
            {
                await SubmitAsync();
            }
        }
    }

    private async Task ValidateAndGoNextAsync()
    {
        await _stepper.NextStepAsync();
    }

    private async Task SubmitAsync()
    {
        _datesAndSalePoliciesFormContext.SetForm(_datesAndSalePoliciesForm);
        if (!await _datesAndSalePoliciesFormContext.ValidateAsync()) return;

        _datesAndSalePoliciesFormContext.SetSaving(true);
        LoadingState.Show();
        try
        {
            var request = new UpdateEventRequest
            {
                Id = EventId,
                Name = _name,
                Subtitle = _subtitle,
                CategoryIds = _selectedCategories.Where(c => c.Id.HasValue).Select(c => c.Id!.Value).ToList(),
                ShortDescription = _shortDescription,
                LongDescription = _longDescription,
                VenueMapId = _selectedVenueMap.Id,
                SecurityPolicies = _securityPolicies,
                AdditionalComments = _additionalComments,
                AgeRestriction = _ageRestriction
            };

            await EventService.UpdateEventAsync(EventId, request);

            var scheduleRequest = new UpdateEventScheduleRequest
            {
                Id = ScheduleId,
                EventId = EventId,
                StartDateTime = DateTimeHelpers.ToDateTimeOffset(_startDate, _startTime),
                EndDateTime = DateTimeHelpers.ToDateTimeOffset(_endDate, _endTime),
                PreSaleDate = DateTimeHelpers.ToDateTimeOffset(_preSaleDate, _preSaleTime),
                PreSaleEndDate = DateTimeHelpers.ToDateTimeOffset(_presaleEndDate, _preSaleEndTime),
                OnSaleDate = DateTimeHelpers.ToDateTimeOffset(_onSaleDate, _onSaleTime),
                OffSaleDate = DateTimeHelpers.ToDateTimeOffset(_offSaleDate, _offSaleTime),
                PublishedDate = DateTimeHelpers.ToDateTimeOffset(_publishedDate, _publishedTime),
                GateOpenDate = DateTimeHelpers.ToDateTimeOffset(_gateOpenDate, _gateOpenTime),
                ExternalEventKey = _externalEventKey,
                AgeRestriction = _ageRestriction,
                SecurityPolicies = _securityPolicies,
                AdditionalComments = _additionalComments
            };

            await ScheduleService.UpdateScheduleAsync(ScheduleId.Value, scheduleRequest);

            await PriceService.UpdatePricesAsync(ScheduleId.Value, new PricesRequest { VenueMapId = _selectedVenueMap.Id, ReferenceId = ScheduleId.Value, ReferenceType = AdminSaleType.Event, Prices = _prices.Select(p => new PriceRequest{ BaseRowId = p.BaseRowId, BaseSeatId = p.BaseSeatId, BaseSectionId = p.BaseSectionId, BaseZoneId = p.BaseZoneId, ItemPrice = p.ItemPrice, Id = p.Id, PriceTypes = p.PriceTypes.Select(d => new PriceTypeRequest{Name = d.Key, Price = d.Value}).ToList()}).ToList() });

            await SaveHorizontalImageAsync();
            await SaveVerticalImageAsync();
            await SaveGalleryImagesAsync();

            Snackbar.Add(L["UpdateSuccess", L["Event"]], Severity.Success);
            Navigation.NavigateTo("./events");
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _datesAndSalePoliciesFormContext.HandleApiException(ex);
            Snackbar.Add(ex.Result.Title ?? L["ErrorSavingEvent"], Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to edit event");
            Snackbar.Add(L["ErrorSavingEvent"], Severity.Error);
        }
        finally
        {
            _datesAndSalePoliciesFormContext.SetSaving(false);
            LoadingState.Hide();
        }
    }

    private async Task UploadHorizontalAsync(IBrowserFile file)
    {
        if (file == null)
        {
            return;
        }

        if (_horizontalImage == null)
        {
            _horizontalImage = new ImageModel
            {
                Name = file.Name,
                TempFile = file
            };
        }
        else
        {
            _horizontalImage.Name = file.Name;
            _horizontalImage.TempFile = file;
        }

        await _horizontalImageUpload.ClearAsync();
    }

    private async Task UploadVerticalAsync(IBrowserFile file)
    {
        if (file == null)
        {
            return;
        }

        if (_verticalImage == null)
        {
            _verticalImage = new ImageModel
            {
                Name = file.Name,
                TempFile = file
            };
        }
        else
        {
            _verticalImage.Name = file.Name;
            _verticalImage.TempFile = file;
        }

        await _verticalImageUpload.ClearAsync();
    }

    private async Task DeleteHorizontalAsync()
    {
        if (_horizontalImage != null)
        {
            if (_horizontalImage.Id.HasValue)
            {
                await EventService.DeleteEventImageAsync(_horizontalImage.Id.Value);
            }

            _horizontalImage = null;
            await _horizontalImageUpload.ClearAsync();
        }
    }

    private async Task DeleteVerticalAsync()
    {
        if (_verticalImage != null)
        {
            if (_verticalImage.Id.HasValue)
            {
                await EventService.DeleteEventImageAsync(_verticalImage.Id.Value);
            }

            _verticalImage = null;
            await _verticalImageUpload.ClearAsync();
        }
    }

    private async Task UploadGalleryImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || !files.Any())
        {
            return;
        }

        foreach (var file in files)
        {
            if (file.Size > _maxFileSize)
            {
                Snackbar.Add($"El archivo '{file.Name}' supera el límite de 10MB.", Severity.Error);
                continue;
            }

            try
            {
                using var stream = file.OpenReadStream(_maxFileSize);

                var imageInfo = await Image.IdentifyAsync(stream);
                if (imageInfo == null)
                {
                    Snackbar.Add($"El archivo '{file.Name}' no es una imagen válida.", Severity.Error);
                    continue;
                }

                if (imageInfo.Width < _minWidth || imageInfo.Height < _minHeight)
                {
                    Snackbar.Add($"La imagen '{file.Name}' mide {imageInfo.Width}x{imageInfo.Height}px. El mínimo es {_minWidth}x{_minHeight}px.", Severity.Warning);
                    continue;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"An error occurred while trying to read the file '{file.Name}'. Error: {ex.Message}");
                Snackbar.Add($"Error al procesar '{file.Name}': El formato podría no estar soportado.", Severity.Error);
                continue;
            }

            if (_galleryImages.ContainsKey(file.Name))
            {
                _galleryImages[file.Name].TempFile = file;
            }
            else
            {
                _galleryImages.Add(file.Name, new ImageModel
                {
                    Name = file.Name,
                    TempFile = file
                });
            }
        }

        if (_galleryUpload != null)
        {
            await _galleryUpload.ClearAsync();
        }
    }

    private async Task RemoveGalleryImageAsync(string fileName)
    {
        ImageModel? file = _galleryImages.GetValueOrDefault(fileName);

        try
        {
            if (file is not null && file.Id.HasValue)
            {
                await EventService.DeleteEventImageAsync(file.Id.Value);
            }

            _galleryImages.Remove(fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"An error ocurred while trying to remove a gallery image. Error: {ex.Message}");
            Snackbar.Add($"Ocurrio un error al tratar de eliminar la imgen '{fileName}'.", Severity.Error);
        }

    }

    private async Task CleanGalleryImagesAsync()
    {
        foreach (ImageModel galleryImage in _galleryImages.Values)
        {
            if (galleryImage.Id.HasValue)
            {
                await EventService.DeleteEventImageAsync(galleryImage.Id.Value);
            }
        }

        _galleryImages.Clear();
    }

    private void SetDragClass()
    {
        _dragClass = $"{DefaultDragClass} mud-border-success";
        _dragging = true;
    }

