    private async Task DownloadCsvAsync()
    {
        try
        {
            // FileResponse? file = await PriceService.DownloadPricesCsvAsync(ScheduleId, EventState.EventInfo.SelectedVenueMap?.Id ?? default);

            FileResponse? file = null;

            if (file is null)
            {
                throw new Exception("No file was received for download.");
            }
            else
            {
                await DownloadFileAsync(file);
            }
        }
