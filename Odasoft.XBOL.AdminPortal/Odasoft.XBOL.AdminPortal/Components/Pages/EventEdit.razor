    private async Task AddImage(IBrowserFile file, MediaType mediaType, int order = 0)
    {
        if (file == null)
        {
            return;
        }

        if (file.Size > _maxFileSize)
        {
            // TODO: Internationalization
            Snackbar.Add($"El archivo '{file.Name}' supera el límite de 10MB.", Severity.Error);
            return;
        }

        using var stream = file.OpenReadStream(_maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        memoryStream.Position = 0;

        var imageInfo = await Image.IdentifyAsync(memoryStream);
        if (imageInfo == null)
        {
            Snackbar.Add($"El archivo '{file.Name}' no es una imagen válida.", Severity.Error);
            return;
        }

        if (imageInfo.Width < _minWidth || imageInfo.Height < _minHeight)
        {
            Snackbar.Add($"La imagen '{file.Name}' mide {imageInfo.Width}x{imageInfo.Height}px. El mínimo es {_minWidth}x{_minHeight}px.", Severity.Warning);
            return;
        }

        var fileBytes = memoryStream.ToArray();

        var src = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

        var newImage = new ImageModel
            {
                Name = file.Name,
                TempFile = file,
                Src = src,
                Order = order,
                MediaType = mediaType
            };

        switch (mediaType)
        {
            case MediaType.Banner:
                newImage.Id = _bannerImage?.Id;
                _bannerImage = newImage;
                await _bannerImageUpload.ClearAsync();
                break;
            case MediaType.Sponsor:
                newImage.Id = _sponsorImages[order]?.Id;
                _sponsorImages[order] = newImage;
                await _sponsorUploads[order].ClearAsync();
                break;
            default:
                return;
        }
    }

    private async Task DeleteImageAsync(MediaType mediaType, int order = 0)
    {
        switch (mediaType)
        {
            case MediaType.Banner:
                if (_bannerImage != null)
                {
                    if (_bannerImage.Id.HasValue)
                    {
                        await MediaService.DeleteMediaAsync(_bannerImage.Id.Value);
                    }

                    _bannerImage = null;
                    await _bannerImageUpload.ClearAsync();
                }
                break;
            case MediaType.Sponsor:
                var image = _sponsorImages[order];
                if(image != null)
                {
                    if (image.Id.HasValue)
                    {
                        await MediaService.DeleteMediaAsync(image.Id.Value);
                    }

                    _sponsorImages[order] = null;
                    await _sponsorUploads[order].ClearAsync();
                }
                break;
            default:
                return;
        }        
    }

    private async Task UploadGalleryImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || !files.Any())
        {
            return;
        }

        foreach (var file in files)
        {
            if (file.Size > _maxFileSize)
            {
                Snackbar.Add($"El archivo '{file.Name}' supera el límite de 10MB.", Severity.Error);
                continue;
            }

            string src = string.Empty;
            try
            {
                using var stream = file.OpenReadStream(_maxFileSize);
                using var memoryStream = new MemoryStream();

                await stream.CopyToAsync(memoryStream);

                memoryStream.Position = 0;

                var imageInfo = await Image.IdentifyAsync(memoryStream);
                if (imageInfo == null)
                {
                    Snackbar.Add($"El archivo '{file.Name}' no es una imagen válida.", Severity.Error);
                    continue;
                }

                if (imageInfo.Width < _minWidth || imageInfo.Height < _minHeight)
                {
                    Snackbar.Add($"La imagen '{file.Name}' mide {imageInfo.Width}x{imageInfo.Height}px. El mínimo es {_minWidth}x{_minHeight}px.", Severity.Warning);
                    continue;
                }

                var fileBytes = memoryStream.ToArray();

                src = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";
            }
            catch (Exception ex)
            {
                Console.WriteLine($"An error occurred while trying to read the file '{file.Name}'. Error: {ex.Message}");
                Snackbar.Add($"Error al procesar '{file.Name}': El formato podría no estar soportado.", Severity.Error);
                continue;
            }            

            if (_galleryImages.ContainsKey(file.Name))
            {
                _galleryImages[file.Name].TempFile = file;
                _galleryImages[file.Name].Src = src;
            }
            else
            {
                _galleryImages.Add(file.Name, new ImageModel
                {
                    Name = file.Name,
                    TempFile = file,
                    Src = src,
                    MediaType = MediaType.Gallery
                });
            }
        }

        if (_galleryUpload != null)
        {
            await _galleryUpload.ClearAsync();
        }

        _carousel.MoveTo(_galleryImages.Count - 1);
    }

    private async Task RemoveGalleryImageAsync(string fileName)
    {
        ImageModel? file = _galleryImages.GetValueOrDefault(fileName);

        try
        {
            if (file is not null && file.Id.HasValue)
            {
                await MediaService.DeleteMediaAsync(file.Id.Value);
            }

            _galleryImages.Remove(fileName);
            await Task.Delay(1);
            _carousel.MoveTo(Math.Max(_galleryImages.Count - 1, 0));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"An error ocurred while trying to remove a gallery image. Error: {ex.Message}");
            Snackbar.Add($"Ocurrio un error al tratar de eliminar la imgen '{fileName}'.", Severity.Error);
        }

    }

    private async Task CleanGalleryImagesAsync()
    {
        foreach (ImageModel galleryImage in _galleryImages.Values)
        {
            if (galleryImage.Id.HasValue)
            {
                await MediaService.DeleteMediaAsync(galleryImage.Id.Value);
            }
        }

        _galleryImages.Clear();
        await Task.Delay(1);
        _carousel.MoveTo(0);
    }

