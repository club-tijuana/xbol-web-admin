    private async Task OnPreviewInteraction(StepperInteractionEventArgs arg)
    {
        bool isAttemptingNextStep = arg.Action == StepAction.Activate && arg.StepIndex == _activeIndex + 1;
        if (arg.Action == StepAction.Complete || isAttemptingNextStep)
        {
            bool isCurrentStepValid = false;

            switch (_activeIndex)
            {
                case 0:
                    _descriptionFormContext.SetForm(_descriptionForm);
                    isCurrentStepValid = await _descriptionFormContext.ValidateAsync();
                    break;
                case 1:
                    _pricesFormContext.SetForm(_pricesForm);
                    isCurrentStepValid = await _pricesFormContext.ValidateAsync();
                    break;
                case 2:
                    _datesAndSalePoliciesFormContext.SetForm(_datesAndSalePoliciesForm);
                    isCurrentStepValid = await _datesAndSalePoliciesFormContext.ValidateAsync();
                    break;
                default:
                    isCurrentStepValid = true;
                    break;
            }

            if (!isCurrentStepValid)
            {
                arg.Cancel = true;
                return;
            }
            else
            {
                if (_activeIndex >= _highestUnlockedStep)
                {
                    _highestUnlockedStep = _activeIndex + 1;
                }

                if (_activeIndex == 0)
                {
                    if (_currentPricesMapId != _selectedVenueMap.Id)
                    {
                        _layout = await VenueMapsService.GetVenueMapLayoutByIdAsync(_selectedVenueMap.Id);
                        await LoadPrices();
                        _currentPricesMapId = _selectedVenueMap.Id;
                    }
                }
            }
        }
        else if (arg.Action == StepAction.Activate)
        {
            if (arg.StepIndex > _highestUnlockedStep)
            {
                arg.Cancel = true;

                Snackbar.Add(L["CompletePreviousStepsWarning"], Severity.Warning);
            }
        }
    }

