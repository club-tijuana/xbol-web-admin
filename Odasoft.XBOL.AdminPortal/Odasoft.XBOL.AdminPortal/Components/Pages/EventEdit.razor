        var dialog = await DialogService.ShowAsync<PriceTypeDialogEdit>(null, parameters, _dialogOptions);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is not null)
        {
            var priceType = result.Data.ToString();
            if (!string.IsNullOrWhiteSpace(priceType))
            {
                EditPriceType(_priceTypeName, priceType);
            }
        }
    }

    private async Task DownloadCsvAsync()
    {
        try
        {
            //FileResponse? file = await _priceService.DownloadPricesCsvAsync(ScheduleId, _selectedVenueMap?.Id ?? default);
            FileResponse? file = null;

            if (file is null)
            {
                throw new Exception("No file was received for download.");
            }
            else
            {
                await DownloadFileAsync(file);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error trying to get file: {ex.Message}");
            Snackbar.Add(L["ErrorDownloadingPricesTemplate"], Severity.Error);
        }
    }

    private async Task DownloadFileAsync(FileResponse file)
    {
        try
        {
            string contentDisposition = file.Headers["Content-Disposition"].FirstOrDefault() ?? "";
            string filename = "";

            if (ContentDispositionHeaderValue.TryParse(contentDisposition, out var disposition))
            {
                filename = disposition.FileNameStar.Value ?? disposition.FileName.Value ?? filename;
                filename = filename.Trim('\"');
            }

            using var streamRef = new DotNetStreamReference(stream: file.Stream);

            await JS.InvokeVoidAsync("downloadFileFromStream", filename, streamRef);

            Snackbar.Add(L["SuccesfulFileDownload"], Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading file: {ex.Message}");
            Snackbar.Add(L["ErrorDownloadingPricesTemplate"], Severity.Error);
        }
    }

    private async Task OpenPriceImportDialog()
    {
        var parameters = new DialogParameters<PriceImportDialog> { { x => x.EventId, EventId }, { x => x.VenueMapId, _selectedVenueMap.Id } };
        var dialog = await DialogService.ShowAsync<PriceImportDialog>(parameters);

        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Console.WriteLine(result.Data);
            IEnumerable<PriceSegmentResponse> priceResponses = (IEnumerable<PriceSegmentResponse>)result.Data;

            _prices = priceResponses.Select(x => new PriceForm()
            {
                BaseZoneId = x.BaseZoneId,
                BaseSectionId = x.BaseSectionId,
                BaseRowId = x.BaseRowId,
                BaseSeatId = x.BaseSeatId,
                PriceTypes = x.PriceTypes?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new(),
                Prices = x.Prices?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new()
            }).ToList();

            foreach (var priceType in _prices.SelectMany(x => x.PriceTypes))
            {
                if (!PriceTypes.ContainsKey(priceType.Key))
                {
                    PriceTypes.Add(priceType.Key, priceType.Value);
                }
            }
        }
    }
