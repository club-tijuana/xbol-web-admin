@page "/events/create"
@page "/events/{EventId:long}/edit"
@page "/events/{EventId:long}/schedules/{ScheduleId:long}/edit"
@page "/events/{EventId:long}/review"
@page "/events/{EventId:long}/schedules/{ScheduleId:long}/review"

@using Odasoft.XBOL.Auth
@attribute [RequireAnyPermission(AdminPermissions.Events.Read, AdminPermissions.Events.ReadCurrent, AdminPermissions.Events.Create, AdminPermissions.Events.Update)]

@using Microsoft.Net.Http.Headers
@using Odasoft.XBOL.AdminPortal.Extensions
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.AdminPortal.ViewModels.Event
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.Business.Services
@using Radzen.Blazor
@using SixLabors.ImageSharp

@inject CatalogsService CatalogsService;
@inject IEventService EventService;
@inject OrganizersService OrganizersService;
@inject VenuesService VenuesService
@inject VenueMapsService VenueMapsService;
@inject EventScheduleService ScheduleService;
@inject MediaService MediaService;
@inject AppLocalizer<EventEdit> L
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LoadingState LoadingState;
@inject IJSRuntime JS;
@inject ILogger<EventEdit> Logger;
@inject PriceReferenceService PriceReferenceService;

<style>
    .mud-stepper .mud-stepper-content {
        padding-left: 0;
        padding-right: 8px;
    }

    .mud-stepper-nav .mud-step:first-of-type {
        padding-left: 0;
    }

    .mud-stepper-nav .mud-step:last-of-type {
        padding-right: 8px;
    }
</style>

<PageTitle>@_pageTitle</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="MudBlazor.Color.Secondary"
                       Variant="Variant.Outlined" DropShadow="false" OnClick="@(() => GoBackAsync())">
                @L["GoBack"]
            </MudButton>
        </LeftContent>
        <RightContent>
            @if (_isEdit || _isReview)
            {
                @if (_isReview)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.TaskAlt"
                               Color="MudBlazor.Color.Tertiary"
                               Variant="Variant.Filled"
                               DropShadow="false"
                               Disabled="_loading || _eventStatus != AdminEventStatus.PendingReview"
                               OnClick="OpenReviewDialog">@L["FinishReview"]</MudButton>
                }
                else
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Save"
                               Color="MudBlazor.Color.Tertiary"
                               Variant="Variant.Filled"
                               DropShadow="false"
                               OnClick="PublishAsync"
                               Disabled="_eventStatus != AdminEventStatus.Approved || _loading">@L["Publish"]</MudButton>
                }
            }
        </RightContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer IsLoading="_loading"
                  HasError="_error"
                  ErrorMessage="@L["ErrorLoadingEvent"]"
                  OnRetry="InitializeForm">
    <MudCard Elevation="3">
        <MudCardContent Class="pa-6">
            <MudStack Justify="Justify.SpaceBetween" AlignItems="AlignItems.Stretch" Class="mb-4">
                <MudStack Row>
                    <MudText Typo="Typo.h5">@($"{(_isEdit || _isReview ? _name : _pageTitle)}")</MudText>
                    @if (!_isReview)
                    {
                        <EventStatusChip Status="_eventStatus"></EventStatusChip>
                    }
                </MudStack>
                @if (_isReview)
                {
                    <MudAlert Severity="Severity.Warning"
                              Class="bg-primary-lighten text-secondary w-100"
                              Dense
                              NoIcon>@L["ReviewDescription"]</MudAlert>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">@L["RequiredFieldsNote"]</MudText>
                }
            </MudStack>

            <MudStepper @ref="_stepper" @bind-ActiveIndex="_activeIndex" OnPreviewInteraction="OnPreviewInteraction" NonLinear Class="pa-0">
                <ChildContent>
                    <MudStep Title="@L["DescriptionAndVenue"]">
                        <MudForm @ref="_descriptionForm" @bind-IsValid="_descriptionFormValid" @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="7">
                                <MudItem xs="12">
                                    <AdminSelect Label="@(L["Organizer"].Value)"
                                                 @bind-Value="_organizerId"
                                                 Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">

                                        @foreach (var organizer in _organizers)
                                        {
                                            <MudSelectItem T="long?" Value="organizer.Id">
                                                @organizer.Name
                                            </MudSelectItem>
                                        }
                                    </AdminSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_name"
                                                            Label="@L["Name"].Value"
                                                            Field="@_descriptionFormContext.Field("Name")"
                                                            Required
                                                            Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_subtitle"
                                                            Label="@L["Subtitle"].Value"
                                                            Field="@_descriptionFormContext.Field("Subtitle")"
                                                            Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudSelect Label="@L["EventType"]"
                                                       T="AdminEventCategoryResult"
                                                       MultiSelection="true"
                                                       @bind-SelectedValues="_selectedCategories"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       ToStringFunc="@(c => c?.DisplayName ?? "")"
                                                       Required
                                                       Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">

                                                @foreach (var category in _eventCategories)
                                                {
                                                    <MudSelectItem T="AdminEventCategoryResult" Value="category">
                                                        @category.DisplayName
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_shortDescription"
                                                            Label="@L["EventSummary"].Value"
                                                            Field="@_descriptionFormContext.Field("ShortDescription")"
                                                            Lines="@(3)"
                                                            Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudStack>
                                                <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600;">@L["EventDescription"]</MudText>
                                                @* TODO: Create and use component *@
                                                <MudPaper Outlined="true" Class="pa-0">
                                                    <RadzenHtmlEditor @bind-Value="_longDescription" Style="min-height: 300px; width: 100%;"
                                                                      Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">
                                                        <RadzenHtmlEditorUndo Title="Deshacer" />
                                                        <RadzenHtmlEditorRedo Title="Rehacer" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorBold Title="Negrita" />
                                                        <RadzenHtmlEditorItalic Title="Cursiva" />
                                                        <RadzenHtmlEditorUnderline Title="Subrayado" />
                                                        <RadzenHtmlEditorStrikeThrough Title="Tachado" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorAlignLeft Title="Alinear a la izquierda" />
                                                        <RadzenHtmlEditorAlignCenter Title="Centrar" />
                                                        <RadzenHtmlEditorAlignRight Title="Alinear a la derecha" />
                                                        <RadzenHtmlEditorJustify Title="Justificar" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorUnorderedList Title="Lista de viñetas" />
                                                        <RadzenHtmlEditorOrderedList Title="Lista numerada" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorColor Title="Color del texto" />
                                                        <RadzenHtmlEditorBackground Title="Color de fondo" />
                                                        <RadzenHtmlEditorRemoveFormat Title="Quitar formato" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorSubscript Title="Subíndice" />
                                                        <RadzenHtmlEditorSuperscript Title="Superíndice" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorLink Title="Insertar enlace" />
                                                        <RadzenHtmlEditorUnlink Title="Quitar enlace" />
                                                        <RadzenHtmlEditorImage Title="Insertar imagen" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorFontName Title="Fuente" Placeholder="Fuente" />
                                                        <RadzenHtmlEditorFontSize Title="Tamaño" Placeholder="Tamaño" />
                                                        <RadzenHtmlEditorFormatBlock Title="Formato" Placeholder="Párrafo" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorSource Title="Ver código HTML" />
                                                    </RadzenHtmlEditor>
                                                </MudPaper>
                                            </MudStack>
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueResponse?"
                                                         Value="_selectedVenue"
                                                         ValueChanged="OnVenueSelected"
                                                         Label="@L["Venue"].Value"
                                                         Required
                                                         Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">
                                                @foreach (var venue in _venues)
                                                {
                                                    <MudSelectItem T="VenueResponse?" Value="@venue">@venue.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueMapResponse?"
                                                         Value="_selectedVenueMap"
                                                         ValueChanged="OnVenueMapSelected"
                                                         Label="@L["Map"].Value"
                                                         Required
                                                         Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">
                                                @foreach (var map in _venueMaps)
                                                {
                                                    <MudSelectItem T="VenueMapResponse?" Value="@map">@map.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueAddress"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Label="@L["Address"].Value"
                                                          Disabled="@true" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueCoordinates"
                                                          Label="@L["Coordinates"].Value"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Disabled="@true" />
                                        </MudItem>
                                        @if (_selectedVenueMap is not null)
                                        {
                                            <MudItem xs="12" Class="d-flex justify-center">
                                                <MudImage Src="@_selectedVenueMap.ThumbnailUrl" Alt="@_selectedVenueMap.Name" Class="rounded-lg" Height="400" />
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                    <MudStep Title="@L["ZonePrices"]">
                        <MudForm @ref="_pricesForm" @bind-IsValid="_pricesValid" @onkeydown="OnKeyDownAsync">
                            <MudTable Items="_prices"
                                      GroupBy="_groupDefinition"
                                      Elevation="0"
                                      FixedHeader>
                                <ToolBarContent>
                                    <MudText Typo="Typo.h5">@L["Zones"]</MudText>
                                    <MudSpacer />
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        @if (!_isReview)
                                        {
                                            <MudButton StartIcon="@Icons.Material.Filled.FileDownload" OnClick="@(() => DownloadCsvAsync())" Color="MudBlazor.Color.Secondary" Variant="Variant.Filled">@L["DownloadTemplate"]</MudButton>
                                            <MudButton StartIcon="@Icons.Material.Filled.FileUpload" Color="MudBlazor.Color.Secondary" Variant="Variant.Filled" OnClick="OpenPriceImportDialog">@L["ImportPrices"]</MudButton>
                                        }
                                        @* <MudTextField @bind-Value="_searchPrices" Placeholder="@L["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField> *@
                                    </MudStack>
                                </ToolBarContent>
                                <ColGroup>
                                    <col />
                                    <col />
                                    <col />
                                    <col />
                                    <col />
                                    <col />
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <col />
                                    }
                                </ColGroup>
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceForm, object>(x => GetZoneName(x.BaseZoneId))">@L["Zone"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceForm, object>(x => GetSectionName(x.BaseSectionId))">@L["Section"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceForm, object>(x => GetSectionName(x.BaseRowId))">@L["Row"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceForm, object>(x => GetSectionName(x.BaseSeatId))">@L["Seat"]</MudTableSortLabel></MudTh>
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <MudTh>
                                            @priceType.Key
                                            @if (!priceType.Value)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                               Color="MudBlazor.Color.Secondary"
                                                               Size="MudBlazor.Size.Small"
                                                               OnClick="@(() => OpenEditDialog(priceType.Key))" />
                                            }
                                        </MudTh>
                                    }
                                    <MudTh>
                                        @if (!_isReview)
                                        {
                                            <MudButton Color="MudBlazor.Color.Primary" IconColor="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="OpenAddDialog">@L["AlternativePrice"]</MudButton>
                                        }
                                    </MudTh>
                                    <MudTh />
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd></MudTd>
                                    <MudTd>
                                        <AdminSelect T="long?"
                                                     Value="@context.BaseSectionId"
                                                     ValueChanged="@((long? newValue) => OnSectionChanged(context, newValue))"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value">
                                            @foreach (var section in GetSectionsFor(context.BaseZoneId))
                                            {
                                                <MudSelectItem T="long?" Value="section.Id">
                                                    @(section.Name)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    <MudTd>
                                        <AdminSelect T="long?"
                                                     Value="@context.BaseRowId"
                                                     ValueChanged="@((long? newValue) => OnRowChanged(context, newValue))"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value"
                                                     Clearable="@true">
                                            @foreach (var row in GetRowsFor(context.BaseSectionId))
                                            {
                                                <MudSelectItem T="long?" Value="row.Id">
                                                    @(row.Name)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    <MudTd>
                                        <AdminSelect T="long?"
                                                     @bind-Value="@context.BaseSeatId"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value"
                                                     Clearable="@true">
                                            @foreach (var seat in GetSeatsFor(context.BaseRowId))
                                            {
                                                <MudSelectItem T="long?" Value="seat.Id">
                                                    @(seat.SeatNumber)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <MudTd DataLabel="@priceType.Key">
                                            <AdminNumericField T="decimal?"
                                                               Value="@GetPriceTypeValue(context, priceType.Key)"
                                                               ValueChanged="@((decimal? newValue) => SetPriceTypeValue(context, priceType.Key, newValue))"
                                                               Clearable="@true"
                                                               Format="N2"
                                                               Adornment="@Adornment.Start"
                                                               AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                                               Placeholder="0.00"
                                                               HideSpinButtons="@true"
                                                               Immediate="@false"
                                                               Disabled="@_isReview" />
                                        </MudTd>
                                    }
                                    <MudTd></MudTd>
                                    <MudTd>
                                        @if (!_isReview && (context.BaseRowId != null || context.BaseSectionId != null || context.BaseSeatId != null))
                                        {
                                            <MudTooltip Text="@L["Delete"]" Placement="Placement.Top">
                                                <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                               Color="MudBlazor.Color.Secondary"
                                                               Size="MudBlazor.Size.Medium"
                                                               OnClick="@(() => DeletePriceAsync(context))" />
                                            </MudTooltip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                                <GroupHeaderTemplate>
                                    <MudTh colspan="@(6 + PriceTypes.Count)">
                                        <MudText Class="text-primary-darken" Typo="Typo.subtitle2">
                                            @(GetZoneName(long.Parse(context.Key.ToString())))
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        @if (!_isReview)
                                        {
                                            <MudIconButton Color="MudBlazor.Color.Primary"
                                                           Icon="@Icons.Material.Outlined.Add"
                                                           OnClick="@(() => AddPrice(long.Parse(context.Key.ToString())))">@L["AddPrice"]</MudIconButton>
                                        }
                                    </MudTh>
                                </GroupHeaderTemplate>
                            </MudTable>
                        </MudForm>
                    </MudStep>
                    <MudStep Title="@L["DatesAndSalePolicies"]">
                        <MudForm @ref="_datesAndSalePoliciesForm" @bind-IsValid="_datesAndSalePoliciesValid" @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="6">
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["EventSchedule"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_startDate"
                                                     Label="@L["StartDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("StartDate")"
                                                     Required
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_startTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_endDate"
                                                     Label="@L["EndDate"].Value"
                                                     Required
                                                     Field="@_datesAndSalePoliciesFormContext.Field("EndDate")"
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_endTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["TicketsPreSale"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_preSaleDate"
                                                     Label="@L["StartDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("PreSaleDate")"
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_preSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_presaleEndDate"
                                                     Label="@L["EndDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("PreSaleEndDate")"
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_preSaleEndTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["TicketsSale"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_onSaleDate"
                                                     Label="@L["StartDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("OnSaleDate")"
                                                     Required
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_onSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_offSaleDate"
                                                     Label="@L["EndDate"].Value"
                                                     Required
                                                     Field="@_datesAndSalePoliciesFormContext.Field("OffSaleDate")"
                                                     Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_offSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required
                                                   Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12" md="5">
                                    <MudGrid Spacing="6">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                            ;">@L["WebSitePublishing"]</MudText>
                                        </MudItem>
                                        <MudItem xs="12" md="7">
                                            <AdminDatePicker @bind-Date="_publishedDate"
                                                             Label="@L["PublishDate"].Value"
                                                             Field="@_datesAndSalePoliciesFormContext.Field("PublishedDate")"
                                                             Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                        <MudItem xs="12" md="5">
                                            <MudTimePicker @bind-Time="_publishedTime"
                                                           Label="@L["Time"].Value"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           TimeFormat="h:mm tt"
                                                           AmPm="true"
                                                           Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" md="5">
                                    <MudGrid Spacing="6">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                            ;">@L["VenueAccess"]</MudText>
                                        </MudItem>
                                        <MudItem xs="12" md="7">
                                            <AdminDatePicker @bind-Date="_gateOpenDate"
                                                             Label="@L["AccessDate"].Value"
                                                             Field="@_datesAndSalePoliciesFormContext.Field("GateOpenDate")"
                                                             Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                        <MudItem xs="12" md="5">
                                            <MudTimePicker @bind-Time="_gateOpenTime"
                                                           Label="@L["Time"].Value"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           TimeFormat="h:mm tt"
                                                           AmPm="true"
                                                           Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)" />
                                        </MudItem>
                                    </MudGrid>
