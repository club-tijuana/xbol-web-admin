    private async Task SubmitAsync()
    {
        _datesAndSalePoliciesFormContext.SetForm(_datesAndSalePoliciesForm);
        if (!await _datesAndSalePoliciesFormContext.ValidateAsync()) return;

        _datesAndSalePoliciesFormContext.SetSaving(true);
        LoadingState.Show();
        try
        {
            var request = new EventRequest
            {
                Name = _name,
                Subtitle = _subtitle,
                CategoryIds = _selectedCategories.Where(c => c.Id.HasValue).Select(c => c.Id!.Value).ToList(),
                ShortDescription = _shortDescription,
                LongDescription = _longDescription,
                VenueMapId = _selectedVenueMap.Id,
                SecurityPolicies = _securityPolicies,
                AdditionalComments = _additionalComments,
                AgeRestriction = _ageRestriction
            };

            await SaveEventAsync(request);

            var scheduleRequest = new EventScheduleRequest
            {
                EventId = EventId,
                StartDateTime = DateTimeHelpers.ToDateTimeOffset(_startDate, _startTime),
                EndDateTime = DateTimeHelpers.ToDateTimeOffset(_endDate, _endTime),
                PreSaleDate = DateTimeHelpers.ToDateTimeOffset(_preSaleDate, _preSaleTime),
                PreSaleEndDate = DateTimeHelpers.ToDateTimeOffset(_presaleEndDate, _preSaleEndTime),
                OnSaleDate = DateTimeHelpers.ToDateTimeOffset(_onSaleDate, _onSaleTime),
                OffSaleDate = DateTimeHelpers.ToDateTimeOffset(_offSaleDate, _offSaleTime),
                PublishedDate = DateTimeHelpers.ToDateTimeOffset(_publishedDate, _publishedTime),
                GateOpenDate = DateTimeHelpers.ToDateTimeOffset(_gateOpenDate, _gateOpenTime),
                ExternalEventKey = _externalEventKey,
                AgeRestriction = _ageRestriction,
                SecurityPolicies = _securityPolicies,
                AdditionalComments = _additionalComments
            };

            await SaveEventScheduleAsync(scheduleRequest);

            var priceRequest = new PricesRequest { 
                VenueMapId = _selectedVenueMap.Id,
                ReferenceId = ScheduleId.Value,
                ReferenceType = AdminSaleType.Event,
                Prices = _prices.Select(p => new PriceRequest { BaseRowId = p.BaseRowId, BaseSeatId = p.BaseSeatId, BaseSectionId = p.BaseSectionId, BaseZoneId = p.BaseZoneId, ItemPrice = p.ItemPrice, Id = p.Id, PriceTypes = p.PriceTypes.Select(d => new PriceTypeRequest { Name = d.Key, Price = d.Value }).ToList() }).ToList() 
            };

            await SavePricesAsync(priceRequest);

            await SaveImageAsync(_bannerImage);
            await SaveImageAsync(_sponsorImages[0]);
            await SaveImageAsync(_sponsorImages[1]);
            await SaveGalleryImagesAsync();

            Snackbar.Add(L["UpdateSuccess", L["Event"]], Severity.Success);
            Navigation.NavigateTo("./events");
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _datesAndSalePoliciesFormContext.HandleApiException(ex);
            Snackbar.Add(ex.Result.Title ?? L["ErrorSavingEvent"], Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to edit event");
            Snackbar.Add(L["ErrorSavingEvent"], Severity.Error);
        }
        finally
        {
            _datesAndSalePoliciesFormContext.SetSaving(false);
            LoadingState.Hide();
        }
    }

