    private async Task SaveEventMediaAsync()
    {
        if (EventId is null || EventId <= 0)
        {
            return;
        }

        var items = new List<EventMediaDesiredItem>();
        var files = new List<FileParameter>();
        var streams = new List<MemoryStream>();

        try
        {
            AddDesiredMediaItem(items, files, streams, _bannerImage, AdminMediaType.Banner, 0);

            foreach (var (image, order) in EventMediaOrderer.CompactSponsors(_sponsorImages))
            {
                AddDesiredMediaItem(items, files, streams, image, AdminMediaType.Sponsor, order);
            }

            foreach (var (index, image) in _galleryImages.Index())
            {
                AddDesiredMediaItem(items, files, streams, image, AdminMediaType.Gallery, index);
            }

            await MediaService.ReconcileEventMediaAsync(EventId.Value, items, files);
        }
        finally
        {
            foreach (var stream in streams)
            {
                stream.Dispose();
            }
        }
    }

    private static void AddDesiredMediaItem(
        List<EventMediaDesiredItem> items,
        List<FileParameter> files,
        List<MemoryStream> streams,
        ImageModel? image,
        AdminMediaType mediaType,
        int order)
    {
        if (image is null)
        {
            return;
        }

        image.Order = order;

        if (image.FileBytes is { Length: > 0 })
        {
            var stream = new MemoryStream(image.FileBytes);
            var fileIndex = files.Count;

            streams.Add(stream);
            files.Add(new FileParameter(stream, image.Name, image.ContentType));
            items.Add(new EventMediaDesiredItem
            {
                MediaType = mediaType,
                Order = order,
                FileIndex = fileIndex
            });

            return;
        }

        if (image.Id.HasValue)
        {
            items.Add(new EventMediaDesiredItem
            {
                MediaType = mediaType,
                Order = order,
                ExistingMediaId = image.Id.Value
            });
        }
    }

