                                                   FilesChanged="(file) => AddImage(file, AdminMediaType.Sponsor, 1)"
                                                   Accept=".jpg, .png, .jpeg">
                                        <CustomContent>
                                            <div class="d-flex align-center gap-4">
                                                <MudButton StartIcon="@Icons.Material.Filled.Upload"
                                                           Variant="Variant.Filled"
                                                           Color="MudBlazor.Color.Secondary"
                                                           OnClick="@context.OpenFilePickerAsync"
                                                           Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">
                                                    @L["Sponsor"] 2
                                                </MudButton>

                                                @if (_sponsorImages[1] != null && !(_isReview || _eventStatus == AdminEventStatus.Published))
                                                {
                                                    <MudChip T="string"
                                                             Variant="Variant.Text"
                                                             Color="MudBlazor.Color.Dark"
                                                             OnClose="() => DeleteImageAsync(AdminMediaType.Sponsor, 1)"
                                                             CloseIcon="@Icons.Material.Filled.Close">
                                                        @_sponsorImages[1]?.Name
                                                    </MudChip>
                                                }
                                            </div>
                                        </CustomContent>
                                        <SelectedTemplate />
                                    </MudFileUpload>
                                    <MudStack>
                                        <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight: 600;">@L["HorizontalImagePreview"]</MudText>

                                        @if (string.IsNullOrEmpty(_sponsorImages[1]?.Src))
                                        {
                                            <ImagePlaceholder Class="rounded-lg" Height="200px" Width="355px" />
                                        }
                                        else
                                        {
                                            <MudImage Src="@_sponsorImages[1]?.Src"
                                                      Class="rounded-lg"
                                                      ObjectFit="ObjectFit.Cover"
                                                      ObjectPosition="ObjectPosition.Center"
                                                      Height="200"
                                                      Width="355" />
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudItem>

                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@L["WebsiteGallery"]</MudText>
                            </MudItem>

                            <MudItem xs="12" Class="pt-0">
                                <MudFileUpload @ref="_galleryUpload" T="IReadOnlyList<IBrowserFile>" Accept=".jpg, .png, .jpeg" AppendMultipleFiles="true" DragAndDrop="true"
                                               @bind-Dragging="@_dragging" @bind-Dragging:after="@ClearDragClass" FilesChanged="UploadGalleryImagesAsync"
                                               Disabled="@(_isReview || _eventStatus == AdminEventStatus.Published)">
                                    <CustomContent>
                                        <MudPaper Height="300px;" Outlined="true" @onclick="@context.OpenFilePickerAsync" @ondragenter="@SetDragClass"
                                                  Class="@($"pa-4 {_dragClass}")">

                                            <MudText Typo="Typo.body1">
                                                @L["GalleryUploadHint"]
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                @L["GalleryUploadHintDetails", _minWidth, _minHeight, _maxFileSize / 1024 / 1024]
                                            </MudText>

                                            @if (_galleryImages.Count > 0 && !(_isReview || _eventStatus == AdminEventStatus.Published))
                                            {
                                                <div class="mt-4 d-flex flex-wrap gap-2" style="z-index: 10;">
                                                    @foreach (var image in _galleryImages)
                                                    {
                                                        <MudChip T="string"
                                                                 Variant="Variant.Filled"
                                                                 Class="bg-secondary-darken"
                                                                 Color="MudBlazor.Color.Dark"
                                                                 OnClose="@(() => RemoveGalleryImageAsync(image))"
                                                                 CloseIcon="@Icons.Material.Filled.Close"
                                                                 @onclick:preventDefault="true">
                                                            @image.Name
                                                        </MudChip>
                                                    }
                                                </div>
                                            }

                                            @if (_galleryImages.Any() && !(_isReview || _eventStatus == AdminEventStatus.Published))
                                            {
                                                <div style="position: absolute; bottom: 16px; right: 16px; z-index: 20;">
                                                    <MudButton Variant="Variant.Outlined"
                                                               StartIcon="@Icons.Material.Filled.ClearAll"
                                                               Color="MudBlazor.Color.Secondary"
                                                               OnClick="CleanGalleryImagesAsync">
                                                        @L["Clear"]
                                                    </MudButton>
                                                </div>
                                            }
                                        </MudPaper>
                                    </CustomContent>
                                    <SelectedTemplate />
                                </MudFileUpload>
                            </MudItem>
                            <MudItem xs="12">
                                <MudStack>
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight: 600;">@L["GalleryPreview"]</MudText>
                                    @if (!_galleryImages.Any())
                                    {
                                        <ImagePlaceholder Class="rounded-lg" Height="200px" Width="355px" />
                                    }
                                    else
                                    {
                                        <MudCarousel @ref="_carousel"
                                                     ItemsSource="_galleryImages"
                                                     Style="height:200px; width: 355px;"
                                                     ShowArrows
                                                     ShowBullets>
                                            <ItemTemplate>
                                                <MudImage Src="@context.Src"
                                                          Class="rounded-lg"
                                                          ObjectFit="ObjectFit.Cover"
                                                          ObjectPosition="ObjectPosition.Center"
                                                          Height="200"
                                                          Width="355" />
                                            </ItemTemplate>
                                        </MudCarousel>
                                    }
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudStep>
                </ChildContent>
                <ActionContent Context="stepperContext">
                    <MudSpacer />
                    @if (_activeIndex < _maxIndex)
                    {
                        <MudButton OnClick="ValidateAndGoNextAsync"
                                   EndIcon="@Icons.Material.Filled.ChevronRight"
                                   Variant="Variant.Text"
                                   Color="MudBlazor.Color.Primary">
                            @L["Next"]
                        </MudButton>
                    }
                    else if (_activeIndex == _maxIndex && !(_isReview || _eventStatus == AdminEventStatus.Published))
                    {
                        <MudButton OnClick="SubmitAsync"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Outlined.Save"
                                   Color="MudBlazor.Color.Tertiary">
                            @L["Save"]
                        </MudButton>
                    }
                </ActionContent>
            </MudStepper>
        </MudCardContent>
    </MudCard>
</LoadingContainer>

@code {
    [Parameter] public long? EventId { get; set; }
    [Parameter] public long? ScheduleId { get; set; }

    private string _pageTitle = "";
    private bool _loading = true;
    private bool _error = false;
    private bool _isEdit = false;
    private bool _isReview = false;

    private MudStepper _stepper = null!;
    private int _activeIndex = 0;
    private int _highestUnlockedStep = 0;
    private int _maxIndex = 3;

    private MudForm _descriptionForm = default!;
    private bool _descriptionFormValid;
    private FormContext _descriptionFormContext = default!;

    private MudForm _datesAndSalePoliciesForm = default!;
    private bool _datesAndSalePoliciesValid;
    private FormContext _datesAndSalePoliciesFormContext = default!;

    private MudForm _pricesForm = default!;
    private bool _pricesValid;
    private FormContext _pricesFormContext = default!;

    private List<AdminEventCategoryResult> _eventCategories = [];
    private IReadOnlyCollection<AdminEventCategoryResult> _selectedCategories = [];
    private List<AgeRestriction> _ageRestrictions = Enum.GetValues<AgeRestriction>().ToList();
    private List<VenueResponse> _venues = [];
    private List<VenueMapResponse> _venueMaps = [];
    private List<ListItem> _organizers = [];

    private MudFileUpload<IBrowserFile> _bannerImageUpload = null!;
    private ImageModel? _bannerImage;
    private MudFileUpload<IBrowserFile>[] _sponsorUploads = new MudFileUpload<IBrowserFile>[2];
    private ImageModel?[] _sponsorImages = new ImageModel?[2];
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _galleryUpload = null!;
    private List<ImageModel> _galleryImages = [];
    private MudCarousel<ImageModel> _carousel = null!;

    private readonly long _maxFileSize = 10 * 1024 * 1024; // 10 MB
    private readonly int _minWidth = 1920;
    private readonly int _minHeight = 1080;

    private const string DefaultDragClass = "relative d-flex flex-column p-r gap-2 rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full";
    private string _dragClass = DefaultDragClass;
    private bool _dragging = false;

    private AdminEventStatus? _eventStatus;
    private string? _name;
    private string? _subtitle;
    private string? _shortDescription;
    private string? _longDescription;
    private DateTime? _startDate;
    private TimeSpan? _startTime;
    private DateTime? _endDate;
    private TimeSpan? _endTime;
    private DateTime? _preSaleDate;
    private TimeSpan? _preSaleTime;
    private DateTime? _presaleEndDate;
    private TimeSpan? _preSaleEndTime;
    private DateTime? _onSaleDate;
    private TimeSpan? _onSaleTime;
    private DateTime? _offSaleDate;
    private TimeSpan? _offSaleTime;
    private DateTime? _publishedDate;
    private TimeSpan? _publishedTime;
    private DateTime? _gateOpenDate;
    private TimeSpan? _gateOpenTime;
    private int? _holdExpirationInMinutes;
    private AgeRestriction? _ageRestriction;
    private string? _securityPolicies;
    private string? _additionalComments;
    private string? _externalEventKey;

    private List<PriceForm> _prices = [];
    private long? _currentPricesMapId;
    private string _searchPrices = string.Empty;
    private TableGroupDefinition<PriceForm> _groupDefinition = new()
    {
        GroupName = "Zone",
        Indentation = true,
        Expandable = false,
        Selector = (e) => e.BaseZoneId,
        IsInitiallyExpanded = true
    };

    private Dictionary<string, bool> PriceTypes { get; set; } = new Dictionary<string, bool> { { "General", true } };

    private string _priceTypeName = string.Empty;

    private VenueMapLayoutResponse _layout;

    private string? _venueAddress;
    private string? _venueCoordinates;

    private long? _organizerId;
    private VenueResponse? _selectedVenue;
    private VenueMapResponse? _selectedVenueMap;

    private static readonly DialogOptions _dialogOptions = new() { CloseButton = true };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _descriptionFormContext.SetForm(_descriptionForm);
            await InitializeForm();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _descriptionFormContext = new FormContext(StateHasChanged);
        _datesAndSalePoliciesFormContext = new FormContext(StateHasChanged);
        _pricesFormContext = new FormContext(StateHasChanged);

        // TODO: Change to use user permissions instead of URL to determine read-only mode
        if (Navigation.Uri.Contains("/review"))
        {
            _isReview = true;
        }
    }

    private async Task InitializeForm()
    {
        _loading = true;
        _error = false;
        StateHasChanged();
        try
        {
            await LoadCatalogs();
            if (EventId.HasValue && EventId.Value > 0)
            {
                _isEdit = true;
                await LoadData();
                _pageTitle = _name;
            }
            else
            {
                _pageTitle = L["CreateEvent"];
                _isEdit = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCatalogs()
    {
        var venueTask = CatalogsService.GetVenuesAsync();
        var catTask = EventService.GetCategoriesAsync();
        var organizersTask = OrganizersService.GetOrganizersCatalogAsync();

        await Task.WhenAll(venueTask, catTask, organizersTask);

        _venues = await venueTask;
        _eventCategories = (await catTask).Where(c => c.IsActive == true).ToList();
        _organizers = (await organizersTask).ToList();
    }

    private async Task LoadData()
    {
        if (EventId is null || EventId <= 0)
        {
            return;
        }

        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            var eventResult = await EventService.GetEventByIdAsync(EventId.Value);

            ScheduleId = ScheduleId ?? eventResult.Schedules?.First().Id;

            var schedule = eventResult.Schedules?.FirstOrDefault(s => s.Id == ScheduleId);

            _name = eventResult.Name;
            _subtitle = eventResult.Subtitle;
            _shortDescription = eventResult.ShortDescription;
            _longDescription = eventResult.LongDescription;
            _ageRestriction = eventResult.AgeRestriction;
            _securityPolicies = eventResult.SecurityPolicies;
            _additionalComments = eventResult.AdditionalComments;
            _selectedCategories = eventResult.Categories.ToList();
            _eventStatus = eventResult.Status;
            _organizerId = eventResult.OrganizerId;

            await OnVenueSelected(_venues.FirstOrDefault(v => v.Id == eventResult.VenueId));
            await OnVenueMapSelected(_venueMaps.FirstOrDefault(m => m.Id == eventResult.VenueMapId));

            if (schedule is not null)
            {
                _startDate = DateTimeHelpers.ToNullableDateTime(schedule?.StartDateTime);
                _startTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.StartDateTime);
                _endDate = DateTimeHelpers.ToNullableDateTime(schedule?.EndDateTime);
                _endTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.EndDateTime);
                _preSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleStartDate);
                _preSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleStartDate);
                _presaleEndDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleEndDate);
                _preSaleEndTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleEndDate);
                _onSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OnSaleDate);
                _onSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OnSaleDate);
                _offSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OffSaleDate);
                _offSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OffSaleDate);
                _publishedDate = DateTimeHelpers.ToNullableDateTime(schedule?.PublishedDate);
                _publishedTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PublishedDate);
                _gateOpenDate = DateTimeHelpers.ToNullableDateTime(schedule?.GateOpenDate);
                _gateOpenTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.GateOpenDate);
                _holdExpirationInMinutes = schedule.HoldExpirationInMinutes;
                _externalEventKey = schedule.ExternalEventKey;
            }

            _layout = await VenueMapsService.GetVenueMapLayoutByIdAsync(_selectedVenueMap.Id);

            await LoadPrices();
            await LoadEventMediaAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
