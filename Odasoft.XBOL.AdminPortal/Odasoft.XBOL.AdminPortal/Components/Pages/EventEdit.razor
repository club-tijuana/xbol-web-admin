    private void InitializePrices()
    {
        if (_layout.Zones is not null && _layout.Zones.Count > 0)
        {
            foreach (var zone in _layout.Zones)
            {
                _prices.Add(new PriceForm
                {
                   BaseZoneId = zone.Id 
                });
            }
        }
    }

    private void AddPriceType(string type)
    {
        if (!string.IsNullOrWhiteSpace(type) && !PriceTypes.Contains(type))
        {
            PriceTypes.Add(type);
        }
    }

    private void EditPriceType(string oldName, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName) || PriceTypes.Contains(newName))
        {
            return;
        }
        int index = PriceTypes.IndexOf(oldName);
        if (index != -1)
        {
            PriceTypes[index] = newName;
            foreach (var price in _prices)
            {
                if (price.PriceTypes.ContainsKey(oldName))
                {
                    decimal? value = price.PriceTypes[oldName];
                    price.PriceTypes.Remove(oldName);
                    price.PriceTypes[newName] = value;
                }
            }
        }
    }

    private async Task DeletePriceType()
    {
        PriceTypes.Remove(_priceTypeName);

        foreach (var price in _prices)
        {
            if (price.PriceTypes.ContainsKey(_priceTypeName))
            {
                price.PriceTypes.Remove(_priceTypeName);
            }
        }
    }

    private decimal? GetPriceTypeValue(PriceForm row, string key)
    {
        return row.PriceTypes.TryGetValue(key, out var value) ? value : null;
    }

    private void SetPriceTypeValue(PriceForm row, string key, decimal? newValue)
    {
        row.PriceTypes[key] = newValue;
    }

    private async Task DeletePriceAsync(PriceForm price)
    {
        var confirmed = await DialogService.ShowConfirmDeleteAsync(
        L["DeleteDialogTitle", L["Price"]],
        L["DeleteDialogMessage"]);

        if (!confirmed) return;

        try
        {
            _prices.Remove(price);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting event: {ex.Message}");
            Snackbar.Add(L["DeleteError"], Severity.Error);
        }
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<PriceTypeDialogAdd>(null, _dialogOptions);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is not null)
        {
            var priceType = result.Data.ToString();
            if (!string.IsNullOrWhiteSpace(priceType))
            {
                AddPriceType(priceType);
            }
        }
    }

    private async Task OpenEditDialog(string type)
    {
        _priceTypeName = type;

        var parameters = new DialogParameters<PriceTypeDialogEdit>
        {
            { x => x.Name, _priceTypeName },
            { x => x.OnDelete, EventCallback.Factory.Create(this, DeletePriceType) },
        };
        var dialog = await DialogService.ShowAsync<PriceTypeDialogEdit>(null, parameters, _dialogOptions);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is not null)
        {
            var priceType = result.Data.ToString();
            if (!string.IsNullOrWhiteSpace(priceType))
            {
                EditPriceType(_priceTypeName, priceType);          
            }
        }
    }

    public class PriceForm
    {
        public long? Id { get; set; }
        public long? BaseZoneId { get; set; }
        public long? BaseSectionId { get; set; }
        public long? BaseRowId { get; set; }
        public long? BaseSeatId { get; set; }
        public decimal? ItemPrice { get; set; }
        public Dictionary<string, decimal?> PriceTypes { get; set; } = new();

        public bool IsZonePrice => BaseSectionId is null && BaseRowId is null && BaseSeatId is null;
    }
}
