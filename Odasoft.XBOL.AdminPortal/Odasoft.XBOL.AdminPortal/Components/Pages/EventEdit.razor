    private void AddPriceType(string type)
    {
        if (!string.IsNullOrWhiteSpace(type) && !PriceTypes.ContainsKey(type))
        {
            PriceTypes.Add(type, false);
            MarkPriceAsDirty(0);
        }
    }

    private void EditPriceType(string oldName, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName) || PriceTypes.ContainsKey(newName))
        {
            return;
        }
        if (PriceTypes.ContainsKey(oldName))
        {
            bool isPrimary = PriceTypes[oldName];
            PriceTypes.Remove(oldName);
            PriceTypes[newName] = isPrimary;

            foreach (var price in EventState.PricesInfo.Prices)
            {
                if (price.Prices.ContainsKey(oldName))
                {
                    decimal value = price.Prices[oldName];
                    price.Prices.Remove(oldName);
                    price.Prices[newName] = value;
                }
            }
            MarkPriceAsDirty(0);
        }
    }

    private async Task DeletePriceType()
    {
        PriceTypes.Remove(_priceTypeName);

        foreach (var price in EventState.PricesInfo.Prices)
        {
            if (price.PriceTypes.ContainsKey(_priceTypeName))
            {
                price.PriceTypes.Remove(_priceTypeName);
            }
        }
        MarkPriceAsDirty(0);
    }

    private decimal? GetPriceTypeValue(PriceInfoModel row, string key)
    {
        return row.Prices.TryGetValue(key, out var value) ? value : null;
    }

    private void SetPriceTypeValue(PriceInfoModel row, string key, decimal? newValue)
    {
        if (newValue.HasValue)
        {
            row.Prices[key] = newValue.Value;
            row.PriceTypes.TryAdd(key, PriceTypes.TryGetValue(key, out var isBasePrice) && isBasePrice);
        }
        else
        {
            row.Prices.Remove(key);
        }
        MarkPriceAsDirty(row.Id ?? 0);
    }

    private bool CanCopyPriceType(PriceInfoModel source, string priceType)
    {
        var value = GetPriceTypeValue(source, priceType);

        return value.HasValue && value.Value > 0;
    }

    private void CopyPriceTypeToAll(PriceInfoModel source, string priceType)
    {
        var value = GetPriceTypeValue(source, priceType);
        if (!CanCopyPriceType(source, priceType) || !value.HasValue)
        {
            return;
        }

        foreach (var price in EventState.PricesInfo.Prices)
        {
            SetPriceTypeValue(price, priceType, value);
        }
    }

