    private async Task LoadEventMediaAsync()
    {
        if (EventId is null || EventId <= 0)
        {
            return;
        }

        var media = await MediaService.GetEventMediaAsync(EventId.Value);

        _bannerImage = ToImageModel(media.Banner, AdminMediaType.Banner);
        _sponsorImages = new ImageModel?[2];
        _galleryImages = [];

        foreach (var sponsor in (media.Sponsors ?? []).OrderBy(s => s.Order ?? int.MaxValue))
        {
            var order = sponsor.Order ?? 0;
            if (order < 0 || order >= _sponsorImages.Length)
            {
                continue;
            }

            _sponsorImages[order] = ToImageModel(sponsor, AdminMediaType.Sponsor, order);
        }

        foreach (var (index, image) in (media.Gallery ?? []).OrderBy(g => g.Order ?? int.MaxValue).Index())
        {
            var imageModel = ToImageModel(image, AdminMediaType.Gallery, index);
            if (imageModel is not null)
            {
                imageModel.Order = index;
                _galleryImages.Add(imageModel);
            }
        }
    }

    private static ImageModel? ToImageModel(MediaResponse? media, AdminMediaType mediaType, int order = 0)
    {
        if (media is null || !media.Id.HasValue)
        {
            return null;
        }

        return new ImageModel
        {
            Id = media.Id,
            Name = GetMediaName(media),
            ContentType = media.ContentType ?? string.Empty,
            Src = media.Url ?? string.Empty,
            Order = media.Order ?? order,
            MediaType = mediaType
        };
    }

    private static string GetMediaName(MediaResponse media)
        => !string.IsNullOrWhiteSpace(media.FileName)
            ? media.FileName
            : media.Title ?? string.Empty;

