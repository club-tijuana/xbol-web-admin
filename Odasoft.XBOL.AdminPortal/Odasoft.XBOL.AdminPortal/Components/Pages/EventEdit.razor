    private async Task LoadPrices()
    {
        if (EventId == null || EventState.EventInfo.SelectedVenueMap == null)
        {
            InitializeEmptyPrices();
            return;
        }

        try
        {
            PriceReferenceResponse priceResponse = await PriceReferenceService.GetPriceReferenceAsync(AdminSaleType.Event, EventId.Value, EventState.EventInfo.SelectedVenueMap.Id);

            _priceReferenceId = priceResponse.Id;

            EventState.PricesInfo.Prices = priceResponse.PriceSegments.Select(x => new PriceInfoModel
            {
                Id = x.Id,
                BaseZoneId = x.BaseZoneId,
                BaseSectionId = x.BaseSectionId,
                BaseRowId = x.BaseRowId,
                BaseSeatId = x.BaseSeatId,
                PriceTypes = x.PriceTypes?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new(),
                Prices = x.Prices?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new()
            }).ToList();

            PriceTypes = EventState.PricesInfo.Prices.FirstOrDefault()?.PriceTypes ?? new Dictionary<string, bool> { { "General", true } };
            _dirtyPriceIds.Clear();
            _pricesHaveChanges = false;
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode == StatusCodes.Status404NotFound)
            {
                InitializeEmptyPrices();
            }
        }
    }

    private async Task LoadAdditionalCharges()
    {
