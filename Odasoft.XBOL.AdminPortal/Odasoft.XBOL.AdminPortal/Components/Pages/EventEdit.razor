    private async Task LoadPrices()
    {
        if (EventId == null || _selectedVenueMap == null)
        {
            InitializeEmptyPrices();
            return;
        }

        try
        {
            PriceReferenceResponse priceResponse = await PriceReferenceService.GetPriceReferenceAsync(AdminSaleType.Event, EventId.Value, _selectedVenueMap.Id);

            _prices = priceResponse.PriceSegments.Select(x => new PriceForm
            {
                Id = x.Id,
                BaseZoneId = x.BaseZoneId,
                BaseSectionId = x.BaseSectionId,
                BaseRowId = x.BaseRowId,
                BaseSeatId = x.BaseSeatId,
                PriceTypes = x.PriceTypes?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new(),
                Prices = x.Prices?.ToDictionary(kvp => kvp.Key, kvp => kvp.Value) ?? new()
            }).ToList();

            PriceTypes = _prices.FirstOrDefault()?.PriceTypes ?? new Dictionary<string, bool> { { "General", true } };
        }
        catch (ApiException apiEx)
        {
            if (apiEx.StatusCode == StatusCodes.Status404NotFound)
            {
                InitializeEmptyPrices();
            }
        }
    }

    private void InitializeEmptyPrices()
    {
        if (_layout.Zones is not null && _layout.Zones.Count > 0)
        {
            _prices.Clear();
            foreach (var zone in _layout.Zones)
            {
                _prices.Add(new PriceForm
                {
                    BaseZoneId = zone.Id
                });
            }
        }
    }

    private void AddPriceType(string type)
    {
        if (!string.IsNullOrWhiteSpace(type) && !PriceTypes.ContainsKey(type))
