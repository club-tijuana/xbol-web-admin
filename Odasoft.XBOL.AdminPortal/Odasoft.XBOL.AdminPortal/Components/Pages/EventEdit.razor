    private async Task OnVenueSelected(VenueResponse? venueSelected)
    {
        _selectedVenue = venueSelected;
        _selectedVenueMap = null;

        if (_selectedVenue is null)
        {
            _venueMaps = [];
            _venueAddress = null;
            _venueCoordinates = null;
            return;
        }

        LoadingState.Show();
        try
        {
            _venueMaps = await CatalogsService.GetVenueMapsByVenueId(_selectedVenue.Id);

            _venueAddress = $"{_selectedVenue.StreetAddress} {_selectedVenue.ExtNum}, {_selectedVenue.Neighborhood}, {_selectedVenue.ZipCode} {_selectedVenue.City}, {_selectedVenue.State}";
            _venueCoordinates = $"{_selectedVenue.Latitude}, {_selectedVenue.Longitude}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load venue");
            Snackbar.Add(L["ErrorLoadingVenue"], Severity.Error);
        }
        finally
        {
            LoadingState.Hide();            
        }
    }

