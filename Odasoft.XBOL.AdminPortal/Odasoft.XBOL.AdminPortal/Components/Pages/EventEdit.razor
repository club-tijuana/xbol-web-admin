    private void OnSectionChanged(PriceForm price, long? sectionId)
    {
        price.BaseSectionId = sectionId;

        price.BaseRowId = null;
        price.BaseSeatId = null;
        StateHasChanged();
    }

    private void OnRowChanged(PriceForm price, long? rowId)
    {
        price.BaseRowId = rowId;

        price.BaseSeatId = null;
        StateHasChanged();
    }

    private void AddPrice(long zoneId)
    {
        var sections = GetSectionsFor(zoneId);
        _prices.Add(new PriceForm { BaseZoneId = zoneId, BaseSectionId = sections.FirstOrDefault()?.Id });
    }

    private IEnumerable<BaseSectionResponse>GetSectionsFor(long? zoneId)
    {
        if(zoneId == null)
        {
            return [];
        }

        var sections = _layout.Sections.Where(x => x.ZoneId == zoneId);

        return sections;
    }

    private IEnumerable<BaseRowResponse> GetRowsFor(long? sectionId)
    {
        if(sectionId == null)
        {
            return [];
        }

        var rows = _layout.Rows.Where(x => x.SectionId == sectionId);

        return rows;
    }

    private IEnumerable<BaseSeatResponse> GetSeatsFor(long? rowId)
    {
        if (rowId == null)
        {
            return [];
        }

        var seats = _layout.Seats.Where(x => x.RowId == rowId);

        return seats;
    }

    private string GetZoneName(long? zoneId)
    {
        if(zoneId == null)
        {
            return string.Empty;
        }

        var zone = _layout.Zones?.FirstOrDefault(x => x.Id == zoneId);

        return zone?.Name ?? string.Empty;
    }

