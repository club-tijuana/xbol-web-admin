    private async Task AddImage(IBrowserFile file, AdminMediaType mediaType, int order = 0)
    {
        if (file == null)
        {
            return;
        }

        if (file.Size > _maxFileSize)
        {
            // TODO: Internationalization
            Snackbar.Add($"El archivo '{file.Name}' supera el límite de 10MB.", MudBlazor.Severity.Error);
            return;
        }

        _imageHasChanges = true;

        using var stream = file.OpenReadStream(_maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        memoryStream.Position = 0;

        var imageInfo = await Image.IdentifyAsync(memoryStream);
        if (imageInfo == null)
        {
            Snackbar.Add($"El archivo '{file.Name}' no es una imagen válida.", MudBlazor.Severity.Error);
            return;
        }

        if (imageInfo.Width < _minWidth || imageInfo.Height < _minHeight)
        {
            Snackbar.Add($"La imagen '{file.Name}' mide {imageInfo.Width}x{imageInfo.Height}px. El mínimo es {_minWidth}x{_minHeight}px.", MudBlazor.Severity.Warning);
            return;
        }

        var fileBytes = memoryStream.ToArray();

        var src = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

        var newImage = new ImageModel
        {
            Name = file.Name,
            FileBytes = fileBytes,
            ContentType = file.ContentType,
            Src = src,
            Order = order,
            MediaType = mediaType
        };

        switch (mediaType)
        {
            case AdminMediaType.Banner:
                newImage.Id = EventState.ImagesInfo.BannerImage?.Id;
                EventState.ImagesInfo.BannerImage = newImage;
                await _bannerImageUpload.ClearAsync();
                break;
            case AdminMediaType.Sponsor:
                newImage.Id = EventState.ImagesInfo.SponsorImages[order]?.Id;
                EventState.ImagesInfo.SponsorImages[order] = newImage;
                await _sponsorUploads[order].ClearAsync();
                break;
            default:
                return;
        }
    }

    private async Task DeleteImageAsync(AdminMediaType mediaType, int order = 0)
    {
        _imageHasChanges = true;
        switch (mediaType)
        {
            case AdminMediaType.Banner:
                if (EventState.ImagesInfo.BannerImage != null)
                {
                    EventState.ImagesInfo.BannerImage = null;
                    await _bannerImageUpload.ClearAsync();
                }
                break;
            case AdminMediaType.Sponsor:
                var image = EventState.ImagesInfo.SponsorImages[order];
                if(image != null)
                {
                    EventState.ImagesInfo.SponsorImages[order] = null;
                    await _sponsorUploads[order].ClearAsync();
                }
                break;
            default:
                return;
        }
    }

    private async Task UploadGalleryImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        if (files == null || !files.Any())
        {
            return;
        }

        _imageHasChanges = true;

        foreach (var file in files)
        {
            if (file.Size > _maxFileSize)
            {
                Snackbar.Add($"El archivo '{file.Name}' supera el límite de 10MB.", MudBlazor.Severity.Error);
                continue;
            }

            string src = string.Empty;
            try
            {
                using var stream = file.OpenReadStream(_maxFileSize);
                using var memoryStream = new MemoryStream();

                await stream.CopyToAsync(memoryStream);

                memoryStream.Position = 0;

                var imageInfo = await Image.IdentifyAsync(memoryStream);
                if (imageInfo == null)
                {
                    Snackbar.Add($"El archivo '{file.Name}' no es una imagen válida.", MudBlazor.Severity.Error);
                    continue;
                }

                if (imageInfo.Width < _minWidth || imageInfo.Height < _minHeight)
                {
                    Snackbar.Add($"La imagen '{file.Name}' mide {imageInfo.Width}x{imageInfo.Height}px. El mínimo es {_minWidth}x{_minHeight}px.", MudBlazor.Severity.Warning);
                    continue;
                }

                var fileBytes = memoryStream.ToArray();

                src = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

                EventState.ImagesInfo.GalleryImages.Add(new ImageModel
                {
                    Name = file.Name,
                    FileBytes = fileBytes,
                    ContentType = file.ContentType,
                    Src = src,
                    MediaType = AdminMediaType.Gallery
                });
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, $"An error occurred while trying to read the file '{file.Name}'.");
                Snackbar.Add($"Error al procesar '{file.Name}': El formato podría no estar soportado.", MudBlazor.Severity.Error);
                continue;
            }
        }

        if (_galleryUpload != null)
        {
            await _galleryUpload.ClearAsync();
        }

        if (_carousel is not null)
        {
            _carousel.MoveTo(EventState.ImagesInfo.GalleryImages.Count - 1);
        }
    }

    private async Task RemoveGalleryImageAsync(ImageModel image)
    {
        try
        {
            EventState.ImagesInfo.GalleryImages.Remove(image);
