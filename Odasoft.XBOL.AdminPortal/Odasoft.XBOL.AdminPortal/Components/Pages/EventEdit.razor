    private void EditPriceType(string oldName, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName) || PriceTypes.ContainsKey(newName))
        {
            return;
        }

        if (PriceTypes.ContainsKey(oldName))
        {
            bool isPrimary = PriceTypes[oldName];
            PriceTypes.Remove(oldName);
            PriceTypes[newName] = isPrimary;

            foreach (var price in _prices)
            {
                if (price.Prices.ContainsKey(oldName))
                {
                    decimal value = price.Prices[oldName];
                    price.Prices.Remove(oldName);
                    price.Prices[newName] = value;
                }
            }
        }
    }

