                    <MudStep Title="@L["PosterAndGallery"]">
                        <MudGrid Spacing="7">
                            <MudItem xs="12">
                                <MudFileUpload @ref="_horizontalImageUpload" T="IBrowserFile" FilesChanged="UploadHorizontalAsync">
                                    <CustomContent>
                                        <div class="d-flex align-center gap-4">
                                            <MudButton StartIcon="@Icons.Material.Filled.Upload"
                                                       Variant="Variant.Filled"
                                                       Class="text-uppercase"
                                                       Style="background-color: #546e7a; color: white;"
                                                       OnClick="@context.OpenFilePickerAsync">
                                                @L["HorizontalPoster"]
                                            </MudButton>

                                            @if (_horizontalImage != null)
                                            {
                                                <MudText Typo="Typo.body1" Style="color: #455a64; font-weight: 500;">
                                                    @_horizontalImage.Name
                                                </MudText>

                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" OnClick="DeleteHorizontalAsync" />
                                            }
                                        </div>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>
                            <MudItem xs="12">
                                <MudFileUpload @ref="_verticalImageUpload" T="IBrowserFile" FilesChanged="UploadVerticalAsync">
                                    <CustomContent>
                                        <div class="d-flex align-center gap-4">
                                            <MudButton StartIcon="@Icons.Material.Filled.Upload"
                                                       Variant="Variant.Filled"
                                                       Class="text-uppercase"
                                                       Style="background-color: #546e7a; color: white;"
                                                       OnClick="@context.OpenFilePickerAsync">
                                                @L["VerticalPoster"]
                                            </MudButton>

                                            @if (_verticalImage != null)
                                            {
                                                <MudText Typo="Typo.body1" Style="color: #455a64; font-weight: 500;">
                                                    @_verticalImage.Name
                                                </MudText>

                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" OnClick="DeleteVerticalAsync" />
                                            }
                                        </div>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>

                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@L["WebsiteGallery"]</MudText>
                            </MudItem>

                            <MudItem xs="12" Class="pt-0">
                                <MudFileUpload @ref="_galleryUpload" T="IReadOnlyList<IBrowserFile>" Accept=".jpg, .png, .jpeg" AppendMultipleFiles="true" DragAndDrop="true"
                                               @bind-Dragging="@_dragging" @bind-Dragging:after="@ClearDragClass" FilesChanged="UploadGalleryImagesAsync">
                                    <CustomContent>
                                        <MudPaper Height="300px;" Outlined="true" @onclick="@context.OpenFilePickerAsync" @ondragenter="@SetDragClass"
                                                  Class="@($"pa-4 {_dragClass}")">

                                            <MudText Typo="Typo.body1">
                                                @L["GalleryUploadHint"]
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                @L["GalleryUploadHintDetails", _minWidth, _minHeight, _maxFileSize / 1024 / 1024]
                                            </MudText>

                                            @if (_galleryImages != null && _galleryImages.Count() > 0)
                                            {
                                                <div class="mt-4 d-flex flex-wrap gap-2" style="z-index: 10;">
                                                    @foreach (var fileName in _galleryImages.Keys)
                                                    {
                                                        <MudChip T="string" Color="MudBlazor.Color.Dark" OnClose="@(() => RemoveGalleryImageAsync(fileName))" @onclick:preventDefault="true">
                                                            @fileName
                                                        </MudChip>
                                                    }
                                                </div>
                                            }

                                            @if (_galleryImages != null && _galleryImages.Any())
                                            {
                                                <div style="position: absolute; bottom: 16px; right: 16px; z-index: 20;">
                                                    <MudButton Variant="Variant.Outlined"
                                                               StartIcon="@Icons.Material.Filled.ClearAll"
                                                               Color="MudBlazor.Color.Secondary"
                                                               OnClick="CleanGalleryImagesAsync">
