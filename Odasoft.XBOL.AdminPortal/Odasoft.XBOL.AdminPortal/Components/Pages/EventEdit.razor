@page "/events/{EventId:long}/edit"
@page "/events/{EventId:long}/schedules/{ScheduleId:long}/edit"
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.Business.Services
@using SixLabors.ImageSharp

@inject CatalogsService CatalogsService;
@inject IEventService EventService;
@inject VenuesService VenuesService
@inject EventScheduleService ScheduleService
@inject AppLocalizer<EventEdit> L
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LoadingState LoadingState;
@inject ILogger<EventEdit> Logger

<style>
    .mud-stepper .mud-stepper-content {
        padding-left:0;
        padding-right: 8px;
    }

    .mud-stepper-nav .mud-step:first-of-type{
        padding-left:0;
    }
    .mud-stepper-nav .mud-step:last-of-type{
        padding-right:8px;
    }
</style>

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="MudBlazor.Color.Secondary"
                       Variant="Variant.Outlined" DropShadow="false" OnClick="@(() => GoBackAsync())">
                @L["GoBack"]
            </MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer
    IsLoading="_loading"
    HasError="_error"
    ErrorMessage="@L["ErrorLoadingEvent"]"
    OnRetry="LoadData">
    <MudCard Elevation="3">
        <MudCardContent Class="pa-6">
            <MudStack Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
                <MudText Typo="Typo.h5">@L["PageTitle"]</MudText>
                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">@L["RequiredFieldsNote"]</MudText>
            </MudStack>

            <MudStepper @ref="_stepper" @bind-ActiveIndex="_activeIndex" OnPreviewInteraction="OnPreviewInteraction" NonLinear Class="pa-0">
                <ChildContent>
                    <MudStep Title="@L["DescriptionAndVenue"]">
                        <MudForm @ref="_descriptionForm" @bind-IsValid="_descriptionFormValid" @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="7">
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_name"
                                                            Label="@L["Name"].Value"
                                                            Field="@_descriptionFormContext.Field("Name")"
                                                            Required />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_subtitle"
                                                            Label="@L["Subtitle"].Value"
                                                            Field="@_descriptionFormContext.Field("Subtitle")" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudSelect Label="@L["EventType"]"
                                                       T="EventCategoryResult"
                                                       MultiSelection="true"
                                                       @bind-SelectedValues="_selectedCategories"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       ToStringFunc="@(c => c?.DisplayName ?? "")"
                                                       Required>

                                                @foreach (var category in _eventCategories)
                                                {
                                                    <MudSelectItem T="EventCategoryResult" Value="category">
                                                        @category.DisplayName
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_shortDescription"
                                                            Label="@L["EventSummary"].Value"
                                                            Field="@_descriptionFormContext.Field("ShortDescription")"
                                                            Lines="@(3)" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="_longDescription"
                                                            Label="@L["EventDescription"].Value"
                                                            Field="@_descriptionFormContext.Field("LongDescription")"
                                                            Lines="@(6)" />
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueResponse?"
                                                         Value="_selectedVenue"
                                                         ValueChanged="OnVenueSelected"
                                                         Label="@L["Venue"].Value"
                                                         Required>
                                                @foreach (var venue in _venues)
                                                {
                                                    <MudSelectItem T="VenueResponse?" Value="@venue">@venue.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueMapResponse?"
                                                         Value="_selectedVenueMap"
                                                         ValueChanged="OnVenueMapSelected"
                                                         Label="@L["Map"].Value"
                                                         Required>
                                                @foreach (var map in _venueMaps)
                                                {
                                                    <MudSelectItem T="VenueMapResponse?" Value="@map">@map.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueAddress"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Label="@L["Address"].Value"
                                                          Disabled="@true" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueCoordinates"
                                                          Label="@L["Coordinates"].Value"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Disabled="@true" />
                                        </MudItem>
                                        @if (_selectedVenueMap is not null)
                                        {
                                            <MudItem xs="12" Class="d-flex justify-center">
                                                <MudImage Src="@_selectedVenueMap.ThumbnailUrl" Alt="@_selectedVenueMap.Name" Class="rounded-lg" Height="400" />
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                    <MudStep Title="@L["DatesAndSalePolicies"]">
                        <MudForm @ref="_datesAndSalePoliciesForm" @bind-IsValid="_datesAndSalePoliciesValid" @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="6">
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["EventSchedule"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_startDate"
                                                     Label="@L["StartDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("StartDate")"
                                                     Required />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_startTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_endDate" Label="@L["EndDate"].Value" Required Field="@_datesAndSalePoliciesFormContext.Field("EndDate")" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_endTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["TicketsPreSale"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_preSaleDate"
                                                     Label="@L["StartDate"].Value"
                                                     Field="@_datesAndSalePoliciesFormContext.Field("PreSaleDate")"
                                                     Required />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_preSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_presaleEndDate" Label="@L["EndDate"].Value" Required Field="@_datesAndSalePoliciesFormContext.Field("PreSaleEndDate")" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_preSaleEndTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["TicketsSale"]</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_onSaleDate" Label="@L["StartDate"].Value" Field="@_datesAndSalePoliciesFormContext.Field("OnSaleDate")" Required />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_onSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <AdminDatePicker @bind-Date="_offSaleDate" Label="@L["EndDate"].Value" Required Field="@_datesAndSalePoliciesFormContext.Field("OffSaleDate")" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudTimePicker @bind-Time="_offSaleTime"
                                                   Label="@L["Time"].Value"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   TimeFormat="h:mm tt"
                                                   AmPm="true"
                                                   Required />
                                </MudItem>
                                <MudFlexBreak />
                                <MudItem xs="12" md="5">
                                    <MudGrid Spacing="6">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                            ;">@L["WebSitePublishing"]</MudText>
                                        </MudItem>
                                        <MudItem xs="12" md="7">
                                            <AdminDatePicker @bind-Date="_publishedDate" Label="@L["PublishDate"].Value" Required Field="@_datesAndSalePoliciesFormContext.Field("PublishedDate")" />
                                        </MudItem>
                                        <MudItem xs="12" md="5">
                                            <MudTimePicker @bind-Time="_publishedTime"
                                                           Label="@L["Time"].Value"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           TimeFormat="h:mm tt"
                                                           AmPm="true"
                                                           Required />
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" md="5">
                                    <MudGrid Spacing="6">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                            ;">@L["VenueAccess"]</MudText>
                                        </MudItem>
                                        <MudItem xs="12" md="7">
                                            <AdminDatePicker @bind-Date="_gateOpenDate" Label="@L["AccessDate"].Value" Required Field="@_datesAndSalePoliciesFormContext.Field("GateOpenDate")" />
                                        </MudItem>
                                        <MudItem xs="12" md="5">
                                            <MudTimePicker @bind-Time="_gateOpenTime"
                                                           Label="@L["Time"].Value"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           TimeFormat="h:mm tt"
                                                           AmPm="true"
                                                           Required />
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <AdminTextField @bind-Value="_externalEventKey"
                                                    Label="@L["ExternalEventKey"].Value"
                                                    Field="@_descriptionFormContext.Field("ExternalEventKey")"
                                                    Required />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudSelect Label="@L["AgeRestrictions"]"
                                               T="AgeRestriction?"
                                               @bind-Value="_ageRestriction"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Validation="@(_descriptionFormContext.Field("AgeRestriction").ValidationFor<AgeRestriction?>())"
                                               ToStringFunc="@(restriction => L[restriction.ToString()].Value)">

                                        @foreach (var restriction in _ageRestrictions)
                                        {
                                            <MudSelectItem T="AgeRestriction?" Value="restriction">
                                                @L[restriction.ToString()]
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <AdminTextField @bind-Value="_securityPolicies"
                                                    Label="@L["SecurityPolicies"].Value"
                                                    Field="@_descriptionFormContext.Field("SecurityPolicies")"
                                                    Lines="@(6)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <AdminTextField @bind-Value="_additionalComments"
                                                    Label="@L["AdditionalComments"].Value"
                                                    Field="@_descriptionFormContext.Field("AdditionalComments")"
                                                    Lines="@(6)" />
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                    <MudStep Title="@L["PosterAndGallery"]">
                        <MudGrid Spacing="7">
                            <MudItem xs="12">
                                <MudFileUpload @ref="_horizontalImageUpload" T="IBrowserFile" FilesChanged="UploadHorizontalAsync">
                                    <CustomContent>
                                        <div class="d-flex align-center gap-4">
                                            <MudButton StartIcon="@Icons.Material.Filled.Upload"
                                                       Variant="Variant.Filled"
                                                       Class="text-uppercase"
                                                       Style="background-color: #546e7a; color: white;"
                                                       OnClick="@context.OpenFilePickerAsync">
                                                @L["HorizontalPoster"]
                                            </MudButton>

                                            @if (_horizontalImage != null)
                                            {
                                                <MudText Typo="Typo.body1" Style="color: #455a64; font-weight: 500;">
                                                    @_horizontalImage.Name
                                                </MudText>

                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" OnClick="DeleteHorizontalAsync" />
                                            }
                                        </div>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>
                            <MudItem xs="12">
                                <MudFileUpload @ref="_verticalImageUpload" T="IBrowserFile" FilesChanged="UploadVerticalAsync">
                                    <CustomContent>
                                        <div class="d-flex align-center gap-4">
                                            <MudButton StartIcon="@Icons.Material.Filled.Upload"
                                                       Variant="Variant.Filled"
                                                       Class="text-uppercase"
                                                       Style="background-color: #546e7a; color: white;"
                                                       OnClick="@context.OpenFilePickerAsync">
                                                @L["VerticalPoster"]
                                            </MudButton>

                                            @if (_verticalImage != null)
                                            {
                                                <MudText Typo="Typo.body1" Style="color: #455a64; font-weight: 500;">
                                                    @_verticalImage.Name
                                                </MudText>

                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" OnClick="DeleteVerticalAsync" />
                                            }
                                        </div>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>

                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@L["WebsiteGallery"]</MudText>
                            </MudItem>

                            <MudItem xs="12" Class="pt-0">
                                <MudFileUpload @ref="_galleryUpload" T="IReadOnlyList<IBrowserFile>" Accept=".jpg, .png, .jpeg" AppendMultipleFiles="true" DragAndDrop="true"
                                               @bind-Dragging="@_dragging" @bind-Dragging:after="@ClearDragClass" FilesChanged="UploadGalleryImagesAsync">
                                    <CustomContent>
                                        <MudPaper Height="300px;" Outlined="true" @onclick="@context.OpenFilePickerAsync" @ondragenter="@SetDragClass"
                                                  Class="@($"pa-4 {_dragClass}")">

                                            <MudText Typo="Typo.body1">
                                                @L["GalleryUploadHint"]
                                            </MudText>
                                            <MudText Typo="Typo.caption">
                                                @L["GalleryUploadHintDetails", _minWidth, _minHeight, _maxFileSize]
                                            </MudText>

                                            @if (_galleryImages != null && _galleryImages.Count() > 0)
                                            {
                                                <div class="mt-4 d-flex flex-wrap gap-2" style="z-index: 10;">
                                                    @foreach (var fileName in _galleryImages.Keys)
                                                    {
                                                        <MudChip T="string" Color="MudBlazor.Color.Dark" OnClose="@(() => RemoveGalleryImageAsync(fileName))" @onclick:preventDefault="true">
                                                            @fileName
                                                        </MudChip>
                                                    }
                                                </div>
                                            }

                                            @if (_galleryImages != null && _galleryImages.Any())
                                            {
                                                <div style="position: absolute; bottom: 16px; right: 16px; z-index: 20;">
                                                    <MudButton Variant="Variant.Outlined"
                                                               StartIcon="@Icons.Material.Filled.ClearAll"
                                                               Color="MudBlazor.Color.Secondary"
                                                               OnClick="CleanGalleryImagesAsync">
                                                        @L["Clear"]
                                                    </MudButton>
                                                </div>
                                            }
                                        </MudPaper>
                                    </CustomContent>
                                </MudFileUpload>
                            </MudItem>
                        </MudGrid>
                    </MudStep>
                </ChildContent>
                <ActionContent Context="stepperContext">
                    <MudSpacer />
                    @if (_activeIndex < _maxIndex)
                    {
                        <MudButton OnClick="ValidateAndGoNextAsync"
                                   EndIcon="@Icons.Material.Filled.ChevronRight"
                                   Variant="Variant.Outlined"
                                   Color="MudBlazor.Color.Primary">
                            @L["Next"]
                        </MudButton>
                    }
                    else if (_activeIndex == _maxIndex)
                    {
                        <MudButton OnClick="SubmitAsync"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Outlined.Save"
                                   Color="MudBlazor.Color.Tertiary">
                            @L["Save"]
                        </MudButton>
                    }
                </ActionContent>
            </MudStepper>
        </MudCardContent>
    </MudCard>
</LoadingContainer>

@code {
    [Parameter] public long EventId { get; set; }
    [Parameter] public long? ScheduleId { get; set; }

    private bool _loading = true;
    private bool _error = false;

    private MudStepper _stepper = null!;
    private int _activeIndex = 0;
    private int _highestUnlockedStep = 0;
    private int _maxIndex = 2;

    private MudForm _descriptionForm = default!;
    private bool _descriptionFormValid;
    private FormContext _descriptionFormContext = default!;

    private MudForm _datesAndSalePoliciesForm = default!;
    private bool _datesAndSalePoliciesValid;
    private FormContext _datesAndSalePoliciesFormContext = default!;

    private List<EventCategoryResult> _eventCategories = [];
    private IReadOnlyCollection<EventCategoryResult> _selectedCategories = [];
    private List<AgeRestriction> _ageRestrictions = Enum.GetValues<AgeRestriction>().ToList();
    private List<VenueResponse> _venues = [];
    private List<VenueMapResponse> _venueMaps = [];

    private MudFileUpload<IBrowserFile> _horizontalImageUpload = null!;
    private ImageModel? _horizontalImage;
    private MudFileUpload<IBrowserFile> _verticalImageUpload = null!;
    private ImageModel? _verticalImage;
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _galleryUpload = null!;
    private Dictionary<string, ImageModel> _galleryImages = [];

    private readonly long _maxFileSize = 10 * 1024 * 1024; // 10 MB
    private readonly int _minWidth = 1920;
    private readonly int _minHeight = 1080;

    private const string DefaultDragClass = "relative d-flex flex-column p-r gap-2 rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full";
    private string _dragClass = DefaultDragClass;
    private bool _dragging = false;


    private string? _name;
    private string? _subtitle;
    private string? _shortDescription;
    private string? _longDescription;
    private DateTime? _startDate;
    private TimeSpan? _startTime;
    private DateTime? _endDate;
    private TimeSpan? _endTime;
    private DateTime? _preSaleDate;
    private TimeSpan? _preSaleTime;
    private DateTime? _presaleEndDate;
    private TimeSpan? _preSaleEndTime;
    private DateTime? _onSaleDate;
    private TimeSpan? _onSaleTime;
    private DateTime? _offSaleDate;
    private TimeSpan? _offSaleTime;
    private DateTime? _publishedDate;
    private TimeSpan? _publishedTime;
    private DateTime? _gateOpenDate;
    private TimeSpan? _gateOpenTime;
    private AgeRestriction? _ageRestriction;
    private string? _securityPolicies;
    private string? _additionalComments;
    private string _externalEventKey;

    private string? _venueAddress;
    private string? _venueCoordinates;

    private VenueResponse? _selectedVenue;
    private VenueMapResponse? _selectedVenueMap;

    protected override async Task OnInitializedAsync()
    {
        _descriptionFormContext = new FormContext(StateHasChanged);
        _datesAndSalePoliciesFormContext = new FormContext(StateHasChanged);
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            var venueTask = CatalogsService.GetVenuesAsync();
            var catTask = EventService.GetCategoriesAsync();
            var eventTask = EventService.GetEventByIdAsync(EventId);
            await Task.WhenAll(venueTask, catTask, eventTask);

            _venues = await venueTask;
            _eventCategories = (await catTask).Where(c => c.IsActive == true).ToList();

            var eventResult = await eventTask;

            ScheduleId = ScheduleId ?? eventResult.Schedules?.First().Id;

            var schedule = eventResult.Schedules?.FirstOrDefault(s => s.Id == ScheduleId);

            _name = eventResult.Name;
            _subtitle = eventResult.Subtitle;
            _shortDescription = eventResult.ShortDescription;
            _longDescription = eventResult.LongDescription;
            _ageRestriction = eventResult.AgeRestriction;
            _securityPolicies = eventResult.SecurityPolicies;
            _additionalComments = eventResult.AdditionalComments;
            _selectedCategories = eventResult.Categories.ToList();

            await OnVenueSelected(_venues.FirstOrDefault(v => v.Id == eventResult.VenueId));
            await OnVenueMapSelected(_venueMaps.FirstOrDefault(m => m.Id == eventResult.VenueMapId));

            if (schedule is not null)
            {
                _startDate = DateTimeHelpers.ToNullableDateTime(schedule?.StartDateTime);
                _startTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.StartDateTime);
                _endDate = DateTimeHelpers.ToNullableDateTime(schedule?.EndDateTime);
                _endTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.EndDateTime);
                _preSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleStartDate);
                _preSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleStartDate);
                _presaleEndDate = DateTimeHelpers.ToNullableDateTime(schedule?.PreSaleEndDate);
                _preSaleEndTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PreSaleEndDate);
                _onSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OnSaleDate);
                _onSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OnSaleDate);
                _offSaleDate = DateTimeHelpers.ToNullableDateTime(schedule?.OffSaleDate);
                _offSaleTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.OffSaleDate);
                _publishedDate = DateTimeHelpers.ToNullableDateTime(schedule?.PublishedDate);
                _publishedTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.PublishedDate);
                _gateOpenDate = DateTimeHelpers.ToNullableDateTime(schedule?.GateOpenDate);
                _gateOpenTime = DateTimeHelpers.ToNullableTimeSpan(schedule?.GateOpenDate);
                _externalEventKey = schedule.ExternalEventKey;
            }

            ICollection<EventImageResponse> horizontalImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.HorizontalPoster);
            var horizontal = horizontalImages.FirstOrDefault();

            if (horizontal != null && horizontal.Id.HasValue)
            {
                _horizontalImage = new ImageModel
                {
                    Id = horizontal.Id,
                    Name = horizontal.Title
                };
            }

            ICollection<EventImageResponse> verticalImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.VerticalPoster);
            var vertical = verticalImages.FirstOrDefault();

            if (vertical != null && vertical.Id.HasValue)
            {
                _verticalImage = new ImageModel
                {
                    Id = vertical.Id,
                    Name = vertical.Title
                };
            }

            ICollection<EventImageResponse> galleryImages = await EventService.GetEventImageByTypeAsync(EventId, ImageType.Gallery);

            foreach (var image in galleryImages)
            {

                if (string.IsNullOrWhiteSpace(image.Title))
                {
                    continue;
                }

                _galleryImages.Add(image.Title, new ImageModel
                {
                    Id = image.Id,
                    Name = image.Title
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

