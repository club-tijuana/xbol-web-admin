@page "/events/create"
@page "/events/{EventId:long}/edit"
@page "/events/{EventId:long}/schedules/{ScheduleId:long}/edit"
@page "/events/{EventId:long}/review"
@page "/events/{EventId:long}/schedules/{ScheduleId:long}/review"

@using Odasoft.XBOL.Auth
@attribute [RequireAnyPermission(AdminPermissions.Events.Read, AdminPermissions.Events.ReadCurrent, AdminPermissions.Events.Create, AdminPermissions.Events.Update)]

@using Microsoft.Net.Http.Headers
@using Microsoft.Extensions.Options
@using Odasoft.XBOL.AdminPortal.Extensions
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.AdminPortal.ViewModels.Event
@using Odasoft.XBOL.AdminPortal.Validators
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.Business.Services
@using Odasoft.XBOL.Business.ModelValidators
@using Odasoft.XBOL.Common.Options
@using Radzen.Blazor
@using SixLabors.ImageSharp
@using FluentValidation;

@inject CatalogsService CatalogsService;
@inject IEventService EventService;
@inject OrganizersService OrganizersService;
@inject VenuesService VenuesService
@inject VenueMapsService VenueMapsService;
@inject EventScheduleService ScheduleService;
@inject MediaService MediaService;
@inject AdditionalChargesService AdditionalChargesService;
@inject AppLocalizer<EventEdit> L
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LoadingState LoadingState;
@inject IJSRuntime JS;
@inject ILogger<EventEdit> Logger;
@inject PriceReferenceService PriceReferenceService;
@inject AdminMediaUrlResolver MediaUrlResolver
@inject IOptions<Odasoft.XBOL.Common.Options.LocalizationOptions> LocalizationOptions

<style>
    .mud-stepper .mud-stepper-content {
        padding-left:0;
        padding-right: 8px;
    }

    .mud-stepper-nav .mud-step:first-of-type{
        padding-left:0;
    }
    .mud-stepper-nav .mud-step:last-of-type{
        padding-right:8px;
    }
</style>

<PageTitle>@_pageTitle</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="MudBlazor.Color.Secondary"
                       Variant="Variant.Outlined" DropShadow="false" OnClick="@(() => GoBackAsync())">
                @L["GoBack"]
            </MudButton>
        </LeftContent>
        <RightContent>
            @if (_isEdit || _isReview)
            {
                @if (_isReview)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.TaskAlt"
                               Color="MudBlazor.Color.Tertiary"
                               Variant="Variant.Filled"
                               DropShadow="false"
                               Disabled="_loading || _eventStatus != AdminEventStatus.PendingReview"
                               OnClick="OpenReviewDialog">@L["FinishReview"]</MudButton>
                }
                else
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Save"
                               Color="MudBlazor.Color.Tertiary"
                               Variant="Variant.Filled"
                               DropShadow="false"
                               OnClick="PublishAsync"
                               Disabled="_eventStatus != AdminEventStatus.Approved || _loading">@L["Publish"]</MudButton>
                }
            }
        </RightContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer
    IsLoading="_loading"
    HasError="_error"
    ErrorMessage="@L["ErrorLoadingEvent"]"
                  OnRetry="InitializeForm">
    <MudCard Elevation="3">
        <MudCardContent Class="pa-6">
            <MudStack Justify="Justify.SpaceBetween" AlignItems="AlignItems.Stretch" Class="mb-4">
                <MudStack Row>
                    <MudText Typo="Typo.h5">@($"{(_isEdit || _isReview ? EventState.EventInfo.Name : _pageTitle)}")</MudText>
                    @if (!_isReview)
                    {
                        <EventStatusChip Status="_eventStatus"></EventStatusChip>
                    }
                </MudStack>
                @if (_isReview)
                {
                    <MudAlert Severity="MudBlazor.Severity.Warning"
                        Class="bg-primary-lighten text-secondary w-100"
                        Dense
                        NoIcon
                    >@L["ReviewDescription"]</MudAlert>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">@L["RequiredFieldsNote"]</MudText>
                }
            </MudStack>

            <MudStepper @ref="_stepper" ActiveIndex="_activeIndex" OnPreviewInteraction="OnPreviewInteraction" ActiveIndexChanged="HandleStepNavigation" NonLinear Class="pa-0"
            CompletedStepColor="MudBlazor.Color.Tertiary">
                <ChildContent>
                    <MudStep
                        Title="@L["DescriptionAndVenue"]"
                        HasError="!_descriptionFormValid"
                        @bind-Completed="_descriptionFormCompleted">
                        <MudForm
                            @ref="_descriptionForm"
                            @bind-IsValid="_descriptionFormValid"
                            Model="EventState.EventInfo"
                            Validation="@(_eventInfoValidator.ValidateValue)"
                            @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="7">
                                <MudItem xs="12">
                                    <AdminSelect Label="@(L["Organizer"].Value)"
                                               @bind-Value="EventState.EventInfo.OrganizerId"
                                               Disabled="@_isReview"
                                                 For="@(() => EventState.EventInfo.OrganizerId)">

                                        @foreach (var organizer in _organizers)
                                        {
                                            <MudSelectItem T="long?" Value="organizer.Id">
                                                @organizer.Name
                                            </MudSelectItem>
                                        }
                                    </AdminSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="EventState.EventInfo.Name"
                                                            Class="required"
                                                            Label="@L["Name"].Value"
                                                            For="@(() => EventState.EventInfo.Name)"
                                                            Disabled="@_isReview" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="EventState.EventInfo.Subtitle"
                                                            Label="@L["Subtitle"].Value"
                                                            For="@(() => EventState.EventInfo.Subtitle)"
                                                            Disabled="@_isReview" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudSelect Label="@L["EventType"]"
                                                       T="AdminEventCategoryResult"
                                                       MultiSelection="true"
                                                       @bind-SelectedValues="EventState.EventInfo.SelectedCategories"
                                                       Validation="@(new Func<IEnumerable<AdminEventCategoryResult>, Task<IEnumerable<string>>>(ValidateCategories))"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       ToStringFunc="@(c => c?.DisplayName ?? "")"
                                                       Disabled="@_isReview"
                                                       Class="required">

                                                @foreach (var category in _eventCategories)
                                                {
                                                    <MudSelectItem T="AdminEventCategoryResult" Value="category">
                                                        @category.DisplayName
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <AdminTextField @bind-Value="EventState.EventInfo.ShortDescription"
                                                            Label="@L["EventSummary"].Value"
                                                            For="@(() => EventState.EventInfo.ShortDescription)"
                                                            Lines="@(3)"
                                                            Disabled="@_isReview" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudStack>
                                                <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
                                    ;">@L["EventDescription"]</MudText>
                                                @* TODO: Create and use component *@
                                                <MudPaper Outlined="true" Class="pa-0">
                                                    <RadzenHtmlEditor
                                                        @bind-Value="EventState.EventInfo.LongDescription" Style="min-height: 300px; width: 100%;"
                                                          Disabled="@_isReview">
                                                        <RadzenHtmlEditorUndo Title="Deshacer" />
                                                        <RadzenHtmlEditorRedo Title="Rehacer" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorBold Title="Negrita" />
                                                        <RadzenHtmlEditorItalic Title="Cursiva" />
                                                        <RadzenHtmlEditorUnderline Title="Subrayado" />
                                                        <RadzenHtmlEditorStrikeThrough Title="Tachado" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorAlignLeft Title="Alinear a la izquierda" />
                                                        <RadzenHtmlEditorAlignCenter Title="Centrar" />
                                                        <RadzenHtmlEditorAlignRight Title="Alinear a la derecha" />
                                                        <RadzenHtmlEditorJustify Title="Justificar" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorUnorderedList Title="Lista de viñetas" />
                                                        <RadzenHtmlEditorOrderedList Title="Lista numerada" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorColor Title="Color del texto" />
                                                        <RadzenHtmlEditorBackground Title="Color de fondo" />
                                                        <RadzenHtmlEditorRemoveFormat Title="Quitar formato" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorSubscript Title="Subíndice" />
                                                        <RadzenHtmlEditorSuperscript Title="Superíndice" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorLink Title="Insertar enlace" />
                                                        <RadzenHtmlEditorUnlink Title="Quitar enlace" />
                                                        <RadzenHtmlEditorImage Title="Insertar imagen" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorFontName Title="Fuente" Placeholder="Fuente" />
                                                        <RadzenHtmlEditorFontSize Title="Tamaño" Placeholder="Tamaño" />
                                                        <RadzenHtmlEditorFormatBlock Title="Formato" Placeholder="Párrafo" />
                                                        <RadzenHtmlEditorSeparator />
                                                        <RadzenHtmlEditorSource Title="Ver código HTML" />
                                                    </RadzenHtmlEditor>
                                                </MudPaper>
                                            </MudStack>
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueResponse?"
                                                         Class="required"
                                                         Value="EventState.EventInfo.SelectedVenue"
                                                         ValueChanged="OnVenueSelected"
                                                         For="@(() => EventState.EventInfo.SelectedVenue)"
                                                         Label="@L["Venue"].Value"
                                                         Disabled="@_isReview">
                                                @foreach (var venue in _venues)
                                                {
                                                    <MudSelectItem T="VenueResponse?" Value="@venue">@venue.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <AdminSelect T="VenueMapResponse?"
                                                         Class="required"
                                                         Value="EventState.EventInfo.SelectedVenueMap"
                                                         ValueChanged="OnVenueMapSelected"
                                                         For="@(() => EventState.EventInfo.SelectedVenueMap)"
                                                         Label="@L["Map"].Value"
                                                         Disabled="@_isReview">
                                                @foreach (var map in _venueMaps)
                                                {
                                                    <MudSelectItem T="VenueMapResponse?" Value="@map">@map.Name</MudSelectItem>
                                                }
                                            </AdminSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueAddress"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Label="@L["Address"].Value"
                                                          Disabled="@true" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_venueCoordinates"
                                                          Label="@L["Coordinates"].Value"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Disabled="@true" />
                                        </MudItem>
                                        @if (EventState.EventInfo.SelectedVenueMap is not null)
                                        {
                                            <MudItem xs="12" Class="d-flex justify-center">
                                                <MudImage Src="@EventState.EventInfo.SelectedVenueMap.ThumbnailUrl" Alt="@EventState.EventInfo.SelectedVenueMap.Name" Class="rounded-lg" Height="400" />
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                    <MudStep
                        Title="@L["ZonePrices"]"
                        HasError="!_pricesValid"
                        @bind-Completed="_pricesCompleted">
                        <MudForm
                            @ref="_pricesForm"
                            @bind-IsValid="_pricesValid"
                            Model="EventState.PricesInfo"
                            Validation="@(_pricesValidator.ValidateValue)"
                            @onkeydown="OnKeyDownAsync">
                            <MudTable
                                Items="EventState.PricesInfo.Prices"
                                GroupBy="_groupDefinition"
                                Elevation="0"
                                FixedHeader
                                Class="event-price-editor-table">
                                <ToolBarContent>
                                    <MudText Typo="Typo.h5">@L["Zones"]</MudText>
                                    <MudSpacer />
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        @if (!_isReview)
                                        {
                                            <MudButton StartIcon="@Icons.Material.Filled.FileDownload" OnClick="@(() => DownloadCsvAsync())" Color="MudBlazor.Color.Secondary" Variant="Variant.Filled">@L["DownloadTemplate"]</MudButton>
                                            <MudButton StartIcon="@Icons.Material.Filled.FileUpload" Color="MudBlazor.Color.Secondary" Variant="Variant.Filled" OnClick="OpenPriceImportDialog">@L["ImportPrices"]</MudButton>
                                            <MudButton StartIcon="@Icons.Material.Outlined.Add" Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="OpenAddDialog">@L["AlternativePrice"]</MudButton>
                                        }
                                        @* <MudTextField @bind-Value="_searchPrices" Placeholder="@L["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField> *@
                                    </MudStack>
                                </ToolBarContent>
                                <ColGroup>
                                    <col />
                                    <col />
                                    <col />
                                    <col />
                                    <col />
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <col />
                                    }
                                </ColGroup>
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceInfoModel, object>(x => GetZoneName(x.BaseZoneId))">@L["Zone"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceInfoModel, object>(x => GetSectionName(x.BaseSectionId))">@L["Section"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceInfoModel, object>(x => GetSectionName(x.BaseRowId))">@L["Row"]</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<PriceInfoModel, object>(x => GetSectionName(x.BaseSeatId))">@L["Seat"]</MudTableSortLabel></MudTh>
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <MudTh>
                                            @priceType.Key
                                            @if (!priceType.Value)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                               Color="MudBlazor.Color.Secondary"
                                                               Size="MudBlazor.Size.Small"
                                                               OnClick="@(() => OpenEditDialog(priceType.Key))" />
                                            }
                                        </MudTh>
                                    }
                                    <MudTh />
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd Style="vertical-align: top;"></MudTd>
                                    <MudTd Style="vertical-align: top;">
                                        <AdminSelect T="long?"
                                                     Value="@context.BaseSectionId"
                                                     ValueChanged="@((long? newValue) => OnSectionChanged(context, newValue))"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value">
                                            @foreach (var section in GetSectionsFor(context.BaseZoneId))
                                            {
                                                <MudSelectItem T="long?" Value="section.Id">
                                                    @(section.Name)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    <MudTd Style="vertical-align: top;">
                                        <AdminSelect T="long?"
                                                     Value="@context.BaseRowId"
                                                     ValueChanged="@((long? newValue) => OnRowChanged(context, newValue))"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value"
                                                     Clearable="@true">
                                            @foreach (var row in GetRowsFor(context.BaseSectionId))
                                            {
                                                <MudSelectItem T="long?" Value="row.Id">
                                                    @(row.Name)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    <MudTd Style="vertical-align: top;">
                                        <AdminSelect T="long?"
                                                     Value="@context.BaseSeatId"
                                                     ValueChanged="@((long? newValue) => OnSeatChanged(context, newValue))"
                                                     Disabled="@(context.IsZonePrice || _isReview)"
                                                     Placeholder="@L["Select"].Value"
                                                     Clearable="@true">
                                            @foreach (var seat in GetSeatsFor(context.BaseRowId))
                                            {
                                                <MudSelectItem T="long?" Value="seat.Id">
                                                    @(seat.SeatNumber)
                                                </MudSelectItem>
                                            }
                                        </AdminSelect>
                                    </MudTd>
                                    @foreach (var priceType in PriceTypes)
                                    {
                                        <MudTd DataLabel="@priceType.Key" Style="vertical-align: top;">
                                            <MudStack Row AlignItems="AlignItems.Start" Spacing="1" Class="price-cell">
                                                <AdminNumericField T="decimal?"
                                                                   Value="@GetPriceTypeValue(context, priceType.Key)"
                                                                   ValueChanged="@((decimal? newValue) => SetPriceTypeValue(context, priceType.Key, newValue))"
                                                                   Validation="@(new Func<decimal?, Task<IEnumerable<string>>>(val => ValidateSpecificPrice(PriceTypes, priceType.Key, val)))"
                                                                   Clearable="@true"
                                                                   Format="N2"
                                                                   Adornment="@Adornment.Start"
                                                                   AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                                                   Placeholder="0.00"
                                                                   HideSpinButtons="@true"
                                                                   Disabled="@_isReview" />
                                                @if (_canCopyPrices)
                                                {
                                                    <div class="price-copy-action">
                                                        <PriceCopyButton Disabled="@(_isReview || !CanCopyPriceType(context, priceType.Key))"
                                                                         OnClick="@(() => CopyPriceTypeToAll(context, priceType.Key))" />
                                                    </div>
                                                }
                                            </MudStack>
                                        </MudTd>
                                    }
                                    <MudTd>
                                        @if (!_isReview && (context.BaseRowId != null || context.BaseSectionId != null || context.BaseSeatId != null))
                                        {
                                            <MudTooltip Text="@L["Delete"]" Placement="Placement.Top">
                                                <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                Color="MudBlazor.Color.Secondary"
                                                Size="MudBlazor.Size.Medium"
                                                OnClick="@(() => DeletePriceAsync(context))" />
                                            </MudTooltip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                                <GroupHeaderTemplate>
                                    <MudTh colspan="@(4 + PriceTypes.Count)">
                                        <MudText Class="text-primary-darken" Typo="Typo.subtitle2">
                                            @(GetZoneName(long.Parse(context.Key.ToString())))
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        @if (!_isReview)
                                        {
                                            <MudIconButton Color="MudBlazor.Color.Primary"
                                                           Icon="@Icons.Material.Outlined.Add"
                                                           OnClick="@(() => AddPrice(long.Parse(context.Key.ToString())))">@L["AddPrice"]</MudIconButton>
                                        }
                                    </MudTh>
                                </GroupHeaderTemplate>
                            </MudTable>
                        </MudForm>
                    </MudStep>
                    <MudStep Title="@L["AdditionalCharges"]"
                             HasError="!_additionalChargesValid"
                             @bind-Completed="_additionalChargesCompleted">
                        <MudForm @ref="_additionalChargesForm"
                                 @bind-IsValid="_additionalChargesValid"
                                 Model="EventState.AdditionalChargesInfo"
                                 Validation="@(_additionalChargesInfoValidator.ValidateValue)"
                                 @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="6">
                                <MudItem xs="12">
                                    <MudDataGrid @ref="_additionalChargesGrid"
                                        T="AdditionalChargeInfoModel"
                                        Items="@EventState.AdditionalChargesInfo.AdditionalCharges"
                                        CommittedItemChanges="@CommittedItemChanges"
                                        EditMode="DataGridEditMode.Cell"
                                        ReadOnly="_isReview"
                                        Validator="_additionalChargesForm"
                                        Bordered="true"
                                        Dense="true"
                                        Elevation="0">
                                        <ToolBarContent>
                                            <MudText Typo="Typo.h5">@L["AdditionalCharges"]</MudText>
                                            <MudSpacer />
                                            <MudButtonGroup Class="ma-0 pa-0" Color="MudBlazor.Color.Primary" Variant="Variant.Filled">
                                                @if (!_isReview)
                                                {
                                                    <MudButton OnClick="NewAdditionalChargeAsync">
                                                        @L["AddAdditionalCharge"]
                                                    </MudButton>
                                                }
                                            </MudButtonGroup>
                                        </ToolBarContent>
                                        <Columns>
                                            <PropertyColumn Property="x => x.Name" Title="@L["FeeName"]">
                                                <EditTemplate>
                                                    @{
                                                        var item = context.Item;
                                                    }
                                                    <AdminTextField
                                                        @key="item.UiId"
                                                        @bind-Value="item.Name"
                                                                  For="@(() => item.Name)"
                                                                  Validation="@(new Func<string, Task<IEnumerable<string>>>(val => ValidateGridCell(item, nameof(item.Name), val)))"
                                                                    Disabled="@_isReview" />
                                                </EditTemplate>
                                            </PropertyColumn>

                                            <PropertyColumn Property="x => x.FeeType" Title="@L["Type"]">
                                                <EditTemplate>
                                                    @{
                                                        var item = context.Item;
                                                    }
                                                    <MudSelect @key="item.UiId"
                                                               T="FeeType"
                                                               @bind-Value="item.FeeType"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               For="@(() => item.FeeType)"
                                                               ToStringFunc="@(feeType => L[feeType.ToString()].Value)"
                                                               Validation="@(new Func<FeeType, Task<IEnumerable<string>>>(val => ValidateGridCell(item, nameof(item.FeeType), val)))"
                                                               Disabled="@(_isReview)">

                                                        @foreach (var fee in _feeTypes)
                                                        {
                                                            <MudSelectItem T="FeeType" Value="fee">
                                                                @L[fee.ToString()]
                                                            </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </EditTemplate>
                                            </PropertyColumn>

                                            <PropertyColumn Property="x => x.ChargeCategory" Title="@L["ChargeCategory"]">
                                                <EditTemplate>
                                                    @{
                                                        var item = context.Item;
                                                    }
                                                    <MudSelect @key="item.UiId"
                                                               T="ChargeCategory"
                                                               @bind-Value="item.ChargeCategory"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               For="@(() => item.ChargeCategory)"
                                                               ToStringFunc="@(category => L[category.ToString()].Value)"
                                                               Validation="@(new Func<ChargeCategory, Task<IEnumerable<string>>>(val => ValidateGridCell(item, nameof(item.ChargeCategory), val)))"
                                                               Disabled="@(_isReview)">

                                                        @foreach (var category in _chargeCategories)
                                                        {
                                                            <MudSelectItem T="ChargeCategory" Value="category">
                                                                @L[category.ToString()]
                                                            </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </EditTemplate>
                                            </PropertyColumn>

                                            <PropertyColumn Property="x => x.Value" Title="@L["FeeAmount"]">
                                                <EditTemplate>
                                                    @{
                                                        var item = context.Item;
                                                    }
                                                    <AdminNumericField @key="item.UiId"
                                                                    @bind-Value="item.Value"
                                                                     For="@(() => item.Value)"
                                                                       Validation="@(new Func<decimal?, Task<IEnumerable<string>>>(val => ValidateGridCell(item, nameof(item.Value), val)))"
                                                                       HideSpinButtons="@true"
                                                                       Disabled="@_isReview" />
                                                </EditTemplate>
                                            </PropertyColumn>

                                            @if (!_isReview)
                                            {
                                                <TemplateColumn>
                                                    <CellTemplate>
                                                        <MudIconButton Color="MudBlazor.Color.Default" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteAdditionalCharge(context.Item))" />
                                                    </CellTemplate>
                                                    <EditTemplate>
                                                        <MudIconButton Color="MudBlazor.Color.Default" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteAdditionalCharge(context.Item))" />
                                                    </EditTemplate>
                                                </TemplateColumn>
                                            }
                                        </Columns>
                                    </MudDataGrid>
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudStep>
                    <MudStep
                        Title="@L["DatesAndSalePolicies"]"
                        HasError="!_scheduleValid"
                        @bind-Completed="_scheduleCompleted">
                        <MudForm @ref="_scheduleForm"
                            @bind-IsValid="_scheduleValid"
                            Model="EventState.ScheduleInfo"
                            Validation="@(_scheduleValidator.ValidateValue)"
                            @onkeydown="OnKeyDownAsync">
                            <MudGrid Spacing="6">
                                <MudItem xs="12">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Spacing="2">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.subtitle2" Class="text-secondary-darken" Style="font-weight:600
