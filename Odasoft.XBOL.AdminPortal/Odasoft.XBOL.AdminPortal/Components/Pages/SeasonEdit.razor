@page "/seasons/{Id:long}/edit"
@using Odasoft.XBOL.AdminPortal.Services.Contracts
@using Odasoft.XBOL.Business
@inject AppLocalizer<SeasonEdit> L
@inject ISeasonService SeasonService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Secondary"
                    Variant="Variant.Outlined" DropShadow="false" OnClick="@(() => _adminForm.GoBackAsync())">
                @L["ButtonBack"]
            </MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

@if (_loadingFailed)
{
    return;
}

<AdminForm @ref="_adminForm" Title="@L["PageTitle"]" OnSubmit="SaveAsync"
           BackUrl="@($"/seasons/{Id}/events")" ErrorMessage="@L["UpdateError"]">
    @* Row 1: Code, Name, StartDate, EndDate *@
    <MudItem xs="12" lg="2">
        <AdminTextField @bind-Value="_code" Label="@L["Code"].Value"
                        Placeholder="@L["CodePlaceholder"].Value"
                        Field="@context.Field("Code")" Required />
    </MudItem>
    <MudItem xs="12" lg="4">
        <AdminTextField @bind-Value="_name" Label="@L["Name"].Value"
                        Placeholder="@L["NamePlaceholder"].Value"
                        Field="@context.Field("Name")" Required />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_startDate" Label="@L["StartDate"].Value"
                         Field="@context.Field("StartDate")" Required />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_endDate" Label="@L["EndDate"].Value"
                         Field="@context.Field("EndDate")" Required />
    </MudItem>

    @* Row 2: Description *@
    <MudItem xs="12">
        <AdminTextField @bind-Value="_description" Label="@L["Description"].Value"
                        Lines="@(3)" Placeholder="@L["DescriptionPlaceholder"].Value" />
    </MudItem>

    @* Row 3: BannerImageUrl, PosterImageUrl *@
    <MudItem xs="12" lg="6">
        <AdminTextField @bind-Value="_bannerImageUrl" Label="@L["BannerImageUrl"].Value"
                        Placeholder="https://" />
    </MudItem>
    <MudItem xs="12" lg="6">
        <AdminTextField @bind-Value="_posterImageUrl" Label="@L["PosterImageUrl"].Value"
                        Placeholder="https://" />
    </MudItem>

    @* Row 4: LandingUrl *@
    <MudItem xs="12">
        <AdminTextField @bind-Value="_landingUrl" Label="@L["LandingUrl"].Value"
                        Placeholder="https://" />
    </MudItem>

    @* Row 5: PublishedDate, OnSaleDate, PreSaleDate, OffSaleDate *@
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_publishedDate" Label="@L["PublishedDate"].Value" />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_preSaleDate" Label="@L["PreSaleDate"].Value" />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_onSaleDate" Label="@L["OnSaleDate"].Value" />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminDatePicker @bind-Date="_offSaleDate" Label="@L["OffSaleDate"].Value" />
    </MudItem>
</AdminForm>

@code {
    [Parameter] public long Id { get; set; }

    private AdminForm _adminForm = default!;
    private bool _loadingFailed;

    private string? _code;
    private string? _name;
    private string? _description;
    private string? _bannerImageUrl;
    private string? _posterImageUrl;
    private string? _landingUrl;
    private DateTime? _startDate;
    private DateTime? _endDate;
    private DateTime? _publishedDate;
    private DateTime? _onSaleDate;
    private DateTime? _preSaleDate;
    private DateTime? _offSaleDate;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var season = await SeasonService.GetSeasonByIdAsync(Id);

            _code = season.Code;
            _name = season.Name;
            _description = season.Description;
            _bannerImageUrl = season.BannerImageUrl;
            _posterImageUrl = season.PosterImageUrl;
            _landingUrl = season.LandingUrl;
            _startDate = DateTimeHelpers.ToNullableDateTime(season.StartDate);
            _endDate = DateTimeHelpers.ToNullableDateTime(season.EndDate);
            _publishedDate = DateTimeHelpers.ToNullableDateTime(season.PublishedDate);
            _onSaleDate = DateTimeHelpers.ToNullableDateTime(season.OnSaleDate);
            _preSaleDate = DateTimeHelpers.ToNullableDateTime(season.PreSaleDate);
            _offSaleDate = DateTimeHelpers.ToNullableDateTime(season.OffSaleDate);
        }
        catch (Exception)
        {
            _loadingFailed = true;
            Snackbar.Add(L["LoadError"], Severity.Error);
            Navigation.NavigateTo("/seasons");
        }
    }

    private async Task SaveAsync()
    {
        var request = new UpdateSeasonRequest
        {
            Code = _code,
            Name = _name,
            Description = _description,
            BannerImageUrl = _bannerImageUrl,
            PosterImageUrl = _posterImageUrl,
            LandingUrl = _landingUrl,
            StartDate = DateTimeHelpers.ToDateTimeOffset(_startDate),
            EndDate = DateTimeHelpers.ToDateTimeOffset(_endDate),
            PublishedDate = DateTimeHelpers.ToDateTimeOffset(_publishedDate),
            OnSaleDate = DateTimeHelpers.ToDateTimeOffset(_onSaleDate),
            PreSaleDate = DateTimeHelpers.ToDateTimeOffset(_preSaleDate),
            OffSaleDate = DateTimeHelpers.ToDateTimeOffset(_offSaleDate),
        };

        await SeasonService.UpdateSeasonAsync(Id, request);
        Snackbar.Add(L["UpdateSuccess"], Severity.Success);
        Navigation.NavigateTo($"/seasons/{Id}/events");
    }
}
