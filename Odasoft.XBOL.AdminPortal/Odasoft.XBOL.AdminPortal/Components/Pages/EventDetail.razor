@page "/events/{EventId:long}"
@page "/events/{EventId:long}/{Tab}"
@page "/events/{EventId:long}/schedule/{ScheduleId:long}"
@page "/events/{EventId:long}/schedule/{ScheduleId:long}/{Tab}"

@using Odasoft.XBOL.AdminPortal.Components.Pages.EventDetails
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.Extensions
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.Business.Services
@using Odasoft.XBOL.Common.Constants

@inject AppLocalizer<EventDetail> L
@inject IEventService _eventService
@inject NavigationManager _navigationManager
@inject IDialogService _dialogService
@inject ISnackbar _snackbar

<PageTitle>@(_event?.Name ?? "")</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => _navigationManager.NavigateTo("./events"))" Color="Color.Secondary"
                       Variant="Variant.Outlined" Class="text-uppercase">
                @L["GoBack"]
            </MudButton>
        </LeftContent>
        <RightContent>
            <MudStack Row>
                <MudButton StartIcon="@Icons.Material.Outlined.EventBusy" Color="Color.Error" Variant="Variant.Filled"
                           Class="text-uppercase" OnClick="DeleteEventAsync">
                    @L["DeleteItem", L["Event"]]
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.Edit" Href="@($"./events/{EventId}/edit")"
                           Color="Color.Secondary" Variant="Variant.Filled" Class="text-uppercase">
                    @L["Edit"]
                </MudButton>
            </MudStack>
        </RightContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer IsLoading="_loading" HasError="_error" ErrorMessage="@L["ErrorLoading"]" OnRetry="LoadEventAsync">

    @if (_event is not null)
    {
        <ImageHeroBanner Banner="_banner"></ImageHeroBanner>

        <MudToggleGroup T="long" Value="@_selectedSchedule" ValueChanged="OnScheduleChanged" CheckMark="false"
                        Class="border-secondary-lighten mb-4 w-max d-flex" Color="Color.Secondary">
            @foreach (var schedule in _event.Schedules)
            {
                <MudToggleItem Value="@schedule.Id" Text="@schedule.StartDateTime.ToString("MMMM dd h:mm tt")"
                                Class="@($"px-4 {(_selectedSchedule == schedule.Id ? "bg-secondary-darken" : "")}")" />
            }
        </MudToggleGroup>

        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
            <MudToggleGroup T="string" Value="@_selectedTab" ValueChanged="OnTabChanged" CheckMark="false"
                            Class="border-secondary-lighten" Color="Color.Secondary">
                <MudToggleItem Value="@TabSales" Text="@L["TabSales"].Value.ToUpper()"
                Class="@($"px-4 {(_selectedTab == TabSales ? "bg-secondary-darken" : "")}")" />
                <MudToggleItem Value="@TabSuitesSales" Text="@L["TabSuitesSales"].Value.ToUpper()"
                Class="@($"px-4 {(_selectedTab == TabSuitesSales ? "bg-secondary-darken" : "")}")" />
                <MudToggleItem Value="@TabPolicies" Text="@L["TabPolicies"].Value.ToUpper()"
                               Class="@($"px-4 {(_selectedTab == TabPolicies ? "bg-secondary-darken" : "")}")" />
            </MudToggleGroup>
            <MudStack Row Spacing="2">
                <MudButton StartIcon="@Icons.Material.Outlined.LocalActivity"
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Disabled="true">
                    @L["BuySuites"]
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Outlined.ShoppingCart"
                    Variant="Variant.Filled"
                    Color="Color.Primary" 
                    OnClick="@(() => _navigationManager.NavigateTo($"./events/{_event.Id}/key/{_eventSchedule.ExternalEventKey}/booking"))">
                    @L["BuyTickets"]
                </MudButton>
            </MudStack>
        </MudStack>

        @if (ScheduleId is not null)
        {
        @if (_selectedTab == TabSales)
        {
                <EventScheduleSales EventScheduleId="ScheduleId.Value" />
        }
        else if (_selectedTab == TabSuitesSales)
        {
                <EventScheduleSuitesSales EventScheduleId="ScheduleId.Value" />
        }
        else if (_selectedTab == TabPolicies)
        {
                <ScheduleAndPolicies Event="_event" EventSchedule="_eventSchedule" />
            }
        }
    }

</LoadingContainer>

@code {
    [Parameter] public long EventId { get; set; }
    [Parameter] public long? ScheduleId { get; set; }
    [Parameter] public string? Tab { get; set; }

    private const string TabSales = "sales";
    private const string TabSuitesSales = "suites-sales";
    private const string TabPolicies = "policies";

    private string _selectedTab = TabPolicies;
    private long _selectedSchedule;
    private bool _loading = true;
    private bool _error;
    private EventInfoDTO? _event;
    private EventScheduleDTO? _eventSchedule;
    private ImageHeroBannerViewModel _banner = new();

    protected override async Task OnInitializedAsync()
    {

    }

    protected override async Task OnParametersSetAsync()
    {
        _selectedTab = Tab?.ToLowerInvariant() switch
        {
            TabSuitesSales => TabSuitesSales,
            TabPolicies => TabPolicies,
            _ => TabSales
        };

        _selectedSchedule = ScheduleId ?? 0;

        // TODO: Fix loading and reload data if any id is different
        if (_event is null || _eventSchedule is null)
        {
            await LoadEventAsync();
        }        
    }

    private void OnScheduleChanged(long scheduleId)
    {
        _selectedSchedule = scheduleId;
        _navigationManager.NavigateTo($"./events/{EventId}/schedule/{_selectedSchedule}/{_selectedTab}", replace: true);
    }

    private void OnTabChanged(string tab)
    {
        _selectedTab = tab;
        var currentUri = new Uri(_navigationManager.Uri);
        var baseUri = currentUri.GetLeftPart(UriPartial.Path).Substring(0, currentUri.GetLeftPart(UriPartial.Path).LastIndexOf('/'));
        _navigationManager.NavigateTo($"{baseUri}/{tab}", replace: true);
    }

    private async Task LoadEventAsync()
    {
        _loading = true;
        _error = false;

        try
        {
            _event = await _eventService.GetEventByIdAsync(EventId);
            _eventSchedule = _event?.Schedules?.First(x => ScheduleId is null || x.Id == ScheduleId);
            OnScheduleChanged(_eventSchedule?.Id ?? 0);
            var horizontalImages = await _eventService.GetEventImageByTypeAsync(EventId, ImageType.HorizontalPoster);

            var horizontalImage = horizontalImages.FirstOrDefault();

            _banner = new()
            {
                Title = _event.Name,
                Subtitle = _event.Subtitle,
                StartDateTime = _eventSchedule?.StartDateTime.UtcDateTime,
                EndDateTime = _eventSchedule?.EndDateTime?.UtcDateTime,
                ImageUrl = horizontalImage is not null ? $"data:{horizontalImage.ContentType};base64,{horizontalImage.ImageBase64}" : _event.BannerImageUrl,
                Venue = _event.VenueName,
                ExternalKey = _eventSchedule?.ExternalEventKey,
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading event '{EventId}': {ex.Message}");
            _error = true;
            _snackbar.Add(L["ErrorLoading"], Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteEventAsync()
    {
        var confirmed = await _dialogService.ShowConfirmDeleteAsync(
        L["DeleteDialogTitle", _event?.Name ?? ""],
        L["DeleteDialogMessage"]);

        if (!confirmed) return;

        try
        {
            await _eventService.DeleteEventAsync(EventId);
            _snackbar.Add(L["DeleteSuccess"], Severity.Success);
            _navigationManager.NavigateTo("./events");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting event: {ex.Message}");
            _snackbar.Add(L["DeleteError"], Severity.Error);
        }
    }
}
