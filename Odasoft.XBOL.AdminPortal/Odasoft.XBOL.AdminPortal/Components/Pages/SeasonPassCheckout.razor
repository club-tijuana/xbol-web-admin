@page "/xolopass/checkout";
@page "/xolopass/checkout/renovate/{orderReference}";
@page "/xolopass/checkout/{seasonId:long}";

@using Microsoft.Extensions.Options;
@using Odasoft.XBOL.AdminPortal.Components.Shared;
@using Odasoft.XBOL.AdminPortal.Configs;
@using Odasoft.XBOL.AdminPortal.Services.Contracts;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.AdminPortal.ViewModels.Order;
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants
@using Odasoft.XBOL.Common.Helpers

@inject AppLocalizer<SeasonPassCheckout> L
@inject IOptions<SeatsIo> _seatsOptions;
@inject ISeasonService _seasonService;
@inject ISeasonPassService _seasonPassService;
@inject CartState _cartState;
@inject IJSRuntime JSRuntime;
@inject ISnackbar _snackbar;
@inject NavigationManager _navigationManager;
@inject ClientsService _clientService;
@inject CatalogsService _catalogsService;

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => GoToSeasonpassList())" Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">Regresar</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<ImageHeroBanner Banner="_seasonBanner"></ImageHeroBanner>

<MudCard Elevation="3" Class="pa-6">
    <MudGrid Class="align-center pb-3">
        <MudItem xs="12" sm="6" lg="8">
            <MudText Typo="Typo.h5">@L["SubtitleSeats"]</MudText>
        </MudItem>
        <MudItem xs="12" sm="12" md="6" lg="4" Class="justify-content-end d-flex">
            <MudPaper Class="d-flex justify-end flex-grow-1 gap-4" Elevation="0">
                <MudButton EndIcon="@Icons.Material.Filled.NavigateNext" OnClick="@(() => GoToSeasonpassList())" Color="Color.Primary" Variant="Variant.Filled" Class="text-uppercase">Método de pago</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
    <MudGrid>
        <MudItem xs="12" sm="12" md="6" lg="1">
            <MudSelect T="long?"
                       Label="Lada"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Disabled="IsRenovation"
                       @bind-Value="_request.ClientContact.PhoneRegionCodeId"
                       ShrinkLabel
                       Required>

                @foreach (var regionCode in _phoneRegionCodes)
                {
                    <MudSelectItem T="long?" Value="regionCode.Id">
                        @($"+{regionCode.DialCode} {regionCode.RegionCode}")
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="6" lg="2">
            <!-- Teléfono -->
            <MudTextField T="string"
                          Label="Teléfono "
                          Required="true"
                          @bind-Value="_request.ClientContact.PhoneNumber"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          MaxLength="10"
                          OnBlur="SearchOnBlur"
                          Disabled="IsRenovation"
                          InputType="InputType.Telephone"
                          ShrinkLabel />
        </MudItem>
        <MudItem xs="12" sm="12" md="6" lg="3">
            <MudTextField T="string"
                          Label="Correo electrónico " Variant="Variant.Outlined"
                          @bind-Value="_request.ClientContact.Email"
                          Required="true" Margin="Margin.Dense"
                          Disabled="IsRenovation"
                          OnBlur="SearchOnBlur"
                          InputType="InputType.Email"
                          Immediate="true"
                          ShrinkLabel />
        </MudItem>
        <MudItem xs="12" sm="12" md="6" lg="3">
            <MudTextField T="string"
                          @bind-Value="_request.ClientContact.FirstName"
                          Label="Nombre del comprador " Variant="Variant.Outlined"
                          Required="true" Margin="Margin.Dense"
                          Disabled="IsRenovation"
                          Immediate="true"
                          ShrinkLabel />
        </MudItem>
        <MudItem xs="12" sm="12" md="6" lg="3">
            <MudTextField T="string"
                          @bind-Value="_request.ClientContact.LastName"
                          Label="Apellido del comprador " Variant="Variant.Outlined"
                          Required="true" Margin="Margin.Dense"
                          Disabled="IsRenovation"
                          Immediate="true"
                          ShrinkLabel />
        </MudItem>
        <MudItem xs="6">
            @if (_loading)
            {
                <MudProgressCircular Indeterminate Color="Color.Primary" />
            }
            else if (_error)
            {
                <MudAlert Severity="Severity.Error">
                    No se pudo cargar el mapa del evento.
                </MudAlert>
            }
            else if (!string.IsNullOrWhiteSpace(_seasonKey))
            {
                <SeatingChart SecretKey="@_secretKey"
                              EventKey="@_seasonKey"
                              EventId="SeasonId"
                              Prices="_prices"
                              SelectedSeats="SelectedSeats"
                              OnChartRendered="HandleChartReadyAsync" />
            }
        </MudItem>
        <MudItem xs="6">
            <div class="d-flex flex-column">
                <OrderSummary AllowRemoval="false"></OrderSummary>
                @if (_showValidationError)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                        Completa todos los datos del comprador y selecciona al menos un asiento.
                    </MudAlert>
                }
                <MudButton Variant="Variant.Filled"
                           DropShadow="false"
                           StartIcon="@Icons.Material.Outlined.Save"
                           Color="Color.Tertiary"
                           Disabled="_isSubmitting"
                           @onclick="Submit">
                    @(_isSubmitting ? "Procesando..." : "Comprar")
                </MudButton>
            </div>
        </MudItem>
    </MudGrid>
</MudCard>

@code {
    [Parameter]
    public string? orderReference { get; set; }

    [Parameter]
    public long SeasonId { get; set; }

    [Parameter]
    public List<string> SelectedSeats { get; set; } = [];

    private string _secretKey = string.Empty;
    private string? _seasonKey = string.Empty;
    private List<SeatsIoPriceDTO> _prices = new();
    private bool _loading = true;
    private bool _error = false;
    private ClientFilter clientFilter = new();
    private ClientSeasonEvent _clientSeasonEvent = new();
    private SeasonBookingRequest _request = new();
    private ImageHeroBannerViewModel _seasonBanner = new();
    private bool IsRenovation => !string.IsNullOrEmpty(orderReference);
    private List<SeatInfo> _selectedSeats { get; set; } = [];
    private bool _showValidationError = false;
    private bool _isSubmitting = false;
    private List<PhoneRegionCodeResponse> _phoneRegionCodes = [];

    protected override async Task OnInitializedAsync()
    {
        _phoneRegionCodes = await _catalogsService.GetPhoneRegionCodesAsync();

        _cartState.OnChange += async () =>
        {
            await InvokeAsync(StateHasChanged);
        };

        _cartState.SetEvent(SeasonId);
        await LoadSeasonData();
    }

    private async Task SearchOnBlur(FocusEventArgs args)
    {
        if (_request.ClientContact.PhoneRegionCodeId.HasValue == false
            && string.IsNullOrWhiteSpace(_request.ClientContact.PhoneNumber)
            && string.IsNullOrWhiteSpace(_request.ClientContact.Email))
        {
            return;
        }

        try
        {
            var result = await _seasonPassService.GetClientSeasonEventInfo(clientFilter);

            if (result is null)
            {
                return;
            }

            if (IsRenovation)
            {
                if (result.AlreadyRenewed is true)
                {
                    _snackbar.Add("El cliente ya cuenta con una renovación.", Severity.Warning);
                    _navigationManager.NavigateTo("/xolopass");
                }
                if (result.CanRenovate is false)
                {
                    _snackbar.Add("El cliente ya no puede renovar.", Severity.Warning);
                    _navigationManager.NavigateTo("/xolopass");
                }
            }

            _request.ClientContact.FirstName = result.ClientContact?.Name ?? "";
            _request.ClientContact.LastName = result.ClientContact?.LastName ?? "";
            _request.ClientContact.FullName = $"{result.ClientContact?.Name} {result.ClientContact?.LastName}".Trim();
            _request.ClientContact.Email = result.ClientContact?.Email ?? "";

        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == StatusCodes.Status404NotFound)
            {
                await SearchForClientAsync();
            }
        }
        catch (Exception ex)
        {
            // TODO: need to handle api responses
            Console.WriteLine($"Client not found. Error {ex.Message}");
        }
    }

    private void GoToSeasonpassList()
    {
        _navigationManager.NavigateTo("/xolopass");
    }

    private async Task LoadSeasonData()
    {
        _loading = true;
        _error = false;

        try
        {
            _secretKey = _seatsOptions.Value.SecretKey;

            if (IsRenovation)
            {
                _clientSeasonEvent = await _seasonPassService.GetClientSeasonEventByOrderReference(orderReference!);
                if (_clientSeasonEvent != null)
                {
                    _request.SeasonKey = _clientSeasonEvent.SeasonKey ?? "";
                    _request.ClientContact = new ClientInfoRequest
                    {
                        PhoneRegionCodeId = _clientSeasonEvent.ClientContact?.PhoneRegionCodeId,
                        PhoneNumber = _clientSeasonEvent.ClientContact?.PhoneNumber ?? "",
                        Email = _clientSeasonEvent.ClientContact?.Email ?? "",
                        FirstName = _clientSeasonEvent.ClientContact?.Name ?? "",
                        LastName = _clientSeasonEvent.ClientContact?.LastName ?? "",
                        FullName = $"{_clientSeasonEvent.ClientContact?.Name} {_clientSeasonEvent.ClientContact?.LastName}".Trim(),
                        Id = _clientSeasonEvent.ClientContact?.Id
                    };

                    _seasonKey = _request.SeasonKey;
                    _selectedSeats = _clientSeasonEvent.Seats.Select(x => new SeatInfo
                    {
                        SeatId = x.SeatId ?? "",
                        Price = (decimal)x.Price,
                        Category = x.Category
                    }).ToList();

                    if (_clientSeasonEvent.SeasonId is null)
                    {
                        _snackbar.Add("Datos de temporada no válidos. Se requiere el ID de temporada.", Severity.Error);
                        _navigationManager.NavigateTo("/xolopass");
                    }
                    else
                    {

                        SeasonId = _clientSeasonEvent.SeasonId.Value;
                        SelectedSeats = _selectedSeats.Select(x => x.SeatId).ToList();
                        _cartState.SelectedSeats = _selectedSeats;

                        var season = await _seasonService.GetSeasonByIdAsync(SeasonId);
                        _prices = season.Prices?.ToList() ?? new();
                        _seasonBanner = await _seasonService.GetSeasonBannerAsync(SeasonId);

                        if (_clientSeasonEvent.AlreadyRenewed is true)
                        {
                            _snackbar.Add("El cliente ya cuenta con una renovación.", Severity.Warning);
                            _navigationManager.NavigateTo("/xolopass");
                        }

                        if (_clientSeasonEvent.CanRenovate is false)
                        {
                            _snackbar.Add("El cliente ya no puede renovar.", Severity.Warning);
                            _navigationManager.NavigateTo("/xolopass");
                        }
                    }
                }
            }
            else
            {
                var season = await _seasonService.GetSeasonByIdAsync(SeasonId);
                _seasonKey = season.ExternalSeasonKey ?? string.Empty;
                _prices = season.Prices?.ToList() ?? new();
                _seasonBanner = await _seasonService.GetSeasonBannerAsync(SeasonId);
            }
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Submit()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        _showValidationError = false;

        try
        {
            if (_request.ClientContact.PhoneRegionCodeId.HasValue == false
                || string.IsNullOrWhiteSpace(_request.ClientContact.PhoneNumber)
                || string.IsNullOrWhiteSpace(_request.ClientContact.Email)
                || string.IsNullOrWhiteSpace(_request.ClientContact.FirstName)
                || string.IsNullOrWhiteSpace(_request.ClientContact.LastName)
                || _cartState.SelectedSeats is null
                || _cartState.SelectedSeats.Count == 0)
            {
                _showValidationError = true;
                _snackbar.Add("Faltan datos para continuar con la compra.", Severity.Warning);
                return;
            }

            _request.Seats = _cartState.SelectedSeats.ToDictionary(x => x.SeatId, x => x.Price);
            _request.SeasonKey = _seasonKey ?? "";
            _request.HoldToken = _cartState.HoldToken ?? "";

            BookingResult result = await _seasonPassService.BookSeasonAsync(_request);

            _snackbar.Add("Xolopass pagado con exito.", configure: c =>
            {
                c.SnackbarVariant = Variant.Text;
                c.Icon = Icons.Custom.Uncategorized.AlertSuccess;
                c.IconColor = Color.Success;
            });

            _navigationManager.NavigateTo("/xolopass");
        }
        catch (Exception)
        {
            _snackbar.Add("Hubo un error, intenta mas tarde", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task HandleChartReadyAsync()
    {
        if (SelectedSeats.Count > 0)
        {
            _cartState.SelectedSeats = _selectedSeats;
        }

        StateHasChanged();
    }

    private async Task SearchForClientAsync()
    {
        try
        {
            ClientContactResponse? client = await _clientService.SearchClientAsync(
                                                    _request.ClientContact.PhoneRegionCodeId,
                                                    _request.ClientContact.PhoneNumber ?? "",
                                                    _request.ClientContact.Email ?? "");

            if (client is not null)
            {
                _request.ClientContact.Id = client.Id;
                _request.ClientContact.FirstName = client.Name ?? "";
                _request.ClientContact.LastName = client.LastName ?? "";
                _request.ClientContact.Email = client.Email ?? "";
                _request.ClientContact.FullName = $"{client.Name} {client.LastName}".Trim();
                _request.ClientContact.PhoneRegionCodeId = client.PhoneRegionCodeId;
                _request.ClientContact.PhoneNumber = client.PhoneNumber ?? "";
            }
        }
        catch (ApiException ex)
        {
            // If the client is not found, we don't want to show an error, we just want to clear the form
            if (ex.StatusCode != StatusCodes.Status404NotFound)
            {
                Console.WriteLine($"Unexpected error searching for client: {ex.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Unexpected error searching for client: {ex.Message}");
        }
    }

    public void Dispose()
    {
        _cartState.OnChange -= StateHasChanged;
    }
}
