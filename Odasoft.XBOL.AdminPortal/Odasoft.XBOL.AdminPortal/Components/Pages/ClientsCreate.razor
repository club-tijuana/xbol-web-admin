@page "/clients/create"

@using Odasoft.XBOL.AdminPortal.Components.Shared;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants;
@using Odasoft.XBOL.Common.Helpers
@using Odasoft.XBOL.Models.ViewModels;
@using System.ComponentModel.DataAnnotations:

@inject ClientsService _clientService;
@inject CatalogsService _catalogsService;
@inject NavigationManager _navigationManager;
@inject LoadingState LoadingState;
@inject AppLocalizer<ClientsCreate> L;
@inject IDialogService _dialogService;
@inject ISnackbar _snackbar;

<PageTitle>Nueva Empresa</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => GoToClientsListAsync())"
                       Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">@L["GoBack"]</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer IsLoading="@_isLoading">
<MudPaper Elevation="3" Class="pa-6">
    <EditForm FormName="ClientCreate" Model="@model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
        <MudGrid Spacing="8">
            <MudItem xs="12">
                <MudStack Spacing="0">
                        <MudText Typo="Typo.h5">@L["NewBusiness"]</MudText>
                        <MudText Typo="Typo.caption">@L["RequiredFieldsNote"]</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.CompanyName"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["Business"]"
                    Required
                    RequiredError="El nombre de la empresa es obligatorio.">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.SocialReason"
                    For="@(() => model.SocialReason)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["CompanyName"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.Rfc"
                    For="@(() => model.Rfc)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["CompanyTaxId"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                    <MudSelect T="ClientType?" Label="@L["ClientType"]"
                           Margin="Margin.Dense" Variant="Variant.Outlined"
                           @bind-Value="model.PersonTypeId"
                           For="@(() => model.PersonTypeId)"
                           Clearable>
                    @foreach (var clientType in _clientTypes)
                    {
                        <MudSelectItem T="ClientType?" Value="@clientType">
                                <MudText>@L[clientType.ToString()]</MudText>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2">Dirección y contacto</MudText>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.City"
                    For="@(() => model.City)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["Country"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.State"
                    For="@(() => model.State)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["State"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.Street"
                    For="@(() => model.Street)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["Street"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudGrid Spacing="8">
                    <MudItem xs="12" md="6">
                        <MudTextField
                            @bind-Value="model.ExtNumber"
                            For="@(() => model.ExtNumber)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["Number"]">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField
                            @bind-Value="model.IntNumber"
                            For="@(() => model.IntNumber)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["InteriorNumber"]">
                        </MudTextField>
                    </MudItem>
                </MudGrid>
            </MudItem>
            <MudItem xs="12" lg="6">
                <MudGrid Spacing="8">
                    <MudItem xs="12" md="6" lg="3">
                        <MudTextField
                            @bind-Value="model.PostalCode"
                            For="@(() => model.PostalCode)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["PostalCode"]">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField
                            @bind-Value="model.Neighborhood"
                            For="@(() => model.Neighborhood)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["Neighborhood"]">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6" lg="3">
                        <MudTextField
                            @bind-Value="model.City"
                            For="@(() => model.City)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["City"]">
                        </MudTextField>
                    </MudItem>
                </MudGrid>
            </MudItem>
            <MudItem xs="12" lg="6">
                <MudGrid Spacing="8">
                    <MudItem xs="12" md="6" lg="3">
                        <MudSelect 
                            Label="@L["AreaCode"]"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            @bind-Value="model.PhoneRegionCodeId"
                                       For="@(() => model.PhoneRegionCodeId)"
                            Clearable>
                                @foreach (var regionCode in _phoneRegionCodes)
                                {
                                    <MudSelectItem T="long?" Value="regionCode.Id">
                                        <MudImage Src="@FlagHelper.GetFlagImageUrl(regionCode.RegionCode ?? "")" Height="15" Elevation="1" ObjectFit="ObjectFit.Fill" /> @($"+{regionCode.DialCode}")
                                    </MudSelectItem>
                                }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6" lg="3">
                        <MudTextField
                            @bind-Value="model.PhoneNumber"
                            For="@(() => model.PhoneNumber)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["Phone"]"
                            InputType="InputType.Telephone">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField
                            @bind-Value="model.Email"
                            For="@(() => model.Email)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Label="@L["Email"]"
                        InputType="InputType.Email">
                        </MudTextField>
                    </MudItem>
                </MudGrid>
            </MudItem>
            <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2">@L["LegalRepresentative"]</MudText>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.LegalRep.Name"
                    For="@(() => model.LegalRep.Name)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["FullName"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudDatePicker Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Date="LegalRepDOB"
                               For="@(() => LegalRepDOB)"
                               Label="@L["DateOfBirth"]"
                               Mask="@(new DateMask("dd/MM/yyyy"))"
                               DateFormat="dd/MM/yyyy"
                               Clearable />
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.LegalRep.Rfc"
                    For="@(() => model.LegalRep.Rfc)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["TaxId"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <MudTextField
                    @bind-Value="model.LegalRep.Curp"
                    For="@(() => model.LegalRep.Curp)"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Label="@L["SSN"]">
                </MudTextField>
            </MudItem>
            <MudItem xs="12">
                    <MudSwitch @bind-Value="CreditEnabled" Color="Color.Primary" UncheckedColor="Color.Secondary">@L["Credit"]</MudSwitch>
            </MudItem>
            <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2">@L["CreditInfo"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField
                    @bind-Value="model.Credit.AuthorizedAmount"
                    For="@(() => model.Credit.AuthorizedAmount)"
                    Variant="Variant.Outlined"
                    Adornment="Adornment.Start"
                    AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                    Margin="Margin.Dense"
                    Label="@L["AuthorizedAmount"]"
                    Placeholder="0.00"
                    Disabled="!CreditEnabled"
                    Immediate="false" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Date="CreditStartDate"
                               For="@(() => CreditStartDate)"
                               Label="@L["StartDate"]"
                               Mask="@(new DateMask("dd/MM/yyyy"))"
                               DateFormat="dd/MM/yyyy"
                               Disabled="!CreditEnabled"
                               Clearable />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect
                    T="PaymentFrequency?"
                    Label="@L["PaymentTerm"]"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    @bind-Value="model.Credit.PaymentCycleTypeId"
                    For="@(() => model.Credit.PaymentCycleTypeId)"
                    Disabled="!CreditEnabled"
                    Clearable>
                    @foreach (var paymentFrequency in _paymentFrequencies)
                    {
                        <MudSelectItem T="PaymentFrequency?" Value="@paymentFrequency">
                            <MudText>@L[paymentFrequency.ToString()]</MudText>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                    <MudSelect Label="@L["InterestApply"]"
                            Margin="Margin.Dense"
                            @bind-Value="model.Credit.InterestApply"
                            For="@(() => model.Credit.InterestApply)"
                            Variant="Variant.Outlined"
                            Disabled="!CreditEnabled"
                            Clearable>
                    <MudSelectItem Value="(bool?)true">Si</MudSelectItem>
                    <MudSelectItem Value="(bool?)false">No</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField @bind-Value="model.Credit.TotalPlusInterest"
                              For="@(() => model.Credit.TotalPlusInterest)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                              Margin="Margin.Dense"
                              Label="@L["TotalPlusInterest"]"
                              Placeholder="0.00"
                              Disabled="!CreditEnabled"
                              Immediate="false" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField @bind-Value="model.Credit.TermInDays"
                              For="@(() => model.Credit.TermInDays)"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Label="@L["TermInDays"]"
                              Disabled="!CreditEnabled"
                              Immediate="false" />
            </MudItem>
            <MudItem xs="12">
                <MudPaper Class="d-flex justify-end" Elevation="0">
                    <MudButton
                        StartIcon="@Icons.Material.Outlined.Save"
                        Variant="Variant.Filled"
                        Color="Color.Tertiary"
                        ButtonType="ButtonType.Submit">
                            @L["Save"]
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>
</LoadingContainer>

@code {
    private CreateClientRequest model = new();

    private bool _isLoading = false;
    private bool _isSubmitting = false;
    private bool _createdSuccesfully = false;

    private bool _creditEnabled = false;

    public bool CreditEnabled
    {
        get
        {
            return _creditEnabled;
        }
        set
        {
            _creditEnabled = value;
            model.HasCredit = value;
            if (!value)
            {
                ResetCredit();
            }
            StateHasChanged();
        }
    }

    private void ResetCredit()
    {
        model.Credit = new();
        CreditStartDate = null;
    }

    private DateTime? CreditStartDate { get; set; }
    private DateTime? LegalRepDOB { get; set; }

    private List<ClientType> _clientTypes = Enum.GetValues<ClientType>().ToList();
    private List<PaymentFrequency> _paymentFrequencies = Enum.GetValues<PaymentFrequency>().ToList();
    private List<PhoneRegionCodeResponse> _phoneRegionCodes = [];

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        _phoneRegionCodes = await _catalogsService.GetPhoneRegionCodesAsync();

        model.LegalRep = new();
        model.Credit = new();

        _isLoading = false;
    }

    private async Task GoToClientsListAsync()
    {
        bool exit = await ConfirmExit();

        if (exit)
        {
            _navigationManager.NavigateTo(SitePages.CLIENTS_LIST);
        }
    }

    private async Task<bool> ConfirmExit()
    {
        var options = new DialogOptions { CloseButton = true, NoHeader = true };
        var parameters = new DialogParameters<ConfirmDialog>();

        parameters.Add(dialog => dialog.Message, "Los cambios no guardados se perderan. ¿Desea continuar?");

        var dialog = await _dialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        return result is not null && !result.Canceled;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        LoadingState.Show();
        try
        {
            model.LegalRep.Birthday = LegalRepDOB;
            model.Credit.StartDate = CreditStartDate.HasValue ? CreditStartDate.Value : default;

            var result = await _clientService.CreateClientAsync(model);

            _snackbar.Add(L["CreateSuccess", L["Client"]], Severity.Success);
            _navigationManager.NavigateTo(SitePages.CLIENTS_LIST);
        }
        catch (Exception)
        {
            _snackbar.Add(L["CreateError", L["Client"]], Severity.Error);
    }
        finally
        {
            _isSubmitting = false;
            LoadingState.Hide();
        }
    }
}
