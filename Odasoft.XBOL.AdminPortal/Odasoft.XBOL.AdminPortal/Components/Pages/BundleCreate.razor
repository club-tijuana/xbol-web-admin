    private async Task SaveBundleMediaAsync(long bundleId)
    {
        await UploadBundleMediaItemAsync(bundleId, _bannerImage, AdminMediaType.Banner, 0);
        foreach (var (index, image) in _galleryImages.Index())
        {
            await UploadBundleMediaItemAsync(bundleId, image, AdminMediaType.Gallery, index);
        }
    }

    private async Task UploadBundleMediaItemAsync(
        long bundleId,
        ImageModel? image,
        AdminMediaType mediaType,
        int order)
    {
        if (image?.FileBytes is not { Length: > 0 })
        {
            return;
        }

        using var stream = new MemoryStream(image.FileBytes);
        var file = new FileParameter(stream, image.Name, image.ContentType);
        await MediaService.UploadMediaAsync(bundleId, AdminSaleType.Bundle, mediaType, order, file);
    }

    private ImageModel? ToImageModel(MediaResponse? media, AdminMediaType mediaType, int order = 0)
    {
        if (media is null || !media.Id.HasValue)
        {
            return null;
        }

        return new ImageModel
        {
            Id = media.Id,
            Name = GetMediaName(media),
            ContentType = media.ContentType ?? string.Empty,
            Src = MediaUrlResolver.Resolve(media.Url) ?? string.Empty,
            Order = media.Order ?? order,
            MediaType = mediaType
        };
    }

    private static string GetMediaName(MediaResponse media)
        => !string.IsNullOrWhiteSpace(media.FileName)
            ? media.FileName
            : media.Title ?? string.Empty;

    private bool ValidatePriceScopes()
    {
        var duplicateScope = _prices
            .GroupBy(PriceScopeKey)
            .FirstOrDefault(group => group.Count() > 1);
        if (duplicateScope is null)
        {
            return true;
        }

        Snackbar.Add(L["DuplicatePrices"], MudBlazor.Severity.Warning);
        return false;
    }

    private static string PriceScopeKey(PriceForm price)
    {
        return string.Join(
            ":",
            price.BaseZoneId ?? 0,
            price.BaseSectionId ?? 0,
            price.BaseRowId ?? 0,
            price.BaseSeatId ?? 0);
    }

    private bool ValidateSelectedEvents(bool showWarning = true)
    {
        if (_selectedEventsByScheduleId.Count == 0)
        {
            return true;
        }

        if (_bundleType == BundleType.SeasonPass)
        {
            var published = _selectedEventsByScheduleId.Values
                .FirstOrDefault(e => !string.IsNullOrWhiteSpace(e.ExternalEventKey));

            if (published is not null)
            {
                if (showWarning)
                {
                    Snackbar.Add(L["EventAlreadyPublished"], MudBlazor.Severity.Warning);
                }

                return false;
            }
        }

        return true;
    }

