    private async Task AddImageAsync(IBrowserFile? file, AdminMediaType mediaType)
    {
        if (file is null)
        {
            return;
        }

        var image = await ReadImageAsync(file, mediaType);
        if (image is null)
        {
            return;
        }

        switch (mediaType)
        {
            case AdminMediaType.Banner:
                _bannerImage = image;
                await _bannerImageUpload.ClearAsync();
                break;
        }
    }

    private async Task DeleteBannerImageAsync()
    {
        _bannerImage = null;
        await _bannerImageUpload.ClearAsync();
    }

    private async Task UploadGalleryImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        if (files.Count == 0)
        {
            return;
        }

        foreach (var file in files)
        {
            var image = await ReadImageAsync(file, AdminMediaType.Gallery);
            if (image is not null)
            {
                _galleryImages.Add(image);
            }
        }

        if (_galleryUpload is not null)
        {
            await _galleryUpload.ClearAsync();
        }

        if (_carousel is not null && _galleryImages.Count > 0)
        {
            _carousel.MoveTo(_galleryImages.Count - 1);
        }
    }

    private async Task<ImageModel?> ReadImageAsync(IBrowserFile file, AdminMediaType mediaType)
    {
        if (file.Size > MaxImageFileSize)
        {
            Snackbar.Add(L["FileTooLarge", file.Name, MaxImageFileSize / 1024 / 1024], MudBlazor.Severity.Error);
            return null;
        }

        using var stream = file.OpenReadStream(MaxImageFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        try
        {
            memoryStream.Position = 0;
            var imageInfo = await SixLabors.ImageSharp.Image.IdentifyAsync(memoryStream);
            if (imageInfo is null)
            {
                Snackbar.Add(L["InvalidImage", file.Name], MudBlazor.Severity.Error);
                return null;
            }

            var fileBytes = memoryStream.ToArray();
            var contentType = string.IsNullOrWhiteSpace(file.ContentType)
                ? "application/octet-stream"
                : file.ContentType;

            return new ImageModel
            {
                Name = file.Name,
                FileBytes = fileBytes,
                ContentType = contentType,
                Src = $"data:{contentType};base64,{Convert.ToBase64String(fileBytes)}",
                MediaType = mediaType
            };
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Rejected invalid bundle image file {FileName}", file.Name);
            Snackbar.Add(L["InvalidImage", file.Name], MudBlazor.Severity.Error);
            return null;
        }
    }

    private async Task RemoveGalleryImageAsync(ImageModel image)
    {
        _galleryImages.Remove(image);
        await Task.Delay(1);

        if (_carousel is not null && _galleryImages.Count > 0)
        {
            _carousel.MoveTo(Math.Max(_galleryImages.Count - 1, 0));
        }
    }

    private async Task CleanGalleryImagesAsync()
    {
        _galleryImages.Clear();
        await Task.Delay(1);

        if (_carousel is not null)
        {
            _carousel.MoveTo(0);
        }
    }

