    private async Task<IEnumerable<string>> ValidateGridCell<TValue>(AdditionalChargeInfoModel item, string propertyName, TValue newValue)
    {
        var propertyInfo = typeof(AdditionalChargeInfoModel).GetProperty(propertyName);
        if (propertyInfo == null) return Array.Empty<string>();

        var originalValue = propertyInfo.GetValue(item);
        propertyInfo.SetValue(item, newValue);

        var context = ValidationContext<AdditionalChargeInfoModel>.CreateWithOptions(item, x => x.IncludeProperties(propertyName));
        var result = await _additionalChargeInfoValidator.ValidateAsync(context);

        propertyInfo.SetValue(item, originalValue);

        if (!result.IsValid)
        {
            return result.Errors.Select(x => x.ErrorMessage);
        }

        return Array.Empty<string>();
    }

