    private static BundleType ParseBundleType(string? value)
    {
        return value?.ToLowerInvariant() switch
        {
            "season-pass" or "seasonpass" or "passes" => BundleType.SeasonPass,
            "basic" or "package" or "packages" => BundleType.Basic,
            _ => BundleType.Basic
        };
    }

