@page "/events/{Id:long}/key/{ExternalKey}/booking"
@page "/season-pass/{Id:long}/key/{ExternalKey}/booking"
@page "/events/{Id:long}/key/{ExternalKey}/checkout"
@page "/season-pass/{Id:long}/key/{ExternalKey}/checkout"
@using Odasoft.XBOL.Auth
@attribute [RequirePermission(AdminPermissions.Orders.Create)]
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.Services
@using Odasoft.XBOL.AdminPortal.States
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.Business
@using Microsoft.AspNetCore.WebUtilities

@inject ILogger<Booking> Logger
@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@inject CartState CartState
@inject IJSRuntime JS
@inject ISnackbar _snackbar
@inject AppLocalizer<Events> L

<PageTitle>@_eventName</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"
                       Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">@L["GoBack"]</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer
    IsLoading="_loading"
    HasError="_error"
    ErrorMessage="@L["ErrorLoadingEvent"]"
    OnRetry="LoadData">
    <ImageHeroBanner Banner="_banner"></ImageHeroBanner>

    @if (_conflictedSeats.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Outlined">
            @if (_renewalPrefill is not null)
            {
                <MudText Typo="Typo.subtitle2">@L["Seats_UnavailableRenewalSeats_Title"]</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@L["Seats_UnavailableRenewalSeats_Subtitle"]</MudText>
                <ul class="pl-4">
                    @foreach (var seat in _conflictedSeats)
                    {
                        <li><MudText Typo="Typo.body2">@seat.DisplayLabel</MudText></li>
                    }
                </ul>
            }
            else
            {
                <MudText Typo="Typo.body2">
                    @string.Format(L["Seats_ConflictedSeats"], string.Join(", ", _conflictedSeats.Select(c => c.SeatId)))
                </MudText>
            }
        </MudAlert>
    }

    @if (_keepBookingMounted || _step == 1)
    {
        <div class="@(_step == 1 ? "" : "d-none")">
            <BookingPanel EventId="@Id"
                          ExternalKey="@ExternalKey"
                          Prices="@_detail?.Prices"
                          PreselectedSeats="@_preselectedSeats"
                          IsRenewal="@_preserveRenewalSeats"
                          OnSeatsHeld="GoToCheckoutStep" />
        </div>
    }
    @if (_hasReachedCheckoutStep)
    {
        <div class="@(_step == 2 ? "" : "d-none")">
            <CheckoutPanel EventId="@Id"
                           ExternalKey="@ExternalKey"
                           ItemType="@_itemType"
                           BundleId="@BookingBundleId"
                           ReferenceOrderId="@_renewalPrefill?.RelatedOrderId"
                           Prefill="@_renewalPrefill?.ClientContact"
                           IsRenewal="@(_renewalPrefill is not null)"
                           PreserveRenewalSeats="@_preserveRenewalSeats"
                           ReleaseDate="@_releaseDate"
                           OnRequiresSeats="GoToBookingStep"
                           OnReturnToChart="GoToBookingStep"
                           OnBookingSucceeded="HandleSucceeded"
                           OnBookingFailed="HandleFailed"
                           OnSeatsConflicted="HandleSeatsConflicted" />
        </div>
    }
</LoadingContainer>

    @code {
    [Parameter]
    public long Id { get; set; }

    [Parameter]
    public string ExternalKey { get; set; } = default!;

    private ImageHeroBannerViewModel _banner = new();
    private string _eventName = string.Empty;
    private bool _loading = true;
    private bool _error = false;

    private SeatManagementDetailDTO? _detail;
    private List<string> _preselectedSeats = [];
    private ItemType _itemType = ItemType.Ticket;

    private string _successUrl = "./events";
    private int _step = 1;
    private bool _hasReachedCheckoutStep;
    private bool _keepBookingMounted;

    private SeasonRenewalPrefill? _renewalPrefill;
    private DateTimeOffset? _releaseDate;
    private List<ConflictedSeat> _conflictedSeats = [];
    private bool _preserveRenewalSeats;
    private bool _renewalRequiresSeatSelection;
    private bool _canOverrideSaleWindow;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is not null)
        {
            var authState = await AuthenticationStateTask;
            _canOverrideSaleWindow = AdminPermissionScopes.HasPermission(authState.User, AdminPermissions.Orders.OverrideSaleWindow);
        }

        _successUrl = Navigation.Uri.Contains("/season-pass/")
            ? $"./season-pass/{Id}"
            : "./events";

        var uri = new Uri(Navigation.Uri);
        var path = uri.AbsolutePath.TrimEnd('/');
        var queryDict = QueryHelpers.ParseQuery(uri.Query);
        var hasRenewalReference = queryDict.TryGetValue("renewal", out var renewalRef)
                                  && !string.IsNullOrWhiteSpace(renewalRef);

        if (!await EnsureSeasonPassBookingAllowedAsync(hasRenewalReference))
        {
            return;
        }

        if (hasRenewalReference)
        {
            await LoadRenewalPrefillAsync(renewalRef!, _preserveRenewalSeats);

            if (_renewalPrefill is null)
            {
                return;
            }

            if (_renewalRequiresSeatSelection && path.EndsWith("/checkout", StringComparison.OrdinalIgnoreCase))
            {
                var reference = Uri.EscapeDataString(renewalRef.ToString());
                Navigation.NavigateTo($"./season-pass/{Id}/key/{ExternalKey}/booking?renewal={reference}", replace: true);
                _loading = false;
                return;
            }
        }

        // In-circuit /checkout deep-link: when CartState already carries
        // selected seats from a fresh BookingPanel hold (or the renewal
        // prefill above), start at step 2. A cold tab landing on /checkout
        // with no prefill and no held seats falls back to step 1.
        if (path.EndsWith("/checkout") && CartState.SelectedSeats.Count > 0)
        {
            _step = 2;
            _hasReachedCheckoutStep = true;
        }

        if (_preselectedSeats.Count == 0)
        {
            _preselectedSeats = ParseSeatsFromQuery(uri);
        }

        await LoadData();
    }

    private async Task<bool> EnsureSeasonPassBookingAllowedAsync(bool hasRenewalReference)
    {
        if (!Navigation.Uri.Contains("/season-pass/", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        try
        {
            var bundle = await AdminClient.GetBundleByIdAsync(Id);
            var externalKeyMatches = string.Equals(bundle.ExternalKey, ExternalKey, StringComparison.Ordinal)
                || bundle.Schedules?.Any(schedule => string.Equals(schedule.ExternalEventKey, ExternalKey, StringComparison.Ordinal)) == true;
            var now = DateTimeOffset.UtcNow;
            var protectedRenewalOpen = SeasonPassPurchaseWindow.IsRenewalOpen(
                bundle.OnSaleDate,
                bundle.OffSaleDate,
                bundle.RenewalStartDate,
                bundle.RenewalEndDate,
                bundle.IsBookable == true,
                now);

            _preserveRenewalSeats = hasRenewalReference && protectedRenewalOpen;
            _renewalRequiresSeatSelection = hasRenewalReference
                && SeasonPassPurchaseWindow.RequiresSeatSelectionForRenewal(bundle.RenewalEndDate, now);

            var isAllowed = externalKeyMatches
                && bundle.IsBookable == true
                && (hasRenewalReference
                    ? SeasonPassPurchaseWindow.CanRenew(
                        bundle.OnSaleDate,
                        bundle.OffSaleDate,
                        bundle.RenewalStartDate,
                        bundle.RenewalEndDate,
                        bundle.IsBookable == true,
                        now)
                    : SeasonPassPurchaseWindow.CanBuy(
                        bundle.OnSaleDate,
                        bundle.OffSaleDate,
                        bundle.PreviousBundleId.HasValue,
                        bundle.RenewalEndDate,
                        bundle.IsBookable == true,
                        now,
                        _canOverrideSaleWindow));

            if (isAllowed)
            {
                return true;
            }

            _snackbar.Add(L["ActionDisabledNotOnSale"], Severity.Warning);
            Navigation.NavigateTo($"./season-pass/{Id}", replace: true);
            _loading = false;
            return false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to validate season pass bundle {BundleId} booking access", Id);
            _snackbar.Add(L["ErrorLoadingEvent"], Severity.Error);
            Navigation.NavigateTo("./season-pass", replace: true);
            _loading = false;
            return false;
        }
    }

    private async Task LoadRenewalPrefillAsync(string orderReference, bool preserveSeats)
    {
        try
        {
            if (Navigation.Uri.Contains("/season-pass/", StringComparison.OrdinalIgnoreCase))
            {
                if (await TryLoadBundleRenewalPrefillAsync(orderReference, preserveSeats))
                {
                    return;
                }

                _snackbar.Add(L["RenewalNotPendingWarning"], Severity.Warning);
                Navigation.NavigateTo("./season-pass");
                return;
            }

            var info = await AdminClient.GetOrderRenawalInfoByReferenceAsync(orderReference);
            _renewalPrefill = ProjectRenewalPrefill(info);

            if (!_renewalPrefill.PendingRenewal)
            {
                _snackbar.Add(L["RenewalNotPendingWarning"], Severity.Warning);
                Navigation.NavigateTo("./season-pass");
                return;
            }

            if (preserveSeats)
            {
                ApplyRenewalSeatsToCart(_renewalPrefill);
            }

            if (info.CurrentSeasonId is long seasonId)
            {
                try
                {
                    var season = await AdminClient.GetSeasonByIdAsync(seasonId);
                    _releaseDate = season.OnSaleDate;
                }
                catch (Exception seasonEx)
                {
                    Logger.LogWarning(seasonEx, "Failed to load season {SeasonId} for release date", seasonId);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load renewal prefill for {Reference}", orderReference);
            _snackbar.Add(L["RenewalLoadError"], Severity.Error);
            Navigation.NavigateTo("./season-pass");
        }
    }

    private async Task<bool> TryLoadBundleRenewalPrefillAsync(string orderReference, bool preserveSeats)
    {
        SaleResponse? sale;
        try
        {
            var page = await AdminClient.GetSalesAsync(
                AdminSaleType.Bundle,
                Id,
                true,
                null,
                null,
                Array.Empty<PaymentType>(),
                Array.Empty<SaleChannel>(),
                Array.Empty<OrderStatus>(),
                orderReference,
                nameof(SaleResponse.OrderReference),
                true,
                0,
                10);

            sale = page.Items?
                .FirstOrDefault(item => string.Equals(item.OrderReference, orderReference, StringComparison.OrdinalIgnoreCase));
        }
        catch (ApiException ex) when (ex.StatusCode is StatusCodes.Status400BadRequest or StatusCodes.Status404NotFound)
        {
            return false;
        }

        if (sale is null)
        {
            return false;
        }

        _renewalPrefill = ProjectBundleRenewalPrefill(sale);

        if (!_renewalPrefill.PendingRenewal)
        {
            _snackbar.Add(L["RenewalNotPendingWarning"], Severity.Warning);
            Navigation.NavigateTo("./season-pass");
            return true;
        }

        if (preserveSeats)
        {
            ApplyRenewalSeatsToCart(_renewalPrefill);
        }

        _releaseDate = sale.RenewalStartDate ?? sale.RenewalOnSaleDate;
        return true;
    }

    private void ApplyRenewalSeatsToCart(SeasonRenewalPrefill prefill)
    {
        CartState.SetEvent(Id);
        CartState.SelectedSeats = [.. prefill.Seats];

        _preselectedSeats = prefill.Seats
            .Select(s => s.SeatId)
            .ToList();
    }

    private static SeasonRenewalPrefill ProjectRenewalPrefill(OrderRenewalInfoResponse info)
    {
        var contact = new CheckoutPrefill(
            ClientId: info.ClientId,
            PhoneRegionCodeId: info.PhoneRegionCodeId,
            PhoneNumber: info.PhoneNumber,
            Email: info.Email,
            FullName: info.ClientName,
            City: info.City,
            Neighborhood: info.Neighbourhood,
            Gender: ConvertGender(info.Gender),
            Birthday: info.Dob?.DateTime);

        var seats = (info.Items ?? [])
            .Where(item => item.IsCancelled != true && !string.IsNullOrWhiteSpace(item.SeatObjectKey))
            .Select(item => new SeatInfo
            {
                SeatId = item.SeatObjectKey!,
                Price = item.RenewalPrice ?? item.Price ?? 0,
                Category = item.Zone,
                IsSelected = true,
                IsSold = item.IsSold ?? false,
                SourceOrderItemId = item.Id,
                PriceListItemId = item.PriceListItemId ?? 0
            })
            .ToList();

        return new SeasonRenewalPrefill(
            RelatedOrderId: info.OrderId,
            PendingRenewal: info.PendingRenewal ?? false,
            ClientContact: contact,
            Seats: seats);
    }

    private static SeasonRenewalPrefill ProjectBundleRenewalPrefill(SaleResponse sale)
    {
        var contact = new CheckoutPrefill(
            ClientId: sale.ClientId,
            PhoneRegionCodeId: sale.BuyerPhoneRegionCodeId,
            PhoneNumber: sale.BuyerPhoneNumber,
            Email: sale.PurchaseEmail,
            FullName: sale.BuyerName,
            City: sale.BuyerCity,
            Neighborhood: sale.BuyerNeighbourhood,
            Gender: null,
            Birthday: null);

        var seats = (sale.Items ?? [])
            .Where(item => item.IsRenewed != true && !string.IsNullOrWhiteSpace(item.TrackingCode))
            .Select(item => new SeatInfo
            {
                SeatId = item.TrackingCode!,
                Price = item.RenewalPrice ?? item.Price ?? 0,
                Category = GetSeatCategory(item),
                IsSelected = true,
                IsSold = item.IsRenewed ?? false,
                SourceOrderItemId = item.ItemId,
                PriceListItemId = item.PriceListItemId ?? 0
            })
            .ToList();

        return new SeasonRenewalPrefill(
            RelatedOrderId: sale.OrderId,
            PendingRenewal: sale.CanRenew == true
                && sale.AlreadyRenewed != true
                && (sale.RenewalRequiresSeatSelection == true || seats.Count > 0),
            ClientContact: contact,
            Seats: seats);
    }

    private static string? GetSeatCategory(SaleDetailResponse item)
    {
        var label = string.Join(" ", new[] { item.Zone, item.Section }
            .Where(part => !string.IsNullOrWhiteSpace(part)));

        return string.IsNullOrWhiteSpace(label) ? null : label;
    }

    private static ClientGender? ConvertGender(Gender? gender) => gender switch
    {
        Business.Gender.Male => ClientGender.Male,
        Business.Gender.Female => ClientGender.Female,
        _ => null,
    };

    private async Task LoadData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _detail = await AdminClient.GetSeatManagementDetailAsync(ExternalKey);
            _eventName = _detail.Name;
            _itemType = BookingBundleId is not null
                ? ItemType.BundlePass
                : _detail.Type switch
            {
                BookableUnitType.Bundle => ItemType.BundlePass,
                BookableUnitType.Season => ItemType.SeasonPass,
                _ => ItemType.Ticket
            };

            _banner = new()
            {
                Title = _detail.Name,
                Subtitle = _detail.Subtitle,
                StartDateTime = _detail.StartDate.UtcDateTime,
                EndDateTime = _detail.EndDate?.UtcDateTime,
                ImageUrl = _detail.BannerImageUrl,
                Venue = _detail.VenueName,
                ExternalKey = ExternalKey,
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading seat management data");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private long? BookingBundleId =>
        _detail?.Type == BookableUnitType.Bundle ||
        (_detail?.Type == BookableUnitType.Schedule &&
         Navigation.Uri.Contains("/season-pass/", StringComparison.OrdinalIgnoreCase))
            ? Id
            : null;

    private bool IsSeasonPassRoute =>
        Navigation.Uri.Contains("/season-pass/", StringComparison.OrdinalIgnoreCase);

    private void GoToCheckoutStep(HoldToken _)
    {
        _step = 2;
        _hasReachedCheckoutStep = true;
    }

    private void GoToBookingStep()
    {
        _step = 1;
        // Once we re-mount the chart in session="manual" with an active hold,
        // keep BookingPanel alive across subsequent step toggles so the chart
        // and hold-expiration timer don't re-init each round-trip. Stays
        // unmount-on-step-2 only for the first transition (session="none"),
        // where unmount is required to avoid the WebSocket-vs-own-hold race.
        if (!string.IsNullOrEmpty(CartState.HoldToken))
        {
            _keepBookingMounted = true;
        }
    }

    private void HandleSucceeded((BookingResult result, bool isPaymentLink) data)
    {
        if (data.isPaymentLink)
        {
            _successUrl = $"./support/{data.result.Localizer}";
            Navigation.NavigateTo(_successUrl);
        }
        else 
        {
            Navigation.NavigateTo(_successUrl);
        }
    }

    private void HandleFailed(Exception _) => _step = 1;

    private void HandleSeatsConflicted(List<ConflictedSeat> conflicts)
    {
        _conflictedSeats = conflicts ?? [];
    }

    private static List<string> ParseSeatsFromQuery(Uri uri)
    {
        var queryDict = QueryHelpers.ParseQuery(uri.Query);
        if (queryDict.TryGetValue("seats", out var seatsValue) && !string.IsNullOrWhiteSpace(seatsValue))
        {
            return seatsValue.ToString()
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }
        return [];
    }

    private async Task GoBack()
    {
        if (_step == 2)
        {
            if (IsSeasonPassRoute)
            {
                Navigation.NavigateTo($"./season-pass/{Id}");
                return;
            }

            GoToBookingStep();
            return;
        }
        await JS.InvokeVoidAsync("history.back");
    }
}
