@page "/events/{Id:long}/key/{ExternalKey}/booking"
@page "/xolopass/{Id:long}/key/{ExternalKey}/booking"
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Microsoft.Extensions.Options
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.AdminPortal.States
@using Microsoft.AspNetCore.WebUtilities

@implements IDisposable
@inject CartState CartState
@inject ISnackbar Snackbar
@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@inject IOptions<SeatsIoOptions> SeatsOptions
@inject IJSRuntime JS
@inject AppLocalizer<Events> L

<PageTitle>@_eventName</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"
                        Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">@L["GoBack"]</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer
    IsLoading="_loading"
    HasError="_error"
    ErrorMessage="@L["ErrorLoadingEvent"]"
    OnRetry="LoadData">
    <ImageHeroBanner Banner="_banner"></ImageHeroBanner>
    <MudPaper Class="pa-6" Elevation="3">
        <MudGrid Justify="Justify.SpaceBetween">
            <MudItem xs="12" Class="d-flex justify-space-between">
                <MudText Typo="Typo.h5">@L["Seats"]</MudText>
                <MudButton Variant="Variant.Filled"
                            DropShadow="false"
                            EndIcon="@Icons.Material.Filled.NavigateNext"
                            Color="Color.Primary"
                            Disabled="@(CartState.IsHoldCallsInProgress || CartState.SelectedSeats.Count == 0)"
                            @onclick="GoToCheckout">
                    @(_holdProcessing? L["Seats_HoldProcessing"] : L["PaymentMethod"])
                </MudButton>
            </MudItem>
            <MudItem xs="7">
                <SeatingChart @ref="_seatingChart" SecretKey="@_secretKey" EventKey="@ExternalKey" EventId="Id" Prices="_detail?.Prices" SelectedSeats="@GetInitialSelectedSeats()" />
            </MudItem>
            <MudItem xs="4" Class="mt-8">
                <OrderSummary Chart="_seatingChart" />
            </MudItem>
        </MudGrid>
    </MudPaper>
</LoadingContainer>

@code {
    [Parameter]
    public long Id { get; set; }

    [Parameter]
    public string ExternalKey { get; set; } = default!;

    private SeatingChart? _seatingChart;
    private ImageHeroBannerViewModel _banner = new();
    private string _secretKey = string.Empty;
    private string _eventName = string.Empty;
    private bool _loading = true;
    private bool _holdProcessing => CartState.IsHoldCallsInProgress;
    private bool _error = false;

    private SeatManagementDetailDTO? _detail;
    private List<string> _preselectedSeats = [];

    protected override async Task OnInitializedAsync()
    {
        _preselectedSeats = ParseSeatsFromQuery();
        CartState.OnChange += StateHasChanged;
        CartState.ClearCart();
        CartState.SetEvent(Id);
        CartState.ClearTokenAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _detail = await AdminClient.GetSeatManagementDetailAsync(ExternalKey);
            _eventName = _detail.Name;
            _secretKey = SeatsOptions.Value.SecretKey;

            _banner = new()
            {
                Title = _detail.Name,
                Subtitle = _detail.Subtitle,
                StartDateTime = _detail.StartDate.UtcDateTime,
                EndDateTime = _detail.EndDate?.UtcDateTime,
                ImageUrl = _detail.BannerImageUrl,
                Venue = _detail.VenueName,
                ExternalKey = ExternalKey,
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading seat management data: {ex.Message}");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task GoToCheckout()
    {
        try
        {
            var holdToken = await AdminClient.HoldSeatsByKeyAsync(ExternalKey, new HoldSeatsBody
            {
                Seats = CartState.SelectedSeats.Select(x => x.SeatId).ToList()
            });

            CartState.SetHoldToken(holdToken.Token, holdToken.ExpiresAt.GetValueOrDefault());

            var basePath = Navigation.Uri.Contains("/xolopass/") ? "xolopass" : "events";
            Navigation.NavigateTo($"./{basePath}/{Id}/key/{ExternalKey}/booking/{holdToken.Token}/checkout");
        }
        catch (Exception)
        {
            Snackbar.Add(L["ErrorBookingTickets"], MudBlazor.Severity.Error);
        }
    }

    private List<string> ParseSeatsFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryDict = QueryHelpers.ParseQuery(uri.Query);
        if (queryDict.TryGetValue("seats", out var seatsValue) && !string.IsNullOrWhiteSpace(seatsValue))
        {
            return seatsValue.ToString()
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }
        return [];
    }

    private List<string> GetInitialSelectedSeats() =>
        _preselectedSeats.Count > 0 ? _preselectedSeats : CartState.SelectedSeatsKeys;

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }
}
