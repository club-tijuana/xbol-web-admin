@page "/events/{Id:long}/availability"
@using Odasoft.XBOL.AdminPortal.Components.Shared
@using Odasoft.XBOL.AdminPortal.Configs
@using Microsoft.Extensions.Options
@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.AdminPortal.States

@inject IAdminClient AdminClient
@inject NavigationManager Navigation
@inject IOptions<SeatsIo> SeatsOptions
@inject AppLocalizer<Events> L

<PageTitle>@L["Availability"] - @_eventName</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/events"))"
                       Color="Color.Secondary" Variant="Variant.Outlined" Class="text-uppercase">@L["GoBack"]</MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<LoadingContainer IsLoading="_loading" HasError="_error" ErrorMessage="@L["ErrorLoadingEvent"]"
                  OnRetry="LoadEventData">
    <ImageHeroBanner Banner="_banner"></ImageHeroBanner>
    <MudPaper Class="pa-6" Elevation="3">
        <MudGrid Justify="Justify.SpaceBetween">
            <MudItem xs="12" Class="d-flex justify-space-between mb-4">
                <MudText Typo="Typo.h5">@L["Availability"]</MudText>
            </MudItem>
            <MudItem xs="7">
                <EventManagerChart @ref="_chartComponent" SecretKey="@_secretKey" EventKey="@_eventKey" EventId="Id"
                                   Mode="manageForSaleConfig" OnSeatSelected="HandleSeatSelected"
                                   OnSeatDeselected="HandleSeatDeselected" />
            </MudItem>
            <MudItem xs="4" Class="mt-8">
                <SeatList @ref="_seatsList" Items="_selectedSeats" Chart="_chartComponent" Title="@L["Selected"]"
                          OnClearAll="RemoveAllSelectionAsync">
                    <RowActionContent Context="item">
                        <SeatListActions Tooltip="@L["RemoveSelection"]" OnRemove="@(() => RemoveSelectionAsync(item.SeatId))" />
                    </RowActionContent>
                </SeatList>
            </MudItem>
        </MudGrid>
    </MudPaper>
</LoadingContainer>

@code {
    [Parameter]
    public long Id { get; set; }

    private ImageHeroBannerViewModel _banner = new();
    private string _secretKey = string.Empty;
    private string _eventKey = string.Empty;
    private string _eventName = string.Empty;
    private bool _loading = true;
    private bool _error = false;
    private EventInfoDTO? _eventInfo;

    private EventManagerChart? _chartComponent;
    private SeatList? _seatsList;
    private List<SeatInfo> _selectedSeats = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadEventData();
    }

    private void HandleSeatSelected(SeatInfo seat)
    {
        _selectedSeats.Add(seat);
        StateHasChanged();
    }

    private void HandleSeatDeselected(string seatId)
    {
        _selectedSeats.RemoveAll(s => s.SeatId == seatId);
        StateHasChanged();
    }

    private async Task RemoveSelectionAsync(string objectId)
    {
        _seatsList?.ClearFocus();

        if (_chartComponent is not null)
            await _chartComponent.DeselectSeatAsync(objectId);
    }

    private async Task RemoveAllSelectionAsync()
    {
        _seatsList?.ClearFocus();

        if (_chartComponent is not null)
            await _chartComponent.ClearSelection();
    }

    private async Task LoadEventData()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _eventInfo = await AdminClient.GetEventByIdAsync(Id);
            _eventName = _eventInfo.Name ?? string.Empty;
            _eventKey = _eventInfo.ExternalEventKey ?? string.Empty;
            _secretKey = SeatsOptions.Value.SecretKey;

            _banner = new()
            {
                Title = _eventInfo.Name,
                Subtitle = _eventInfo.Subtitle,
                StartDateTime = _eventInfo.ScheduledStartDate?.UtcDateTime,
                EndDateTime = _eventInfo.ScheduledEndDate?.UtcDateTime,
                ImageUrl = _eventInfo.BannerImageUrl,
                Venue = _eventInfo.VenueName,
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading event data: {ex.Message}");
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
