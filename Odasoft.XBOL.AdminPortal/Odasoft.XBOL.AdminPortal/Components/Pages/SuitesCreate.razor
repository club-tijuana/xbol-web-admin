@page "/suites/create"
@using Odasoft.XBOL.Business.Services.Contracts
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.Business.Services
@using Odasoft.XBOL.Common.Constants
@inject AppLocalizer<SuitesCreate> L
@inject ISuitesService SuitesService
@inject CatalogsService CatalogsService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Secondary"
                    Variant="Variant.Outlined" DropShadow="false" OnClick="@(() => _adminForm.GoBackAsync())">
                @L["ButtonBack"]
            </MudButton>
        </LeftContent>
    </PageActionBar>
</SectionContent>

<AdminForm @ref="_adminForm" Title="@L["PageTitle"]" OnSubmit="SaveAsync"
           BackUrl="@SitePages.SUITES_SETTINGS" ErrorMessage="@L["CreateError"]">
    <MudItem xs="12" lg="3">
        <AdminSelect @bind-Value="_suiteLevelId" Label="@L["Level"].Value"
                     Field="@context.Field("SuiteLevelId")" Required>
            @foreach (var level in _suiteLevels)
            {
                <MudSelectItem Value="@level.Id">@level.Name</MudSelectItem>
            }
        </AdminSelect>
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminTextField @bind-Value="_name" Label="@L["Name"].Value"
                        Placeholder="@L["NamePlaceholder"].Value"
                        Field="@context.Field("Name")" Required />
    </MudItem>
    <MudItem xs="12" lg="3">
        <AdminNumericField @bind-Value="_seats" Label="@L["Seats"].Value"
                           Field="@context.Field("Seats")" Required />
    </MudItem>
</AdminForm>

@code {
    private AdminForm _adminForm = default!;

    private long _suiteLevelId;
    private string? _name;
    private int _seats;

    private ICollection<ListItem> _suiteLevels = [];

    protected override async Task OnInitializedAsync()
    {
        _suiteLevels = await CatalogsService.GetSuiteLevelsAsync();
        _suiteLevelId = _suiteLevels.Any() ? _suiteLevels.First().Id : default;
    }

    private async Task SaveAsync()
    {
        var request = new CreateSuiteRequest
        {
            SuiteLevelId = _suiteLevelId,
            Name = _name,
            Seats = _seats
        };

        await SuitesService.CreateSuiteAsync(request);
        Snackbar.Add(L["CreateSuccess"], Severity.Success);
        Navigation.NavigateTo(SitePages.SUITES_SETTINGS);
    }
}
