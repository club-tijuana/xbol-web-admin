@using Microsoft.Extensions.Options
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.AdminPortal.Helpers
@using Odasoft.XBOL.Common.Options

@inject AppLocalizer<EventScheduleSales> _localizer;
@inject PaymentLinkService _paymentLinkService;
@inject SalesService _salesService;
@inject ILogger<EventScheduleSales> Logger
@inject IOptions<PaymentLinkOptions> PaymentLinkOptions
@inject IOptions<Odasoft.XBOL.Common.Options.LocalizationOptions> LocalizationOptions

@inject IJSRuntime JSRuntime;
@inject ISnackbar _snackbar;

<MudCard Elevation="3">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="SaleResponse" @ref="_dataGrid" ServerData="ServerReloadAsync" Loading="_loading"
                     Filterable="false" Hover="true" Elevation="0" RowClassFunc="@SelectedRowClassFunc">

            <ToolBarContent>
                <MudGrid Class="align-center pa-4">
                    <MudItem xs="12" sm="6" lg="8">
                        <MudText Typo="Typo.h5" Style="color: #455A64; font-weight: 400;">Ventas</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="4">
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">

                            <MudTextField @bind-Value="_searchTerm"
                                          @bind-Value:after="@(() => _dataGrid.ReloadServerData())"
                                          Placeholder="Buscar"
                                          Adornment="Adornment.Start" Immediate="true" Variant="Variant.Outlined"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          IconSize="Size.Medium" Margin="Margin.Dense" Typo="Typo.body2" Class="flex-grow-1 bg-white"
                                          DebounceInterval="500"
                                          ShrinkLabel />

                            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <ActivatorContent>
                                    <MudIconButton Icon="@Icons.Material.Outlined.FilterAlt" Color="Color.Secondary" OnClick="@context.ToggleAsync" />
                                </ActivatorContent>
                                <ChildContent>
                                    <MudStack Spacing="3" Class="pa-4" Style="width:340px">

                                        <MudDateRangePicker @bind-DateRange="_dateRange" Label="Rango de fecha" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                            PlaceholderStart="DD/MM/AAAA" PlaceholderEnd="DD/MM/AAAA" />

                                        <MudSelect T="PaymentType?" Label="Método de pago" @bind-SelectedValues="_selectedPaymentTypes" Variant="Variant.Outlined"
                                                   Margin="Margin.Dense" MultiSelection="true" ShrinkLabel
                                                   ToStringFunc="@(pt => pt.HasValue ? _localizer[pt.Value.ToString()].Value : "")">
                                            @foreach (var payment in _paymentTypes)
                                            {
                                                <MudSelectItem T="PaymentType?" Value="@payment">
                                                    <MudText Typo="Typo.body2">@_localizer[payment.ToString()]</MudText>
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        <MudSelect T="SaleChannel?" Label="Canal" @bind-SelectedValues="_selectedSaleChannels" Variant="Variant.Outlined"
                                                   Margin="Margin.Dense" MultiSelection="true" ShrinkLabel
                                                   ToStringFunc="@(sc => sc.HasValue ? _localizer[sc.Value.ToString()] : "")">
                                            @foreach (var channel in _saleChannels)
                                            {
                                                <MudSelectItem T="SaleChannel?" Value="@channel">
                                                    <MudText Typo="Typo.body2">@_localizer[channel.ToString()]</MudText>
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        <MudSelect T="OrderStatus?" Label="Estatus" @bind-SelectedValues="_selectedOrderStatuses" Variant="Variant.Outlined"
                                                   Margin="Margin.Dense" MultiSelection="true" ShrinkLabel
                                                   ToStringFunc="@(os => os.HasValue ? _localizer[os.Value.ToString()] : "")">
                                            @foreach (var status in _orderStatuses)
                                            {
                                                <MudSelectItem T="OrderStatus?" Value="@status">
                                                    <MudText Typo="Typo.body2">@_localizer[status.ToString()]</MudText>
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        <MudStack Row Justify="Justify.SpaceBetween" Spacing="2" Class="mt-2">
                                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ClearAll"
                                                       Class="mud-no-activator" OnClick="ClearFiltersAsync" Style="width: 50%;">
                                                Limpiar
                                            </MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                       StartIcon="@Icons.Material.Filled.Search" OnClick="ApplyFiltersAsync" Style="width: 50%;">
                                                Buscar
                                            </MudButton>
                                        </MudStack>
                                    </MudStack>
                                </ChildContent>
                            </MudMenu>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </ToolBarContent>

            <Columns>
                <TemplateColumn Title="Orden" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Style="color: #D48806; font-weight: 600;">@context.Item.OrderReference</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.PurchaseDate" Title="Fecha de compra" Sortable="true">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(context.Item.PurchaseDate.HasValue ? context.Item.PurchaseDate.Value.ToString("dd/MM/yyyy hh:mm tt") : "")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.PurchaseEmail" Title="Correo electrónico" Sortable="false" />

                <PropertyColumn Property="x => x.Quantity" Title="Cantidad" Sortable="false" />

                <TemplateColumn Title="Método de pago" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Style="color: #607D8B;">@(context.Item.PaymentTypes != null ? string.Join(", ", context.Item.PaymentTypes.Select(pt => _localizer[pt.ToString()].Value)) : "")</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Canal" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@_localizer[context.Item.SaleChannel.ToString()]</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Estatus" Sortable="false">
                    <CellTemplate>
                        @if (context.Item.OrderStatus == OrderStatus.Pending)
                        {
                            if (context.Item.ExpirationDate.HasValue)
                            {
                                if (context.Item.ExpirationDate > DateTimeOffset.UtcNow)
                                {
                                    <div class="d-flex flex-column align-start">
                                        <MudChip Size="Size.Small" Style="background-color: #FFF8E1; color: #F78E21; font-weight: 500; border-radius: 12px;">Pendiente</MudChip>
                                        <MudText Typo="Typo.caption" Style="color: #9E9E9E; font-size: 0.7rem; margin-top: 2px;">Exp. @FormatPaymentLinkDate(context.Item.ExpirationDate.Value)</MudText>
                                    </div>
                                }
                                else
                                {
                                    <MudChip Size="Size.Small" Style="background-color: #E94035; color: white; font-weight: 500; border-radius: 12px;">Expirado</MudChip>
                                }
                            }
                        }
                        else if (context.Item.OrderStatus == OrderStatus.Cancelled)
                        {
                            <MudChip Size="Size.Small" Style="background-color: #E1E1E1; font-weight: 500; border-radius: 12px;">Cancelado</MudChip>
                        }
                        else
                        {
                            <MudChip Size="Size.Small" Style="background-color: #00BFA5; color: white; font-weight: 500; border-radius: 12px;">Pagado</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.Total" Title="Importe total" Sortable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Style="color: #607D8B;">
                            @(context.Item.Total.HasValue ? context.Item.Total.Value.ToString("C") : "")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                 <TemplateColumn Sortable="false">
                    <CellTemplate>
                            @if (context.Item.OrderStatus == OrderStatus.Pending
                                && context.Item.PaymentLink != null
                                && context.Item.PaymentLink.ExpirationDate > DateTimeOffset.UtcNow)
                            {
                                <MudIconButton Icon="@Icons.Material.Outlined.Block" Size="Size.Small" Style="color: #757575;" OnClick="@(() => CancelPaymentLinkAsync(context.Item.PaymentLink?.Code))" />

                                <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small" Style="color: #757575;" OnClick="@(() => CopyPaymentLinkAsync(context.Item.PaymentLink?.Link))" />
                            }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Sortable="false">
                    <CellTemplate>
                        <MudStack Row Spacing="0" Justify="Justify.FlexEnd" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@(context.Item.ShowDetails.HasValue && context.Item.ShowDetails.Value ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                           Size="Size.Small"
                                           OnClick="@(() => ToggleDetails(context.Item))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <ChildRowContent>
                @if (context.Item.ShowDetails.HasValue && context.Item.ShowDetails.Value)
                {
                    <div style="background-color: #F8F9FA; padding: 12px 24px; width: 100%;">
                        <MudDataGrid Items="@context.Item.Items" Elevation="0" Style="background-color: transparent;">
                            <Columns>
                                <PropertyColumn Property="x => x.Zone" Title="Zona" HeaderStyle="font-weight: 600;" Sortable="false" />
                                <PropertyColumn Property="x => x.Section" Title="Sección" HeaderStyle="font-weight: 600;" Sortable="false" />
                                <PropertyColumn Property="x => x.Row" Title="Fila" HeaderStyle="font-weight: 600;" Sortable="false" />
                                <PropertyColumn Property="x => x.Seat" Title="Asiento" HeaderStyle="font-weight: 600;" Sortable="false" />
                                <PropertyColumn Property="x => x.Price" Title="Subtotal" HeaderStyle="font-weight: 600;" Sortable="false">
                                    <CellTemplate Context="DetailContext">
                                        @(DetailContext.Item.Price.HasValue ? DetailContext.Item.Price.Value.ToString("C") : "0.00")
                                    </CellTemplate>
                                </PropertyColumn>
                            </Columns>
                        </MudDataGrid>
                    </div>
                }
            </ChildRowContent>

            <PagerContent>
                <MudDataGridPager T="SaleResponse" RowsPerPageString="Mostrar:" InfoFormat="{first_item}-{last_item} de {all_items}" />
            </PagerContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

<style>

    .selected-row {
        background-color: #FFF8E1 !important;
    }

    .mud-table-row.selected-row > td {
        border-bottom: none !important;
    }

    .mud-table-root .mud-table-cell {
        padding-top: 0px !important;
        padding-bottom: 0px !important;
    }

    .mud-table-cell .mud-icon-button {
        padding: 4px !important;
    }
</style>

@code {
    [Parameter] public AdminSaleType SaleType { get; set; }
    [Parameter] public long ReferenceId { get; set; }

    private bool _loading = false;
    private string _searchTerm = "";

    private DateRange? _dateRange;

    private IReadOnlyCollection<PaymentType?> _selectedPaymentTypes = [];
    private List<PaymentType> _paymentTypes = Enum.GetValues<PaymentType>().ToList();

    private IReadOnlyCollection<SaleChannel?> _selectedSaleChannels = [];
    private List<SaleChannel> _saleChannels = Enum.GetValues<SaleChannel>().ToList();

    private IReadOnlyCollection<OrderStatus?> _selectedOrderStatuses = [];
    private List<OrderStatus> _orderStatuses = Enum.GetValues<OrderStatus>().ToList();

    private MudDataGrid<SaleResponse> _dataGrid = default!;

    private async Task<GridData<SaleResponse>> ServerReloadAsync(GridState<SaleResponse> state, CancellationToken token)
    {
        _loading = true;
        try
        {
            var sortDefinition = state.SortDefinitions.FirstOrDefault();

            var result = await _salesService.GetSalesAsync(
                SaleType,
                ReferenceId,
                null,
                _dateRange?.Start,
                _dateRange?.End,
                _selectedPaymentTypes.OfType<PaymentType>(),
                _selectedSaleChannels.OfType<SaleChannel>(),
                _selectedOrderStatuses.OfType<OrderStatus>(),
                _searchTerm,
                sortDefinition?.SortBy ?? "",
                sortDefinition?.Descending ?? false,
                state.Page,
                state.PageSize);

            return new GridData<SaleResponse>
            {
                TotalItems = result.TotalCount,
                Items = result.Items ?? []
            };
        }
        catch (TaskCanceledException)
        {
            return new GridData<SaleResponse> { TotalItems = 0, Items = new List<SaleResponse>() };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching sales");
            _snackbar.Add("Ocurrió un error al cargar las ventas.", Severity.Error);
            return new GridData<SaleResponse> { TotalItems = 0, Items = new List<SaleResponse>() };
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleDetails(SaleResponse item)
    {
        item.ShowDetails = !item.ShowDetails;
    }

    private string SelectedRowClassFunc(SaleResponse item, int rowIndex)
    {
        if (item.ShowDetails.HasValue && item.ShowDetails.Value)
        {
            return "selected-row";
        }

        return "";
    }

    private async Task ClearFiltersAsync()
    {
        _searchTerm = "";
        _selectedPaymentTypes = [];
        _selectedSaleChannels = [];
        _selectedOrderStatuses = [];
        _dateRange = null;

        await _dataGrid.ReloadServerData();
    }

    private async Task ApplyFiltersAsync()
    {
        await _dataGrid.ReloadServerData();
    }

    private async Task CancelPaymentLinkAsync(string? code)
    {
        if (string.IsNullOrWhiteSpace(code) == false)
        {
            await _paymentLinkService.Cancel(code);

            await _dataGrid.ReloadServerData();
        }
    }

    private async Task CopyPaymentLinkAsync(string? paymentLink)
    {
        if (string.IsNullOrWhiteSpace(paymentLink) == false)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", paymentLink);
        }
    }

    private string FormatPaymentLinkDate(DateTimeOffset expiration)
    {
        return PaymentLinkDateTime
            .ToDisplayDateTime(expiration, LocalizationOptions.Value)
            .ToString("dd/MM/yyyy");
    }
}
