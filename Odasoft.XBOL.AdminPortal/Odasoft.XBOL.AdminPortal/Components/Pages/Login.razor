@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Odasoft.XBOL.AdminPortal.Services
@using Odasoft.XBOL.AdminPortal.Services.Contracts
@inject IAuthService AuthService
@inject AntiforgeryStateProvider Antiforgery
@inject BrowserFormPostJsInterop FormPost
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject AppLocalizer<Login> L

<div class="login-page">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="11" sm="8" md="6" lg="4" xl="3">
            <MudPaper Elevation="6" Class="pa-18  align-center">
                <form @onsubmit="LoginAsync" @onsubmit:preventDefault="true">
                    <AntiforgeryToken />

                    <MudTextField @bind-Value="email" Class="pb-6"
                                  Label="@L["Email"]" Variant="Variant.Outlined"
                                  Required="true" Margin="Margin.Dense"
                                  Immediate="true" InputType="InputType.Email"
                                  autocomplete="username" />

                    <MudTextField @bind-Value="password" Class="@PasswordInputClass"
                                  Label="@L["Password"]" Variant="Variant.Outlined" InputType="@passwordInput"
                                  Adornment="Adornment.End" AdornmentIcon="@passwordInputIcon"
                                  OnAdornmentClick="TogglePasswordVisibility" AdornmentAriaLabel="@L["TogglePasswordVisibility"]"
                                  Required="true" Margin="Margin.Dense"
                                  Immediate="true" RequiredError=""
                                  autocomplete="current-password" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-4 text-uppercase"
                               FullWidth="true"
                               ButtonType="ButtonType.Submit"
                               Disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        }
                        @L["SignIn"]
                    </MudButton>
                </form>

                <MudButton Variant="Variant.Text"
                           Color="Color.Secondary"
                           Class="mt-6 text-uppercase"
                           FullWidth="true"
                           ButtonType="ButtonType.Button"
                           OnClick="OpenForgotPasswordDialogAsync">
                    @L["ForgotPassword"]
                </MudButton>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-4">
                        @errorMessage
                    </MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;
    private string passwordInputIcon = Icons.Material.Filled.VisibilityOff;
    private bool isSubmitting;
    private bool isShow = false;
    private InputType passwordInput = InputType.Password;
    private AntiforgeryRequestToken? _currentToken;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "mode")]
    private string? Mode { get; set; }

    [SupplyParameterFromQuery(Name = "oobCode")]
    private string? OobCode { get; set; }

    private string PasswordInputClass => isShow ? "pb-6 login-password-input show" : "pb-6 login-password-input";
    private static DialogOptions AuthDialogOptions => new()
    {
        CloseButton = true,
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true
    };

    protected override void OnInitialized()
    {
        _currentToken = Antiforgery.GetAntiforgeryToken();
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Error))
            errorMessage = Error switch
            {
                "admin_api_unavailable" => L["AdminApiUnavailableError"],
                "admin_api_error" => L["AdminApiError"],
                "admin_profile" => L["AdminProfileError"],
                "session" => L["LoginFailed"],
                _ => L["LoginFailed"]
            };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender
            && string.Equals(Mode, "resetPassword", StringComparison.OrdinalIgnoreCase)
            && !string.IsNullOrWhiteSpace(OobCode))
        {
            await OpenResetPasswordDialogAsync(OobCode);
        }
    }

    private async Task LoginAsync()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        errorMessage = string.Empty;

        var result = await AuthService.LoginAsync(email, password);

        if (!result.Succeeded)
        {
            errorMessage = GetErrorMessage(result.ErrorCode);
            isSubmitting = false;
            return;
        }

        var antiforgery = Antiforgery.GetAntiforgeryToken();
        if (antiforgery is null)
        {
            if (_currentToken is null)
            {
                errorMessage = L["LoginFailed"];
                isSubmitting = false;
                return;
            }
            else
            {
                antiforgery = _currentToken;
            }
        }

        await FormPost.PostAsync("auth/login", new Dictionary<string, string?>
        {
            [antiforgery.FormFieldName] = antiforgery.Value,
            ["idToken"] = result.IdToken,
            ["returnUrl"] = ReturnUrl
        });
    }

    private string GetErrorMessage(string? errorCode) =>
        errorCode switch
        {
            AuthErrorCodes.MissingCredentials => L["MissingCredentials"],
            AuthErrorCodes.InvalidCredentials => L["InvalidCredentials"],
            AuthErrorCodes.LoginFailed => L["LoginFailed"],
            _ => L["LoginFailed"]
        };

    private async Task OpenForgotPasswordDialogAsync()
    {
        await DialogService.ShowAsync<ForgotPasswordDialog>(
            L["ForgotPasswordTitle"],
            AuthDialogOptions);
    }

    private async Task OpenResetPasswordDialogAsync(string oobCode)
    {
        var parameters = new DialogParameters
        {
            [nameof(ResetPasswordDialog.OobCode)] = oobCode,
            [nameof(ResetPasswordDialog.ReturnUrl)] = ReturnUrl
        };

        await DialogService.ShowAsync<ResetPasswordDialog>(
            L["ResetPasswordTitle"],
            parameters,
            AuthDialogOptions);
    }

    private void TogglePasswordVisibility()
    {
        @if (isShow)
        {
            isShow = false;
            passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            passwordInput = InputType.Password;
        }
        else
        {
            isShow = true;
            passwordInputIcon = Icons.Material.Filled.Visibility;
            passwordInput = InputType.Text;
        }
    }

}
