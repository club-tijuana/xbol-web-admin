@page "/season-pass"

@using Odasoft.XBOL.Auth
@attribute [RequirePermission(AdminPermissions.SeasonPasses.Read)]

@using System.Globalization;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants;

@inject AppLocalizer<SeasonPass> L;
@inject IAdminClient AdminClient;
@inject SalesService SalesService;
@inject ISnackbar Snackbar;
@inject NavigationManager NavigationManager;

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <RightContent>
            <MudTooltip Text="@L["ActionDisabledNotOnSale"]" Placement="Placement.Bottom" Disabled="@_isSelectedBundleSellable">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@GoToCheckoutSeasonpass"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Class="text-uppercase"
                           Disabled="@(!_isSelectedBundleSellable)">
                    Comprar Xolopass
                </MudButton>
            </MudTooltip>
        </RightContent>
    </PageActionBar>
</SectionContent>

<MudCard Elevation="3">
    <MudCardHeader>
        <CardHeaderContent>
            <MudGrid Class="align-center">
                <MudItem xs="12" sm="12" md="12" lg="12">
                    <MudText Class="pl-lg-4" Typo="Typo.h5">@L["PageTitle"]</MudText>
                </MudItem>
                <MudItem xs="12" sm="12" md="12" lg="8">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudSelect T="long?" Label="Xolopass" @bind-Value="_selectedBundleId"
                                   @bind-Value:after="OnBundleChanged"
                                   ToStringFunc="GetBundleLabel"
                                   Placeholder="Seleccione un Xolopass"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" ShrinkLabel>
                            @foreach (var bundle in _bundleSelectorItems)
                            {
                                <MudSelectItem T="long?" Value="@bundle.Id">
                                    <MudText Typo="Typo.body2">@bundle.Name</MudText>
                                </MudSelectItem>
                            }
                        </MudSelect>
                        <MudTooltip Text="@L["RenovationModeDisabledNoDestination"]" Placement="Placement.Bottom" Disabled="@_hasRenewalSource">
                            <MudSwitch Color="@Color.Primary" UncheckedColor="@Color.Default"
                                       ThumbIcon="@(_renewalMode ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                       ThumbIconColor="@Color.Default"
                                       @bind-Value="_renewalMode" @bind-Value:after="OnRenewalModeChanged"
                                       Disabled="@(!_hasRenewalSource)"
                                       Label="Ver modo renovación" />
                        </MudTooltip>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="12" lg="4">
                    <MudStack Row AlignItems="AlignItems.Center">
                        <MudTextField @bind-Value="searchString"
                                      @bind-Value:after="@(() => _dataGrid.ReloadServerData())"
                                      Placeholder="@L["Search"]"
                                      Adornment="Adornment.Start"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      AdornmentAriaLabel="@L["Search"]"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Medium"
                                      Margin="Margin.Dense"
                                      Typo="Typo.body2"
                                      Class="flex-grow-1" />
                    </MudStack>
                </MudItem>
            </MudGrid>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent Class="pa-0">
        <MudDataGrid T="SaleResponse" @ref="_dataGrid"
                     ServerData="ServerReload"
                     ExpandSingleRow="true"
                     Loading="_loading"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.Simple"
                     Hover="true"
                     Elevation="0">
            <Columns>
                <HierarchyColumn EnableHeaderToggle="true"></HierarchyColumn>
                <PropertyColumn Property="x => x.OrderReference" Sortable="true" Filterable="false"
                                InitialDirection="MudSortDirection.Descending">
                    <HeaderTemplate>
                        <MudText Typo="Typo.subtitle2" Align="Align.Center">
                            @L["ColumnOrderReference"]
                        </MudText>
                    </HeaderTemplate>
                    <CellTemplate>
                        <MudText Align="Align.Center" Typo="Typo.body2">
                            <MudHighlighter Text="@context.Item.OrderReference" HighlightedText="@searchString" />
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Title="@L["ColumnPhoneNumber"]" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudHighlighter Text="@context.Item.BuyerPhoneNumber" HighlightedText="@searchString" />
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="@L["ColumnEmail"]" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            <MudHighlighter Text="@context.Item.PurchaseEmail" HighlightedText="@searchString" />
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Tipo" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@GetSaleTypeText(context.Item)</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Sortable="false" Filterable="false">
                    <HeaderTemplate>
                        @L["ColumnQuantity"]
                    </HeaderTemplate>
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(context.Item.Quantity ?? context.Item.Items?.Count ?? 0)
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="@L["ColumnTotalAmount"]" Filterable="false" Sortable="false" HeaderClass="text-right" CellClass="text-right">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Align="Align.Right">
                            @((context.Item.Total ?? 0).ToString(FormatConstants.CURRENCY, new CultureInfo("es-MX")))
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                @if (_renewalMode)
                {
                    <TemplateColumn Title="@L["ColumnActions"]" Filterable="false" Sortable="false">
                        <CellTemplate>
                            <MudStack Row Spacing="2">
                                <MudTooltip Text="@GetTooltipText(context.Item)" Placement="Placement.Top">
                                    <MudIconButton Disabled="@(!CanRenew(context.Item))"
                                                   Icon="@Icons.Material.Outlined.ShoppingCart"
                                                   Size="Size.Medium"
                                                   OnClick="@(() => OnRenewClick(context.Item))" />
                                </MudTooltip>
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
            <ChildRowRenderer>
                <tr class="mud-table-row">
                    <th class="mud-table-cell" colspan="2">
                        <div class="mud-typography mud-typography-subtitle2 d-flex justify-center align-center">
                            Asiento
                        </div>
                    </th>
                    <th class="mud-table-cell" colspan="2">
                        <div class="mud-typography mud-typography-subtitle2 d-flex justify-center align-center">
                            Precio
                        </div>
                    </th>
                    <th class="mud-table-cell" colspan="1">
                        <div class="mud-typography mud-typography-subtitle2 d-flex justify-center align-center">
                            Estatus
                        </div>
                    </th>
                    <th class="mud-table-cell" colspan="@(_renewalMode ? 2 : 1)">
                    </th>
                </tr>
                @foreach (var item in context.Item.Items ?? [])
                {
                    <tr class="mud-table-row">
                        <td class="mud-table-cell mud-table-child-content" colspan="2">
                            <div class="d-flex justify-center align-center">
                                @GetSeatLabel(item)
                            </div>
                        </td>
                        <td class="mud-table-cell mud-table-child-content" colspan="2">
                            <div class="d-flex justify-end align-center">
                                @GetItemPrice(item).ToString(FormatConstants.CURRENCY, new CultureInfo("es-MX"))
                            </div>
                        </td>
                        <td class="mud-table-cell mud-table-child-content" colspan="1">
                            <div class="d-flex justify-center align-center">
                                @GetItemStatus(item)
                            </div>
                        </td>
                        <td class="mud-table-cell mud-table-child-content" colspan="@(_renewalMode ? 2 : 1)">
                        </td>
                    </tr>
                }
            </ChildRowRenderer>
            <PagerContent>
                <MudDataGridPager T="SaleResponse" />
            </PagerContent>
        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private bool _loading;
    private string searchString = "";
    private bool _initialized;
    private bool _renewalMode = true;
    private MudDataGrid<SaleResponse> _dataGrid = default!;
    private List<BundleListItemDTO> _bundleSelectorItems = new();
    private long? _selectedBundleId;

    private BundleListItemDTO? SelectedBundle =>
        _selectedBundleId is long id
            ? _bundleSelectorItems.FirstOrDefault(bundle => bundle.Id == id)
            : null;

    private bool _hasRenewalSource => SelectedBundle?.PreviousBundleId is not null;
    private bool _isSelectedBundleSellable => IsBundleSellingNow(SelectedBundle);
    private bool _isSelectedBundleRenewable => IsBundleRenewingNow(SelectedBundle);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var bundlesResponse = await AdminClient.GetBundlesAsync(
                AdminEventStatus.Published,
                BundleType.SeasonPass,
                null,
                "startDate",
                true,
                1,
                100);

            _bundleSelectorItems = bundlesResponse.Items?
                .Where(bundle => bundle.Id.HasValue && !string.IsNullOrWhiteSpace(bundle.ExternalKey))
                .ToList() ?? [];

            _selectedBundleId = _bundleSelectorItems.FirstOrDefault()?.Id;
            _renewalMode = _hasRenewalSource;
            _initialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading filters: {ex.Message}");
            Snackbar.Add(L["ErrorLoadingFilters"], Severity.Error);
        }
    }

    private async Task OnBundleChanged()
    {
        if (!_hasRenewalSource)
        {
            _renewalMode = false;
        }

        if (_dataGrid is not null)
        {
            await _dataGrid.ReloadServerData();
            StateHasChanged();
        }
    }

    private async Task OnRenewalModeChanged()
    {
        if (!_hasRenewalSource)
        {
            _renewalMode = false;
        }

        if (_dataGrid is not null)
        {
            await _dataGrid.ReloadServerData();
        }
    }

    private async Task<GridData<SaleResponse>> FetchFromServer(GridState<SaleResponse> state)
    {
        if (_selectedBundleId is not long bundleId)
        {
            return new GridData<SaleResponse>
            {
                Items = [],
                TotalItems = 0
            };
        }

        var sortDefinition = state.SortDefinitions.FirstOrDefault();

        var result = await SalesService.GetSalesAsync(
            AdminSaleType.Bundle,
            bundleId,
            _renewalMode,
            null,
            null,
            [],
            [],
            [],
            searchString,
            sortDefinition?.SortBy,
            sortDefinition?.Descending,
            state.Page,
            state.PageSize);

        return new GridData<SaleResponse>
        {
            Items = result.Items ?? [],
            TotalItems = result.TotalCount
        };
    }

    private async Task<GridData<SaleResponse>> ServerReload(GridState<SaleResponse> state, CancellationToken token)
    {
        _loading = true;
        try
        {
            if (!_initialized)
            {
                return new GridData<SaleResponse>
                {
                    Items = Array.Empty<SaleResponse>(),
                    TotalItems = 0
                };
            }

            return await FetchFromServer(state);
        }
        catch (TaskCanceledException)
        {
            return new GridData<SaleResponse>
            {
                Items = Array.Empty<SaleResponse>(),
                TotalItems = 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading season passes: {ex.Message}");
            Snackbar.Add(L["ErrorLoadingSeasonPasses"], Severity.Error);
            return new GridData<SaleResponse>
            {
                Items = Array.Empty<SaleResponse>(),
                TotalItems = 0
            };
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToCheckoutSeasonpass()
    {
        if (SelectedBundle is not { Id: long id } bundle || string.IsNullOrWhiteSpace(bundle.ExternalKey))
            return;
        if (!_isSelectedBundleSellable)
            return;

        NavigationManager.NavigateTo($"./season-pass/{id}/key/{bundle.ExternalKey}/booking");
    }

    private void OnRenewClick(SaleResponse item)
    {
        if (SelectedBundle is not { Id: long id } bundle || string.IsNullOrWhiteSpace(bundle.ExternalKey))
            return;
        if (!CanRenew(item) || string.IsNullOrWhiteSpace(item.OrderReference))
            return;

        var reference = Uri.EscapeDataString(item.OrderReference);
        NavigationManager.NavigateTo($"./season-pass/{id}/key/{bundle.ExternalKey}/checkout?renewal={reference}");
    }

    private bool CanRenew(SaleResponse item) =>
        _renewalMode
        && _isSelectedBundleRenewable
        && item.CanRenew == true
        && item.AlreadyRenewed != true;

    private string GetTooltipText(SaleResponse item)
    {
        if (!_isSelectedBundleRenewable)
            return L["ActionDisabledNotOnSale"];
        if (item.AlreadyRenewed == true)
            return "Renovación completada";
        if (item.CanRenew != true)
            return "No disponible para renovación";
        return L["ActionBoletos"];
    }

    private string GetSaleTypeText(SaleResponse item)
    {
        if (_renewalMode)
            return item.CanRenew == true ? "Renovable" : "No renovable";

        return string.IsNullOrWhiteSpace(item.RelatedOrderReference) ? "Nuevo" : "Renovación";
    }

    private string GetBundleLabel(long? id)
    {
        if (id is null)
            return "";

        return _bundleSelectorItems.FirstOrDefault(bundle => bundle.Id == id)?.Name ?? "";
    }

    private static bool IsBundleSellingNow(BundleListItemDTO? bundle)
    {
        if (bundle is null) return false;
        var now = DateTimeOffset.UtcNow;
        var saleStart = bundle.OnSaleDate;
        if (saleStart is null) return false;
        return saleStart <= now && (bundle.OffSaleDate is null || now < bundle.OffSaleDate);
    }

    private static bool IsBundleRenewingNow(BundleListItemDTO? bundle)
    {
        if (bundle?.PreviousBundleId is null) return false;
        var now = DateTimeOffset.UtcNow;
        var renewalStart = bundle.RenewalStartDate ?? bundle.OnSaleDate;
        if (renewalStart is null) return false;
        var renewalEnd = bundle.RenewalEndDate ?? bundle.OffSaleDate;
        return renewalStart <= now && (renewalEnd is null || now < renewalEnd);
    }

    private static string GetSeatLabel(SaleDetailResponse item)
    {
        var label = string.Join(" ", new[] { item.Zone, item.Section, item.Row, item.Seat }
            .Where(part => !string.IsNullOrWhiteSpace(part)));

        return string.IsNullOrWhiteSpace(label) ? item.TrackingCode ?? "" : label;
    }

    private decimal GetItemPrice(SaleDetailResponse item) =>
        _renewalMode ? item.RenewalPrice ?? item.Price ?? 0 : item.Price ?? 0;

    private static string GetItemStatus(SaleDetailResponse item)
    {
        if (item.IsRenewed == true)
            return "Renovado";

        return item.BundlePassStatus?.ToString() ?? "";
    }
}
