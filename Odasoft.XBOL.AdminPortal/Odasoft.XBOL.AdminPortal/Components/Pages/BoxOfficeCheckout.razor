@using FluentValidation;
@using Microsoft.Extensions.Options;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants;
@using Odasoft.XBOL.Common.Helpers;

@implements IAsyncDisposable;

@inject CartState _cartState;
@inject PersistentDialogState _persistentDialogState;
@inject ISnackbar _snackbar;
@inject IAdminClient _adminClient;
@inject NavigationManager _navigation;
@inject IOptions<SeatsIoOptions> SeatsOptions;
@inject AppLocalizer<Events> L;
@inject LoadingState _loadingState;
@inject IDialogService _dialogService;
@inject ClientsService _clientsService;
@inject CatalogsService _catalogsService;
@inject ExchangeRateService _exchangeRateService
@inject ILogger<BoxOfficeCheckout> Logger;

<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigationAsync" ConfirmExternalNavigation="true" />

<MudForm @ref="_form" Model="_request" Validation="@(orderValidator.ValidateValue)">
    <MudGrid Justify="Justify.SpaceBetween">
        <MudItem xs="12" Class="d-flex justify-space-between align-start mb-4">
            <MudStack>
                <MudText Typo="Typo.h5"><b>@_eventInfo.Name</b></MudText>
                <MudStack Row>
                    <MudText Typo="Typo.body1" Class="text-secondary-darken" Style="font-weight:600;">@_eventInfo.VenueName</MudText>
                    <MudText Typo="Typo.body1">@_eventSchedulueInfo?.StartDateTime.ToString("dd/MM/yyyy h:mm tt")</MudText>
                </MudStack>
            </MudStack>
            <MudButton OnClick="ReturnAsync" Variant="Variant.Filled" DropShadow="false" Color="Color.Secondary" StartIcon="@Icons.Material.Outlined.ArrowBackIosNew">@L["Seats"]</MudButton>
        </MudItem>
        <MudItem xs="3">
            <MudGrid Spacing="10">
                <MudItem xs="12">
                    <MudText Typo="Typo.h5" Class="text-primary-darken">@L["BuyerInfo"]</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect Label="@(L["AreaCode"] + "*")"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Value="_request.PhoneRegionCodeId"
                               For="@(() => _request.PhoneRegionCodeId)">

                        @foreach (var regionCode in _phoneRegionCodes)
                        {
                            <MudSelectItem T="long?" Value="regionCode.Id">
                                <MudImage Src="@FlagHelper.GetFlagImageUrl(regionCode.RegionCode ?? "")" Height="15" Elevation="1" ObjectFit="ObjectFit.Fill" /> @($"+{regionCode.DialCode}")
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField Label="@(L["Phone"] + "*")"
                                  @bind-Value="_request.PhoneNumber"
                                  For="@(() => _request.PhoneNumber)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="10"
                                  OnBlur="SearchOnBlurAsync"
                                  InputType="InputType.Telephone" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="@(L["Email"] + "*")"
                                  Variant="Variant.Outlined"
                                  @bind-Value="_request.Email"
                                  For="@(() => _request.Email)"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  OnBlur="SearchOnBlurAsync"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_request.FullName"
                                  For="@(() => _request.FullName)"
                                  Label="@(L["BuyerFullName"] + "*")"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_request.City"
                                  For="@(() => _request.City)"
                                  Label="@L["City"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_request.Neighborhood"
                                  For="@(() => _request.Neighborhood)"
                                  Label="@L["Neighborhood"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect @bind-Value="_request.Gender"
                               For="@(() => _request.Gender)"
                               Label="@L["Gender"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="Sin especificar"
                               Immediate="true"
                               ShrinkLabel>
                        @foreach (var gender in genders)
                        {
                            <MudSelectItem T="ClientGender?" Value="@gender">
                                <MudText Typo="Typo.body2">@L[gender.ToString()]</MudText>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudDatePicker Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @bind-Date="_request.Birthday"
                                   For="@(() => _request.Birthday)"
                                   Label="@L["DateOfBirth"]"
                                   Mask="@(new DateMask("dd/MM/yyyy"))"
                                   DateFormat="dd/MM/yyyy"
                                   Clearable />
                </MudItem>
            </MudGrid>
        </MudItem>
        <MudItem xs="4">
            <MudStack>
                <MudText Typo="Typo.h5" Class="text-primary-darken">@L["Summary"]</MudText>
                <MudText Typo="Typo.body1" Class="text-secondary-darken">@L["SelectSeatsMessage"]:</MudText>
                <BoxOfficeOrderSummary></BoxOfficeOrderSummary>
            </MudStack>
        </MudItem>
        <MudItem xs="3">
            <MudGrid class="d-flex gap-4 align-center mb-3">
                <MudItem xs="12">

                    <MudToggleGroup T="int" @bind-Value="_value">

                        <MudToggleItem T="int" Value="1" Text="Caja" />
                        <MudToggleItem T="int" Value="2" Text="Link de pago" />

                    </MudToggleGroup>

                </MudItem>
            </MudGrid>

            @if (_value == 1)
            {
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.h5" Class="text-primary-darken">@L["PaymentMethod"]</MudText>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.CardAmount"
                                         For="@(() => _request.CardAmount)"
                                         Format="N2"
                                         Label="@L["Card"]"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="false" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllCardAsync">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.CashAmount"
                                         For="@(() => _request.CashAmount)"
                                         Format="N2"
                                         Label="@L["Cash"]"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="false" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllCashAsync">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.DolarAmount"
                                         For="@(() => _request.DolarAmount)"
                                         Format="N2"
                                         Label="@L["Dollars"]"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="false" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllDolar">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.OtherAmount"
                                         For="@(() => _request.OtherAmount)"
                                         Format="N2"
                                         Label="@L["OtherPaymentMethod"]"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="false" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllOtherAsync">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12">
                        <div class="order-summary">
                            <div class="d-flex justify-space-between summary-item">
                                <MudText Typo="Typo.caption">
                                    Tipo de cambio
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    @((exchangeRate.Rate ?? 0).ToString("N2")) MXN/USD
                                </MudText>
                            </div>

                            <div class="d-flex justify-space-between summary-item summary-received">
                                <MudText Typo="Typo.body1">@L["Received"]</MudText>
                                <MudText Typo="Typo.body1" Style="font-size: 20px;">@TotalPay.ToString(FormatConstants.CURRENCY)</MudText>
                            </div>

                            <div class="d-flex justify-space-between summary-item summary-change">
                                <MudText Typo="Typo.body1">@(PendingPay < 0 ? L["Change"] : L["Pending"])</MudText>
                                <MudText Typo="Typo.body1" Color="PendingPayColor">@FormattedPendingPay</MudText>
                            </div>
                        </div>
                    </MudItem>

                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudText Typo="Typo.h6">
                            Cambio
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.MXNAmount"
                                         For="@(() => _request.MXNAmount)"
                                         Format="N2"
                                         Label="MXN"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="true" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllMXNChangeAsync">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12" class="d-flex gap-4 align-center">
                        <MudNumericField @bind-Value="_request.USDAmount"
                                         For="@(() => _request.USDAmount)"
                                         Format="N2"
                                         Label="USD"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                         Margin="Margin.Dense"
                                         Placeholder="0.00"
                                         HideSpinButtons="true"
                                         Immediate="true" />
                        <MudButton Variant="Variant.Outlined" @onclick="SetAllUSDChangeAsync">TODO</MudButton>
                    </MudItem>
                    <MudItem xs="12">
                        <div class="order-summary">
                            <div class="d-flex justify-space-between summary-item summary-received">
                                <MudText Typo="Typo.body2" class="me-1">Saldo</MudText>
                                <MudText Typo="Typo.subtitle2" Color="RemainingBalanceColor">
                                    @RemainingBalance.ToString(FormatConstants.CURRENCY)
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" class="d-flex align-center">
                        <MudTextField Label="Fecha de expiración"
                                      Value="@ExpirationDateText"
                                      ReadOnly="true"
                                      @onclick="OpenDateTimeDialog"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            }

            <MudGrid>
                <MudItem xs="12">
                    <MudRadioGroup @bind-Value="_request.DeliveryType" For="@(() => _request.DeliveryType)">
                        <MudGrid Justify="Justify.SpaceBetween">
                            <MudItem xs="12" lg="6">
                                <MudRadio Value="@("Impreso")" Color="Color.Primary" UncheckedColor="Color.Secondary">
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Print" Title="Favorite" />
                                        <MudText Typo="Typo.body1">@L["PrintTicket"]</MudText>
                                    </MudStack>
                                </MudRadio>
                            </MudItem>
                            <MudItem xs="12" lg="6">
                                <MudRadio Value="@("Digital")" Color="Color.Primary" UncheckedColor="Color.Secondary">
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Send" Title="Favorite" />
                                        <MudText Typo="Typo.body1">@L["DigitalTicket"]</MudText>
                                    </MudStack>
                                </MudRadio>
                            </MudItem>
                        </MudGrid>
                    </MudRadioGroup>
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end">
                    <MudStack AlignItems="AlignItems.End">
                        <MudSwitch @bind-Value="_request.AcceptTermsAndConditions" For="@(() => _request.AcceptTermsAndConditions)" UncheckedColor="Color.Secondary" Color="Color.Primary">
                            <MudText Typo="Typo.body1" Color="Color.Secondary">@L["AcceptTermsAndConditions"].</MudText>
                        </MudSwitch>
                        <MudLink Typo="Typo.body1" EndIcon="@Icons.Material.Filled.OpenInNew" OnClick="OpenTermsAndConditions">@L["SeeTermsAndConditions"]</MudLink>                    
                    </MudStack>
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end">
                    <MudButton Variant="Variant.Filled"
                               DropShadow="false"
                               StartIcon="@Icons.Material.Outlined.Save"
                               Color="Color.Tertiary"
                               Size="Size.Large"
                               @onclick="SubmitAsync">@(_isSubmitting? L["Processing"] + "..." : L["Pay"])</MudButton>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>
</MudForm>

@code {
    [Parameter]
    [EditorRequired]
    public EventInfoDTO _eventInfo { get; set; }

    [EditorRequired]
    [Parameter]
    public string EventKey { get; set; }

    [Parameter]
    public EventCallback OnReturn { get; set; }

    MudForm _form = default!;

    private bool _isSubmitting = false;
    private bool _successfulPurchase = false;

    private int _value = 1;

    private List<ClientGender> genders = Enum.GetValues<ClientGender>().ToList();

    private BookingForm _request = new();
    private BookingFormFluentValidator orderValidator = new();

    private ExchangeRateResponse exchangeRate = new();

    private EventScheduleDTO? _eventSchedulueInfo;

    private decimal DollarAmountInMXN =>
        (_request.DolarAmount ?? 0) * (exchangeRate?.Rate ?? 0);

    private decimal TotalPay =>
        (_request.CardAmount ?? 0) +
        (_request.CashAmount ?? 0) +
        DollarAmountInMXN +
        (_request.OtherAmount ?? 0);

    private decimal TotalReceived =>
        (_request.CardAmount ?? 0) +
        (_request.CashAmount ?? 0) +
        DollarAmountInMXN +
        (_request.OtherAmount ?? 0);

    private decimal TotalChangeMx =>
        (_request.MXNAmount ?? 0)
        + ((_request.USDAmount ?? 0) * (exchangeRate.Rate ?? 0));

    private decimal RemainingBalance => TotalPay - _cartState.TotalPrice - TotalChangeMx;

    private bool HasValidPaymentLinkExpiration =>
        _request.PaymentLinkExpiresAt != null;

    private bool HasBalanceError =>
        _value == 1 &&
        RemainingBalance != 0;

    private bool HasPaymentLinkError =>
        _value == 2 &&
        !HasValidPaymentLinkExpiration;

    private DateTime? ExpirationDate { get; set; } = DateTime.Now;

    private string ExpirationDateText =>
        ExpirationDate?.ToString("dd/MM/yy - HH:mm 'hrs'") ?? "";

    private decimal PendingPay => _cartState.TotalPrice - TotalPay;
    private string FormattedPendingPay => Math.Abs(PendingPay).ToString(FormatConstants.CURRENCY);
    private Color PendingPayColor => PendingPay > 0 ? Color.Error : PendingPay < 0 ? Color.Tertiary : Color.Secondary;
    private Color RemainingBalanceColor => RemainingBalance > 0 ? Color.Error : RemainingBalance < 0 ? Color.Warning : Color.Success;

    private List<PhoneRegionCodeResponse> _phoneRegionCodes = [];

    protected override async Task OnInitializedAsync()
    {
        _cartState.OnChange += StateHasChanged;

        try
        {
            if (_eventInfo?.Schedules?.Any() == true)
            {
                _eventSchedulueInfo = _eventInfo.Schedules.First();
            }

            _phoneRegionCodes = await _catalogsService.GetPhoneRegionCodesAsync();
            exchangeRate = await _exchangeRateService.GetExchangeRateByEventAsync(_cartState.CurrentEventId.Value);

            // TODO: Move this to a proper service
            var holdToken = await _adminClient.HoldSeatsByKeyAsync(EventKey, new HoldSeatsBody
            {
                Seats = _cartState.FinalSeatsSelection.Select(x => x.SeatId).ToList(),
            });

            if (string.IsNullOrWhiteSpace(holdToken.Token))
            {
                throw new InvalidOperationException("HoldSeatsByKeyAsync returned a response with no token.");
            }

            _cartState.SetHoldToken(holdToken.Token, holdToken.ExpiresAt.GetValueOrDefault());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to hold seats");
            _snackbar.Add(L["ErrorBookingTickets"], MudBlazor.Severity.Error);
            await ReturnAsync();
        }
    }

    private async Task SearchOnBlurAsync(FocusEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(_request.PhoneNumber) && string.IsNullOrWhiteSpace(_request.Email))
        {
            return;
        }

        try
        {
            ClientContactResponse? client = await _clientsService.SearchClientAsync(_request.PhoneRegionCodeId, _request.PhoneNumber ?? "", _request.Email ?? "");

            if (client is not null)
            {
                _request.FullName = $"{client.Name} {client.LastName}";
                _request.PhoneRegionCodeId = client.PhoneRegionCodeId;
                _request.PhoneNumber = string.IsNullOrWhiteSpace(client.PhoneNumber) ? _request.PhoneNumber : client.PhoneNumber;
                _request.Email = string.IsNullOrWhiteSpace(client.Email) ? _request.Email : client.Email;
                _request.ClientId = client.Id;
                _request.City = client.City;
                _request.Neighborhood = client.Neighbourhood;
                _request.Gender = (ClientGender?)client.Gender;
                _request.Birthday = DateTimeHelpers.ToNullableDateTime(client.Dob);
            }
        }
        catch (ApiException ex)
        {
            // If the client is not found, we don't want to show an error, we just want to clear the form
            if (ex.StatusCode != StatusCodes.Status404NotFound)
            {
                Logger.LogError(ex, "Unexpected error searching for client");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error searching for client");
        }

    }

    private async Task ReturnAsync()
    {
        bool exit = await ConfirmExitAsync();

        if (exit)
        {
            await OnReturn.InvokeAsync();
        }
    }

    private async Task<bool> ConfirmExitAsync()
    {

        var result = await _dialogService.ShowMessageBoxAsync(
                L["UnsavedChangesTitle"],
                L["UnsavedChangesMessage"],
                yesText: L["UnsavedChangesConfirm"],
                cancelText: L["UnsavedChangesCancel"]);

        if (result is true)
        {
            await ReleaseTokenAsync();
        }

        return result is true;
    }

    private async Task OnBeforeInternalNavigationAsync(LocationChangingContext context)
    {
        if (_successfulPurchase)
        {
            return;
        }

        var exit = await ConfirmExitAsync();

        if (!exit)
        {
            context.PreventNavigation();
        }
    }

    private async Task ReleaseTokenAsync()
    {
        // TODO: make sure token is released in seats.io before leaving this method
        try
        {
            var token = await _adminClient.ReleaseHoldSeatsAsync(_cartState.HoldToken);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to release hold seats {HoldToken}", _cartState.HoldToken);
        }
        finally
        {
            _cartState.ClearTokenAsync();
        }
    }

    private void ClearPaymentExpirationsAsync()
    {
        _request.PaymentLinkExpiresAt = null;
    }

    private async void ClearAmountsAsync()
    {
        _request.CardAmount = null;
        _request.CashAmount = null;
        _request.DolarAmount = null;
        _request.CreditAmount = null;
        _request.OtherAmount = null;
    }

    private async void SetAllCashAsync()
    {
        ClearAmountsAsync();
        _request.CashAmount = _cartState.TotalPrice;
    }
    private async void SetAllCardAsync()
    {
        ClearAmountsAsync();
        _request.CardAmount = _cartState.TotalPrice;
    }
    private async void SetAllDolar()
    {
        ClearAmountsAsync();

        if (exchangeRate == null || exchangeRate.Rate == null)
        {
            _snackbar.Add("No hay tipo de cambio configurado.");
            return;
        }

        _request.DolarAmount = Math.Round(
            _cartState.TotalPrice / exchangeRate.Rate.Value,
            2
        );
    }

    private async void SetAllOtherAsync()
    {
        ClearAmountsAsync();
        _request.OtherAmount = _cartState.TotalPrice;
    }

    private void SetAllMXNChangeAsync()
    {
        _request.MXNAmount = Math.Abs(PendingPay);
        _request.USDAmount = 0;
    }

    private void SetAllUSDChangeAsync()
    {
        if (exchangeRate?.Rate is null || exchangeRate.Rate <= 0)
        {
            return;
        }

        _request.MXNAmount = 0;

        _request.USDAmount = Math.Round(
            Math.Abs(PendingPay) / exchangeRate.Rate.Value,
            2,
            MidpointRounding.AwayFromZero);
    }

    private void OnTogglePaymentTypeChanged()
    {
        if (_value == 1)
        {
            _request.PaymentLinkExpiresAt = null;
        }
        else
        {
            ClearAmountsAsync();
        }
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting)
            return;

        _request.PendingPay = PendingPay;
        _request.ExchangeRate = exchangeRate.Rate ?? 0;
        _request.TotalPrice = _cartState.TotalPrice;

        await _form.ValidateAsync();

        if (!_form.IsValid)
        {
            return;
        }

        // TODO: Add this validation to the FluentValidator
        if (_value == 1) 
        {
            if(TotalPay < PendingPay)
            {
                return;
            }
        }

        if(_cartState.FinalSeatsSelection.Count == 0)
        {
            _snackbar.Add(L["SelectSeatsMessage"], MudBlazor.Severity.Warning);
            return;
        }

        _isSubmitting = true;
        _loadingState.Show();

        var request = new EventBookingRequest
        {
            Seats = _cartState.FinalSeatsSelection.Select(x => new BookingSeatRequest
            {
                SeatKey = x.SeatId,
                SeatPrice = x.Price,
                PriceListItemId = x.PriceListItemId
            }).ToList(),
            HoldToken = _cartState.HoldToken ?? "",
            EventKey = EventKey,
            ClientContact = new ClientInfoRequest
            {
                Id = _request.ClientId,
                PhoneRegionCodeId = _request.PhoneRegionCodeId,
                PhoneNumber = _request.PhoneNumber,
                Email = _request.Email,
                FullName = _request.FullName,
                City = _request.City,
                Neighborhood = _request.Neighborhood,
                Gender = _request.Gender,
                Birthday = DateTimeHelpers.ToDateTimeOffset(_request.Birthday)
            },
            PaymentInfoRequest = new PaymentInfoRequest
            {
                CardAmount = _request.CardAmount,
                CashAmount = _request.CashAmount,
                DolarAmount = _request.DolarAmount,
                OtherAmount = _request.OtherAmount
            },
            ChangeInfoRequest = new ChangeInfoRequest
            {
                AmountMXN = _request.MXNAmount,
                AmountUSD = _request.USDAmount
            },
            IsPaymentLink = _value == 2,
            PaymentLinkRequest = new PaymentLinkRequest
            {
                ExpiresAt = _request.PaymentLinkExpiresAt
            },
            TicketType = ItemType.Ticket,
        };

        try
        {
            // TODO: Move to a proper service
            var result = await _adminClient.BookEventSeatsAsync(request);

            _persistentDialogState.SetBookingResult(result);

            _successfulPurchase = true;
            _cartState.ClearCart();
            _cartState.ClearTokenAsync();

            if (_value == 2)
            {
                _navigation.NavigateTo($"./support/{result.Localizer}");
            }
            else 
            {
                _navigation.NavigateTo("./box-office");
            }
        }
        catch (Exception)
        {
            _snackbar.Add(L["Seats_PaymentError"], MudBlazor.Severity.Error);

            await ReleaseTokenAsync();
            await OnReturn.InvokeAsync();
        }
        finally
        {
            _isSubmitting = false;
            _loadingState.Hide();
        }
    }

    private async Task OpenDateTimeDialog()
    {
        var parameters = new DialogParameters
        {
            ["Value"] = ExpirationDate,
            ["Title"] = "Fecha de expiración"
        };

        var options = new DialogOptions
        {
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            NoHeader = true
        };

        var dialog = await _dialogService.ShowAsync<DateTimeDialog>(
            "",
            parameters,
            options
        );

        var result = await dialog.Result;

        if (!result.Canceled && result.Data is DateTime selected)
        {
            ExpirationDate = selected;
            _request.PaymentLinkExpiresAt = selected;
        }
    }

    private async Task OpenTermsAndConditions()
    {
        var dialog = await _dialogService.ShowAsync<TermsAndConditionsDialog>(L["TermsAndConditions"]);
    }

