@page "/box-office"
@using Odasoft.XBOL.Auth
@attribute [RequirePermission(AdminPermissions.Orders.Create)]

@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Business.Services;
@using Odasoft.XBOL.Common.Constants;

@inject AppLocalizer<BoxOffice> L;
@inject NavigationManager Navigation;
@inject ISnackbar Snackbar;
@inject IDialogService DialogService;
@inject IEventService EventService;
@inject OrdersService OrdersService;
@inject LoadingState LoadingState;
@inject PersistentDialogState PersistentDialogState;
@inject ILogger<BoxOffice> Logger;

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudText Typo="Typo.h5" Color="Color.Secondary">@L["PageTitle"]</MudText>
        </LeftContent>
        <RightContent>
            <MudStack Row AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle1" Color="Color.Tertiary"><b>@L["TrackingInputLabel"]</b></MudText>
                <MudTextField @bind-Value="Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="@L["TrackingInputPlaceholder"]"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Style="min-width: 370px;"
                              OnAdornmentClick="@SearchOrder"
                              OnKeyDown="HandleKeyDown"
                              Immediate>
                </MudTextField>
            </MudStack>
        </RightContent>
    </PageActionBar>
</SectionContent>
<LoadingContainer IsLoading="@_isLoading"
                  HasError="@_error"
                  ErrorMessage="@_errorMessage">
    <MudGrid Spacing="4">
        @if (Events.Any())
        {
            @foreach (var eventItem in Events)
            {

                <MudItem xs="12" md="6" lg="3">
                    <EventCard Event="eventItem" CanOverrideSaleWindow="_canOverrideSaleWindow" OnClick="@(() => GoToSeats(eventItem))"></EventCard>
                </MudItem>
            }
        }
        else
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info">@L["NoEventsFound"]</MudAlert>
            </MudItem>
        }
        @if (TotalPages > 1)
        {
            <MudItem xs="12" Class="d-flex justify-center mt-4">
                <MudPagination Color="Color.Primary" Count="TotalPages" Selected="@_page" SelectedChanged="OnPageChanged" />
            </MudItem>
        }
    </MudGrid>
</LoadingContainer>
@code {
    private string Search { get; set; } = string.Empty;
    private bool _isLoading = false;
    private bool _error = false;
    private string _errorMessage = string.Empty;
    private int _page = QueryParamsConstants.DEFAULT_PAGE;
    private int _pageSize = 12;
    private int _totalItems = 0;
    private bool _canOverrideSaleWindow;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private int TotalPages => (int)Math.Ceiling((double)_totalItems / _pageSize);

    private IEnumerable<EventViewModel> Events { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
            if (AuthenticationStateTask is not null)
            {
                var authState = await AuthenticationStateTask;
                _canOverrideSaleWindow = AdminPermissionScopes.HasPermission(authState.User, AdminPermissions.Orders.OverrideSaleWindow);
            }

            await LoadEvents();
        }

    private async Task LoadEvents()
    {
        _isLoading = true;
        try
        {
            var result = await EventService.GetEventCatalogAsync(
            page: _page - 1,
            pageSize: _pageSize,
            sortColumn: "startDate",
            sortDescending: false,
            upcoming: true,
            buyableOnly: true,
            status: AdminEventStatus.Published);

            Events = result.Items;
            _totalItems = result.TotalItems;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load events on sale");
            Snackbar.Add(L["ErrorLoadingEvents"], Severity.Error);
            _error = true;
            _errorMessage = L["ErrorLoadingEvents"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadEvents();
    }

    private Task ShowOrderDetail(string reference)
    {
        var parameters = new DialogParameters<OrderDetailDialog> { { x => x.OrderReference, reference } };
        DialogOptions options = new() { CloseButton = true };
        return DialogService.ShowAsync<OrderDetailDialog>(string.Empty, parameters, options);
    }

    private async Task GoToSeats(EventViewModel e)
    {
        if (e.IsSeason == true || e.IsBundle == true)
        {
            if (!SeasonPassPurchaseWindow.CanBuy(
                    e.OnSaleDate,
                    e.OffSaleDate,
                    e.HasRenewalWindow,
                    e.RenewalEndDate,
                    e.IsBookable,
                    DateTimeOffset.UtcNow,
                    _canOverrideSaleWindow))
            {
                Snackbar.Add(L["CannotBookSeasonPass"], Severity.Warning);
                return;
            }

            Navigation.NavigateTo($"./box-office/bundles/{e.Id}/seats");
        }
        else
        {
            Navigation.NavigateTo($"./box-office/{e.EventScheduleId}/seats");
        }
    }

    private async Task SearchOrder()
    {
        if (string.IsNullOrWhiteSpace(Search))
        {
            return;
        }

        LoadingState.Show();
        try
        {
            var canRenew = await OrdersService.CanOrderBeRenewedAsync(Search);

            if(canRenew.CanRenew == true)
            {
                Navigation.NavigateTo($"./box-office/bundles/renovate/{canRenew.NewSeasonId}/{canRenew.Reference}");
            }
            else if(!string.IsNullOrWhiteSpace(canRenew.Reference))
            {
                await ShowOrderDetail(canRenew.Reference);
            }
            else
            {
                Snackbar.Add(L["OrderNotFound", Search], Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching for order");
            Snackbar.Add(L["OrderNotFound", Search], Severity.Warning);
        }
        finally
        {
            LoadingState.Hide();
        }
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchOrder();
        }
    }
}
