@page "/box-office"

@inject AppLocalizer<BoxOffice> L
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService;

<PageTitle>@L["PageTitle"]</PageTitle>

<SectionContent SectionName="nav-header">
    <PageActionBar>
        <LeftContent>
            <MudText Typo="Typo.h5" Color="Color.Secondary">@L["PageTitle"]</MudText>
        </LeftContent>
        <RightContent>
            <MudStack Row AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle1" Color="Color.Tertiary"><b>@L["TrackingInputLabel"]</b></MudText>
                <MudTextField @bind-Value="Search"
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense" 
                              Placeholder="@L["TrackingInputPlaceholder"]"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Style="min-width: 370px;">
                </MudTextField>
            </MudStack>
        </RightContent>
    </PageActionBar>
</SectionContent>
<LoadingContainer IsLoading="@_isLoading"
                  HasError="@_error"
                  ErrorMessage="@_errorMessage">
    <MudGrid Spacing="4">
        @foreach (var @event in Events)
        {            
            <MudItem xs="12" md="6" lg="3">
                <MudCard Elevation="3" Style="cursor: pointer;" @onclick="@(() => Navigation.NavigateTo($"/box-office/{@event.Id}/seats"))">
                    @if (string.IsNullOrEmpty(@event.PosterImageUrl))
                    {
                        <ImagePlaceholder Height="@(_thumbnailHeight + "px")" />
                    }
                    else
                    {
                        <MudCardMedia Image="@(@event.PosterImageUrl)" Height="@_thumbnailHeight" />
                    }
                    <MudCardContent Class="py-2 px-3">
                        <MudGrid>
                            <MudItem xs="6">
                                <MudStack>
                                    <MudTooltip Text="@(@event.EventName)">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="truncate-text"><b>@(@event.EventName)</b></MudText>
                                    </MudTooltip>
                                    <MudText Typo="Typo.caption">@(@event.Date.ToString("d MMM yyyy"))</MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="6" Class="d-flex justify-end">
                                <MudStack>
                                    <MudText Typo="Typo.caption">@L["Availability"]</MudText>
                                    <MudStack Row Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Color="Color.Tertiary" Icon="@Icons.Material.Filled.EventSeat" Size="Size.Small" />
                                        <MudText Color="Color.Tertiary" Typo="Typo.body2"><b>@(@event.AvailableSeats)</b></MudText>
                                    </MudStack>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        <MudItem xs="12">
            <MudStack Row>
                <MudButton OnClick="ShowOrderDetail">Mostrar Orden</MudButton>
                <MudButton OnClick="ShowSeasonPassDetail">Mostrar Season Pass</MudButton>
                <MudButton OnClick="ShowSuccesfulOrder">Mostrar Orden completada</MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</LoadingContainer>
@code {
    private string Search { get; set; } = string.Empty;
    private bool _isLoading = false;
    private bool _isSubmitting = false;
    private bool _error = false;
    private string _errorMessage = string.Empty;
    private int _thumbnailHeight = 120;

    private IEnumerable<EventInfo> Events { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            Events = [new EventInfo { Id = 1, EventName = "Shakira en Tijuana", AvailableSeats = 16523, Date = new DateTimeOffset(2025, 11, 15, 0, 0, 0, default) }, new EventInfo { Id = 2, EventName = "Apertura Play-in: Club Tijuana", AvailableSeats = 16523, Date = new DateTimeOffset(2025, 11, 15, 0, 0, 0, default) }];
        }
        catch (Exception)
        {
            Snackbar.Add(L["ErrorLoadingEvents"], Severity.Error);
            _error = true;
            _errorMessage = L["ErrorLoadingEvents"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task ShowOrderDetail()
    {
        DialogOptions options = new() { CloseButton = true };
        return DialogService.ShowAsync<OrderDetailDialog>(string.Empty, options);
    }

    private Task ShowSeasonPassDetail()
    {
        DialogOptions options = new() { CloseButton = true };
        return DialogService.ShowAsync<SeasonPassDetailDialog>(string.Empty, options);
    }

    private Task ShowSuccesfulOrder()
    {
        DialogOptions options = new() { CloseButton = true, Position = DialogPosition.TopRight };
        return DialogService.ShowAsync<SuccesfulOrderDialog>(string.Empty, options);
    }

    public class EventInfo
    {
        public long Id { get; set; }
            public string? PosterImageUrl { get; set; }
        public required string EventName { get; set; }
        public DateTimeOffset Date { get; set; }
        public int AvailableSeats { get; set; }
    }
}
