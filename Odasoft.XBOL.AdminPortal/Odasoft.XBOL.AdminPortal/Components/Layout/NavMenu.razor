@using Odasoft.XBOL.Common.Constants
@using Odasoft.XBOL.Auth
@using Odasoft.XBOL.Business
@inject AppLocalizer<NavMenu> _localizer;
@inject IAdminClient AdminClient;

<MudNavMenu>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="./" Match="NavLinkMatch.All" IconColor="Color.Primary"
                        Icon="@Icons.Material.Filled.Dashboard" Class="nav-link pt-1">
                Dashboard
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.Orders.Create)">
        <Authorized>
            <MudNavLink Href="./box-office" IconColor="Color.Primary" Class="nav-link pt-1"
                        Icon="@Icons.Material.Filled.Storefront">
                Box Office
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.BuildAny(AdminPermissions.Events.Read, AdminPermissions.Events.ReadCurrent)">
        <Authorized>
            <MudNavLink Href="./events" IconColor="Color.Primary" Class="nav-link pt-1"
                        Icon="@Icons.Material.Filled.ConfirmationNumber">
                Eventos
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.BuildAny(AdminPermissions.Seasons.Read, AdminPermissions.SeasonPasses.Read)">
        <Authorized>
            <MudNavGroup Title="@_localizer["SeasonPasses"]" IconColor="Color.Primary" Class="nav-link pt-1" Icon="@Icons.Material.Filled.EventSeat" Expanded="false">
                <MudNavLink Href="./season-schedules" Class="nav-link pt-1" Disabled>
                    @_localizer["SalesConfiguration"]
                </MudNavLink>
                @foreach (var bundle in _seasonPassBundles)
                {
                    <MudNavLink Href="@($"./season-pass/{bundle.Id}")" Class="nav-link pt-1">
                        @bundle.Name
                    </MudNavLink>
                }
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.Clients.Read)">
        <Authorized>
            <MudNavLink Href="./clients" IconColor="Color.Primary" Class="nav-link-rounded pt-1"
                        Icon="@Icons.Material.Filled.Badge">
                Empresas y créditos
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.SuiteAgreements.Read)">
        <Authorized>
            <MudNavLink Href="@SitePages.SUITE_AGREEMENTS" IconColor="Color.Primary" Class="nav-link-rounded pt-1" Icon="@Icons.Custom.Uncategorized.ChessQueen">
                Contratos de palcos
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.BuildAny(AdminPermissions.Reports.Sales.SelfRead, AdminPermissions.Reports.Sales.CashiersRead, AdminPermissions.Reports.Sales.WebRead)">
        <Authorized>
            <MudNavLink Href="./reports" IconColor="Color.Primary" Class="nav-link-rounded pt-1"
                        Icon="@Icons.Material.Filled.InsertChart">
                Reportes
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.Support.Read)">
        <Authorized>
            <MudNavLink Href="@SitePages.SUPPORT" IconColor="Color.Primary" Class="nav-link pt-1"
                        Icon="@Icons.Material.Filled.ManageSearch">
                @_localizer["Support"]
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="@PermissionPolicy.BuildAny(AdminPermissions.Venues.Read, AdminPermissions.Roles.Read)">
        <Authorized>
            <MudNavGroup Title="@_localizer["Settings"]"
                         Icon="@Icons.Material.Filled.Settings"
                         IconColor="Color.Primary"
                         Class="nav-link-rounded pt-1">
        <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.Venues.Read)" Context="venuesCtx">
            <Authorized>
                <MudNavLink Href="@SitePages.VENUES" Class="nav-link pt-1">
                    @_localizer["VenuesAndSuites"]
                </MudNavLink>
            </Authorized>
        </AuthorizeView>
        <MudNavLink Href="./settings/dinamyc-prices" Class="pt-1" Disabled>
            Precios dinámicos
        </MudNavLink>
        <AuthorizeView Policy="@PermissionPolicy.Build(AdminPermissions.Roles.Read)" Context="rolesCtx">
            <Authorized>
                <MudNavLink Href="./settings/security" Class="pt-1">
                    Roles y permisos
                </MudNavLink>
            </Authorized>
        </AuthorizeView>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private List<BundleListItemDTO> _seasonPassBundles = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadSeasonPassBundlesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading season pass navigation: {ex.Message}");
        }
    }

    private async Task LoadSeasonPassBundlesAsync()
    {
        const int pageSize = 100;
        var bundles = new List<BundleListItemDTO>();

        for (var page = 1; ; page++)
        {
            var response = await AdminClient.GetBundlesAsync(
                null,
                BundleType.SeasonPass,
                null,
                "startDate",
                true,
                page,
                pageSize);

            var pageItems = response.Items?
                .Where(bundle => bundle.Id.HasValue)
                .ToList() ?? [];

            bundles.AddRange(pageItems);

            if (pageItems.Count < pageSize)
                break;
        }

        _seasonPassBundles = bundles;
    }
}
