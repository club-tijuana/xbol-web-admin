        </MudNavLink>
        <MudNavLink Href="@SitePages.SUITES_SETTINGS" Class="nav-link pt-1">
            Palcos
        </MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Configuración"
                 Icon="@Icons.Material.Filled.Settings"
                 IconColor="Color.Primary"
                 Class="nav-link-rounded pt-1"
                 Disabled>
        <MudNavLink Href="/settings/users" Class="pt-1">
            Usuarios
        </MudNavLink>

        <MudNavLink Href="/settings/security" Class="pt-1" Disabled>
            Roles
        </MudNavLink>
    </MudNavGroup>
