            </AuthorizeRouteView>
        </Found>

        <NotFound>
            <RedirectToLogin />
        </NotFound>
    </Router>
</CascadingAuthenticationState> *@
  <ReconnectModal />
  <script src="@Assets["_framework/blazor.web.js"]"></script>
  <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
</body>

</html>
