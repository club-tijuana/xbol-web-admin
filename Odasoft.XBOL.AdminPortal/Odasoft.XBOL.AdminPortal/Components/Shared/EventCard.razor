@using Odasoft.XBOL.Business
@inject AppLocalizer<EventCard> L
@inject NavigationManager _navigationManager;

<MudCard Elevation="3" Style="cursor: pointer;" Class="rounded-lg">
    <div style="position: relative;">
        @if (string.IsNullOrEmpty(Event.BannerImageUrl))
        {
            <ImagePlaceholder OnClick="HandleOnClick" Ratio="16/9" Class="rounded-t-lg" />
        }
        else
        {
            <MudCardMedia Image="@(Event.BannerImageUrl)" @onclick="@HandleOnClick" Style="aspect-ratio: 16/9; height:auto;" />
        }

        @if (Event.IsBundle)
        {
            <MudTooltip Text="Paquete" Placement="Placement.Left">
                <MudPaper Elevation="0" Class="d-flex align-center justify-center"
                          Style="position:absolute;top:8px;right:8px;width:40px;height:40px;border-radius:50%;background:var(--mud-palette-surface);border:2px solid var(--mud-palette-white);">
                    <MudIcon Icon="@Icons.Material.Outlined.Layers" Color="Color.Secondary" Size="Size.Medium" />
                </MudPaper>
            </MudTooltip>
        }
    </div>
    <MudCardContent Class="py-2 px-3" @onclick="@HandleOnClick">
        <MudGrid>
            <MudItem xs="6">
                <MudStack Spacing="1">
                    <MudTooltip Text="@(Event.EventName)">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="truncate-text"><b>@(Event.EventName)</b></MudText>
                    </MudTooltip>
                    <MudText Typo="Typo.caption">@(Event.DateTime.ToString("d MMM yyyy"))</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="6" Class="d-flex justify-end align-end">
                @if (Event.Status == AdminEventStatus.Published)
                {
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption">@L["Availability"]</MudText>
                        <MudStack Row Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Spacing="1">
                            <EventAvailability Available="@(Event.Available)" OmitTotal ExternalKey="@Event.ExternalEventKey" />
                        </MudStack>
                    </MudStack>
                }
                else
                {
                    <EventStatusChip Status="Event.Status" />
                }
            </MudItem>
        </MudGrid>
    </MudCardContent>
    @if (ShowActions)
    {
        <MudDivider />
        <MudCardActions Class="py-0">
            <MudGrid Justify="Justify.SpaceEvenly">
                <MudItem>
                    <MudTooltip Text="@L["Edit"]" Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Size="Size.Medium"
                                       Color="Color.Secondary"
                                       Disabled="@Event.IsBundle"
                                       OnClick="@(() => _navigationManager.NavigateTo($"./events/{Event.Id}/edit"))" />
                    </MudTooltip>
                </MudItem>
                <MudItem>
                    <MudTooltip Text="@L["Tickets"]" Placement="Placement.Top">
                        <MudIconButton
                            Icon="@Icons.Material.Outlined.ShoppingCart"
                            Size="Size.Medium"
                            Color="Color.Secondary"
                            Disabled="@(Event.Status != AdminEventStatus.Published || Event.ExternalEventKey is null)"
                            OnClick="@(() => _navigationManager.NavigateTo(GetBookingRoute()))" />
                    </MudTooltip>
                </MudItem>
                <MudItem>
                    <MudTooltip Text="@L["Suites"]" Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Outlined.LocalActivity"
                                       Size="Size.Medium"
                                       Color="Color.Secondary"
                                       Disabled
                                       OnClick="@(() => _navigationManager.NavigateTo($"./events/{Event.Id}/suites"))" />
                    </MudTooltip>
                </MudItem>
                <MudItem>
                    <MudTooltip Text="@L["Availability"]" Placement="Placement.Top">
                        <MudIconButton
                            Icon="@Icons.Material.Outlined.Map"
                            Size="Size.Medium"
                            Color="Color.Secondary"
                            OnClick="@(() => _navigationManager.NavigateTo($"./events/{Event.Id}/key/{Event.ExternalEventKey}/availability"))"
                            Disabled="@(Event.IsBundle || Event.Status != AdminEventStatus.Published || Event.ExternalEventKey is null)" />
                    </MudTooltip>
                </MudItem>
            </MudGrid>
        </MudCardActions>
    }
    </MudCard>

@code {
    [Parameter]
    [EditorRequired]
    public EventViewModel Event { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public bool ShowActions { get; set; } = false;

    private async Task HandleOnClick()
    {
        await OnClick.InvokeAsync();
    }

    private string GetBookingRoute()
    {
        return Event.IsBundle
            ? $"./season-pass/{Event.Id}/key/{Event.ExternalEventKey}/booking"
            : $"./events/{Event.Id}/key/{Event.ExternalEventKey}/booking";
    }
}
