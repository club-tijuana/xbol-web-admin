@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.AdminPortal.Helpers;

<MudCard Class="mb-4 bg-white" Elevation="3">
    <MudGrid Class="m-0 p-0 align-center" Justify="Justify.FlexStart">
        <MudItem xs="12" sm="6" lg="4" Class="pb-0 mb-0 d-flex">
            @if (string.IsNullOrEmpty(Banner.ImageUrl))

            {
                <ImagePlaceholder Height="95px" />
            }
            else
            {
                <img src="@Banner.ImageUrl" class="img-fluid banner-img" />
            }            
        </MudItem>
        <MudItem xs="12" sm="6" lg="4" Class="pb-0 mb-0">
            <MudText Typo="Typo.h6" Color="@Color.Secondary">@Banner.Title</MudText>
        </MudItem>
        <MudItem xs="12" sm="6" lg="4">
            <MudItem xs="12" sm="6" lg="4" Class="d-flex flex-column pb-0 mb-0 justify-center">
                @if (!string.IsNullOrWhiteSpace(Banner.Venue))
                {
                    <MudText Typo="Typo.subtitle2" Class="text-secondary-darken">@Banner.Venue</MudText>
                }
                @if (Banner.StartDateTime.HasValue)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @EventDisplayDateHelper.GetDateRange(Banner.StartDateTime, Banner.EndDateTime)
                    </MudText>
                }
            </MudItem>
        </MudItem>
    </MudGrid>
</MudCard>

@code {
    [Parameter]
    public ImageHeroBannerViewModel Banner { get; set; } = default!;

}
