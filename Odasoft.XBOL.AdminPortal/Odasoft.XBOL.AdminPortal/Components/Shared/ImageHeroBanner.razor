@using Odasoft.XBOL.AdminPortal.ViewModels.Shared
@using Odasoft.XBOL.AdminPortal.Helpers;

<MudCard Class="mb-4 bg-white" Elevation="3">
    <MudGrid Class="align-center" Justify="Justify.FlexStart">
        <MudItem xs="12" md="3" Class="d-flex">
            @if (string.IsNullOrEmpty(Banner.ImageUrl))

            {
                <ImagePlaceholder Height="95px" />
            }
            else
            {
                <MudImage Src="@Banner.ImageUrl" Height="95" ObjectPosition="ObjectPosition.Center" ObjectFit="ObjectFit.Cover" />
            }
        </MudItem>
        <MudItem xs="12" md="3">
            <MudText Typo="Typo.h6" Color="@Color.Secondary">@Banner.Title</MudText>
        </MudItem>
        <MudItem xs="12" md="3">
            @if (!string.IsNullOrWhiteSpace(Banner.Venue))
            {
                <MudText Typo="Typo.subtitle2" Class="text-secondary-darken">@Banner.Venue</MudText>
            }
            @if (Banner.StartDateTime.HasValue)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @EventDisplayDateHelper.GetDateRange(Banner.StartDateTime, Banner.EndDateTime)
                </MudText>
            }
        </MudItem>
        <MudItem xs="12" md="3" Class="d-flex justify-end pr-6">
            @if (!string.IsNullOrEmpty(Banner.ExternalKey))
            {
                <MudStack>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">Disponibilidad</MudText>
                    <EventAvailability Available="@(Banner.AvailableSeats ?? 0)" Total="@Banner.TotalSeats" ExternalKey="@Banner.ExternalKey" />
                </MudStack>
            }
        </MudItem>
    </MudGrid>
</MudCard>

@code {
    [Parameter]
    public ImageHeroBannerViewModel Banner { get; set; } = default!;

}
