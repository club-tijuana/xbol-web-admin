@using System.Linq.Expressions
@using Odasoft.XBOL.AdminPortal.Helpers
@typeparam T
@inject IStringLocalizer<AdminForm> FormL

<MudTextField T="T" Value="Value" ValueChanged="HandleValueChanged"
              Variant="Variant.Outlined"
              Margin="Margin.Dense"
              Required="@Required" RequiredError="@FormL["RequiredField"]"
              For="@For"
              @attributes="GetCombinedAttributes()" />

@code {
    [Parameter] public T? Value { get; set; }
    [Parameter] public EventCallback<T> ValueChanged { get; set; }
    [Parameter] public FieldBinding? Field { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public Expression<Func<T>>? For { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleValueChanged(T? value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
        Field?.OnChanged();
    }

    private Dictionary<string, object> GetCombinedAttributes()
    {
        var attributes = new Dictionary<string, object>();

        if (AdditionalAttributes != null)
        {
            foreach (var attr in AdditionalAttributes)
            {
                attributes[attr.Key] = attr.Value;
            }
        }

        if (Field != null)
        {
            attributes["Validation"] = Field.ValidationFor<T>();
        }

        return attributes;
    }
}
