@using System.Linq.Expressions
@using Odasoft.XBOL.AdminPortal.Helpers
@inject IStringLocalizer<AdminForm> FormL

<MudDatePicker Date="Date" DateChanged="HandleDateChanged"
               Variant="Variant.Outlined" 
               Margin="Margin.Dense"
               DateFormat="dd/MM/yyyy"
               Mask="@(new DateMask("dd/MM/yyyy"))"
               Required="@Required" RequiredError="@FormL["RequiredField"]"
               For="@For"
               @attributes="GetCombinedAttributes()" />

@code {
    [Parameter] public DateTime? Date { get; set; }
    [Parameter] public EventCallback<DateTime?> DateChanged { get; set; }
    [Parameter] public FieldBinding? Field { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public Expression<Func<DateTime?>>? For { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleDateChanged(DateTime? value)
    {
        Date = value;
        await DateChanged.InvokeAsync(value);
        Field?.OnChanged();
    }

    private Dictionary<string, object> GetCombinedAttributes()
    {
        var attributes = new Dictionary<string, object>();

        if (AdditionalAttributes != null)
        {
            foreach (var attr in AdditionalAttributes)
            {
                attributes[attr.Key] = attr.Value;
            }
        }

        if (Field != null)
        {
            attributes["Validation"] = Field.ValidationFor<DateTime?>();
        }

        return attributes;
    }
}
