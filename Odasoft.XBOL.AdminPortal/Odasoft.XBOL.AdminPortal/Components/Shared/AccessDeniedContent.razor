@inject AppLocalizer<AccessDeniedContent> L
@inject NavigationManager Navigation

<PageTitle>@L["AccessDeniedTitle"]</PageTitle>
<MudContainer Class="mt-16">
    <MudPaper Class="pa-8" Elevation="2">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" />
            <MudText Typo="Typo.h5" Align="Align.Center">@L["AccessDeniedTitle"]</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
                @L["AccessDeniedMessage"]
            </MudText>
            <MudStack Row Spacing="2">
                <MudButton Variant="Variant.Text" OnClick="GoHome">@L["AccessDeniedGoToDashboard"]</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private void GoHome()
    {
        Navigation.NavigateTo("./");
    }
}
