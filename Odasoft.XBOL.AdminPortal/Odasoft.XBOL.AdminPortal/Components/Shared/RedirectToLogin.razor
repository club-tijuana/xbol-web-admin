@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var basePath = new Uri(Navigation.BaseUri).AbsolutePath.TrimEnd('/');
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnPath = string.IsNullOrEmpty(relativePath)
            ? $"{basePath}/"
            : $"{basePath}/{relativePath}";
        var returnUrl = Uri.EscapeDataString(returnPath);
        Navigation.NavigateTo($"login?returnUrl={returnUrl}");
    }
}
