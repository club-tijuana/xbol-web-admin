@using Microsoft.JSInterop;
@using Odasoft.XBOL.AdminPortal.Components.Pages;
@using Odasoft.XBOL.AdminPortal.Components.Shared;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Models.DTO;
@using System.Text.Json;
@using System.Text.Json.Serialization;

@implements IAsyncDisposable;

@inject CartState CartState
@inject IAdminClient AdminClient;
@inject ISnackbar Snackbar;
@inject ILogger<SpotlightSeatMap> Logger;
@inject AppLocalizer<Events> L;

<LoadingContainer HasError="_error" ErrorMessage="@_errorMessage" IsLoading="_loading">
</LoadingContainer>
<div id="@ChartId" style=@($"height: {Height}")></div>

@code {
    [Inject] protected IJSRuntime JSRuntime { get; set; } = default!;

    [Parameter][EditorRequired] public string PublicKey { get; set; } = default!;
    [Parameter][EditorRequired] public string[] EventKeys { get; set; } = [];
    [Parameter][EditorRequired] public long EventId { get; set; }
    [Parameter] public string Language { get; set; } = "es";

    [Parameter]
    public IEnumerable<SeatsIoPriceResponse> Prices { get; set; } = [];

    [Parameter] public string[]? Channels { get; set; }

    [Parameter]
    public List<string> SelectedSeats { get; set; } = [];

    [Parameter]
    public EventCallback OnChartRendered { get; set; }

    [Parameter]
    public string Session { get; set; } = SESSION_NONE;

    [Parameter]
    public string Mode { get; set; } = "spotlight";

    [Parameter]
    public string? HoldToken { get; set; }

    [Parameter]
    public string Height { get; set; } = "700px";

    [Parameter]
    public bool ShowCategoryFilter { get; set; } = false;

    private const string SESSION_CONTINUE = "continue";
    private const string SESSION_NONE = "none";
    private const string SESSION_MANUAL = "manual";

    protected string ChartId => "seating-chart";

    protected IJSObjectReference? _module;
    protected IJSObjectReference? _chart;

    private DotNetObjectReference<SpotlightSeatMap>? _objRef;
    private bool _loading = true;
    private bool _error;
    private string? _errorMessage;
    private bool _isDisposed = false;

    private static long? _lastRenderedEventId;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _loading = true;
            try
            {
                _objRef = DotNetObjectReference.Create(this);
                _module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Shared/SpotlightSeatMap.razor.js");

                // Clear Seats.io session if switching events
                if (_lastRenderedEventId.HasValue && _lastRenderedEventId.Value != EventId)
                {
                    await _module.InvokeVoidAsync("clearSession");
                }
                _lastRenderedEventId = EventId;

                var options = new JsonSerializerOptions
                {
                    DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
                    PropertyNamingPolicy = JsonNamingPolicy.CamelCase
                };

                var jsonElement = JsonSerializer.SerializeToElement(Prices, options);

                var categoryFilter = new CategoryFilterSeatsIoConfig
                {
                    Enabled = ShowCategoryFilter,
                    SortBy = "price",
                    MultiSelect = true,
                    ZoomOnSelect = true
                };

                var config = new
                {
                    publicKey = PublicKey,
                    events = EventKeys,
                    session = Session,
                    holdToken = HoldToken,
                    pricing = jsonElement,
                    channels = Channels,
                    categoryFilter = categoryFilter,
                    language = Language,
                    mode = Mode,
                    selectedObjects = SelectedSeats
                };

                _chart = await _module.InvokeAsync<IJSObjectReference>("renderChart", ChartId, config, _objRef);

                await OnChartRendered.InvokeAsync();

                // Only re-select programmatically when starting from a clean
                // session. With session="manual" the chart already renders the
                // seats held by the token; calling trySelectObjects on them
                // raises "object not in selectable status" from seats.io.
                // if (Session == SESSION_NONE)
                // {
                //     await TrySelectObjectsAsync(SelectedSeats.ToArray());
                // }
            }
            catch (Exception ex)
            {
                _error = true;
                _errorMessage = "Error al cargar el mapa de asientos";

                Logger.LogError(ex, "SeatingChart error");
                StateHasChanged();
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task HandleSeatSelected(string seatId, decimal price, long priceListItemId, string? category, string? selectedTicketType, decimal originalPrice, List<SeatFeeInfo> fees)
    {

    }

    [JSInvokable]
    public async Task HandleSeatDeselected(string seatId)
    {

    }

    public async ValueTask FocusSeatAsync(string seatId)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("focusSeat", _chart, seatId);
        }
    }

    public async ValueTask UnfocusSeatAsync(string seatId)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("unfocusSeat", _chart, seatId);
        }
    }

    public async ValueTask DoSelectObjects(string[] seats)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeAsync<string[]>("doSelectObjects", _chart, seats);
        }
    }

    public async ValueTask DeselectSeatAsync(string seatId)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("deselectSeat", _chart, seatId);
        }
    }

    public async ValueTask DeselectSeatsAsync(string[] seats)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("deselectSeats", _chart, seats);
        }
    }

    public async ValueTask ClearSelection()
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("clearSelection", _chart);
        }
    }

    public async ValueTask ChangeConfig(object config)
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("changeConfig", _chart, config);
        }
    }

    public async ValueTask FocusFilteredCategories()
    {
        if (!_isDisposed && _module is not null && _chart is not null)
        {
            await _module.InvokeVoidAsync("focusFilteredCategories", _chart);
        }
    }

    public async ValueTask TrySelectObjectsAsync(string[] seats)
    {
        if (_isDisposed || _module is null || _chart is null)
            return;

        await _module.InvokeAsync<string[]>("trySelectObjects", _chart, seats, _objRef);
    }

    public virtual async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        GC.SuppressFinalize(this);
        if (_module is not null && _chart is not null)
        {
            try { await _module.InvokeVoidAsync("destroyChart", _chart); }
            catch (JSDisconnectedException) { }
        }

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
