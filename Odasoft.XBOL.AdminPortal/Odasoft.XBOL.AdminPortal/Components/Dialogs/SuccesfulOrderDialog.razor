@inject AppLocalizer<SuccesfulOrderDialog> L

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Color="Color.Success"></MudIcon>
            <MudText Typo="Typo.body2">@L["SuccessfulPurchase"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudGrid Style="min-width: 455px;" Spacing="6" Class="px-8 pb-6">
            <MudItem xs="12">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="text-uppercase">@L["TrackingNumber"]</MudText>
                    <MudText Typo="Typo.h5">CAL178700</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="text-uppercase">@L["Phone"]</MudText>
                    <MudText Typo="Typo.body1">+52 (664) 123 4567</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="text-uppercase">@L["Email"]</MudText>
                    <MudText Typo="Typo.body1">juanperez@gmail.com</MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>

