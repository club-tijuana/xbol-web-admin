@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Mail
@using Odasoft.XBOL.AdminPortal.Services.Contracts
@using Odasoft.XBOL.Business
@inject IAuthService AuthService
@inject AppLocalizer<ForgotPasswordDialog> L

<MudDialog ActionsClass="mt-2 d-flex justify-center flex-grow-1" TitleClass="mud-typography-h5 pb-2" Style="width: 330px; max-width: calc(100vw - 32px);">
    <DialogContent>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-1 py-1 bg-primary-lighten rounded">
            @L["Instructions"]
        </MudText>

        <MudForm @ref="_form" @bind-IsValid="_isFormValid" Class="mt-2">
            <MudTextField @bind-Value="_request.Email"
                          Label="@L["Email"]"
                          Variant="Variant.Outlined"
                          Required="true"
                          Margin="Margin.Dense"
                          Immediate="true"
                          InputType="InputType.Email"
                          RequiredError="@L["EmailRequired"]"
                          Validation="@(new Func<string, IEnumerable<string>>(ValidateEmail))"
                          OnKeyDown="SubmitOnEnterAsync"
                          autocomplete="username" />
        </MudForm>

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                @_successMessage
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Tertiary"
                   Class="mb-4"
                   ButtonType="ButtonType.Button"
                   Disabled="@(!CanSubmit)"
                   OnClick="SubmitAsync">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Class="me-2" />
            @L["Submit"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = default!;
    private readonly ForgotPasswordRequest _request = new();
    private FormContext _formContext = default!;
    private bool _isFormValid;
    private bool _isSubmitting;
    private string? _successMessage;
    private string? _errorMessage;

    private bool CanSubmit => _isFormValid && !_isSubmitting;

    protected override void OnInitialized()
    {
        _formContext = new FormContext(StateHasChanged);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _formContext.SetForm(_form);
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting)
            return;

        _successMessage = null;
        _errorMessage = null;

        if (!await _formContext.ValidateAsync())
            return;

        _isSubmitting = true;

        try
        {
            await AuthService.ForgotPasswordAsync(_request.Email ?? string.Empty);
            _successMessage = L["Success"];
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _formContext.HandleApiException(ex);
            _errorMessage = ex.Result.Detail ?? ex.Result.Title ?? L["Failed"];
        }
        catch
        {
            _errorMessage = L["Failed"];
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task SubmitOnEnterAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await SubmitAsync();
    }

    private IEnumerable<string> ValidateEmail(string value)
    {
        var email = value?.Trim();

        if (string.IsNullOrWhiteSpace(email))
        {
            yield return L["EmailRequired"];
            yield break;
        }

        if (!IsValidEmail(email))
            yield return L["EmailInvalid"];
    }

    private static bool IsValidEmail(string email)
    {
        try
        {
            var address = new MailAddress(email);
            return string.Equals(address.Address, email, StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }
}
