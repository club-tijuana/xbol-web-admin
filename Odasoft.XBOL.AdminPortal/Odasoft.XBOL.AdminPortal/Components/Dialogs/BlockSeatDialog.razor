@using MudBlazor.Utilities
@using Odasoft.XBOL.AdminPortal.Resources
@using Odasoft.XBOL.Business
@inject IAdminClient AdminClient
@inject ISnackbar Snackbar
@inject IStringLocalizer<AdminForm> FormL
@inject AppLocalizer<BlockSeatDialog> L

<BaseDialog Title="@L["Block"].Value">
    <ChildContent>
        <MudText Typo="Typo.caption" Color="Color.Error" Class="mb-2">@L["RequiredFieldsNote"]</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">@L["SeatCountMessage", SeatKeys.Count]</MudText>
        <MudForm @ref="_form">
            <MudStack Spacing="4">
                <AdminTextField @bind-Value="_reason" Label="@L["ReasonLabel"].Value"
                                Placeholder="@L["BlockReasonPlaceholder"].Value"
                                Field="@_formContext.Field("Reason")" Required />
                <MudColorPicker @bind-Value="_color" Label="@L["ColorLabel"].Value" Variant="Variant.Outlined"
                                Required RequiredError="@FormL["RequiredField"]"
                                Validation="@(_formContext.Field("Color").ValidationFor<MudColor>())"
                                ColorPickerMode="ColorPickerMode.HEX" />
            </MudStack>
        </MudForm>
    </ChildContent>
    <Actions>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Lock"
                   Disabled="_formContext.IsSaving"
                   OnClick="SubmitAsync" Class="text-uppercase">@L["Block"]</MudButton>
    </Actions>
</BaseDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<string> SeatKeys { get; set; } = [];
    [Parameter] public string ExternalKey { get; set; } = string.Empty;

    private MudForm _form = default!;
    private FormContext _formContext = default!;
    private string? _reason;
    private MudColor _color = new("#FF0000");

    protected override void OnInitialized()
    {
        _formContext = new FormContext(StateHasChanged);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) _formContext.SetForm(_form);
    }

    private async Task SubmitAsync()
    {
        if (!await _formContext.ValidateAsync()) return;

        _formContext.SetSaving(true);
        try
        {
            var request = new BlockSeatsRequest
            {
                SeatKeys = SeatKeys,
                Reason = _reason!,
                Color = _color.ToString(MudColorOutputFormats.Hex),
            };
            await AdminClient.BlockSeatsAsync(ExternalKey, request);
            Snackbar.Add(L["SeatsBlocked"].Value, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ApiException<ProblemDetails> ex)
        {
            _formContext.HandleApiException(ex);
            Snackbar.Add(ex.Result.Title ?? L["ErrorBlockingSeats"].Value, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add(L["ErrorBlockingSeats"].Value, Severity.Error);
        }
        finally
        {
            _formContext.SetSaving(false);
        }
    }
}
