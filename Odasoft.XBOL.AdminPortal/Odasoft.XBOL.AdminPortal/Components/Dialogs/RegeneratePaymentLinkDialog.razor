@using Microsoft.Extensions.Options
@using Odasoft.XBOL.Business
@using Odasoft.XBOL.AdminPortal.Helpers
@using Odasoft.XBOL.AdminPortal.Components.Pages
@using Odasoft.XBOL.Common.Options

@inject AppLocalizer<Events> L
@inject IDialogService _dialogService
@inject IOptions<PaymentLinkOptions> PaymentLinkOptions
@inject IOptions<Odasoft.XBOL.Common.Options.LocalizationOptions> LocalizationOptions

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.subtitle2">¿Deseas regenerar el link de pago?</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid>
            <MudItem xs="12" class="d-flex align-center">
                <MudTextField Label="Fecha de expiración"
                              Value="@ExpirationDateText"
                              ReadOnly="true"
                              @onclick="OpenDateTimeDialog"
                              Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">CANCELAR</MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!HasValidExpiration)"
                   OnClick="Confirm">
            Confirmar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private PaymentLinkRequest _request = new();

    private DateTime? ExpirationDate { get; set; }

    private string ExpirationDateText =>
        ExpirationDate?.ToString("dd/MM/yy - HH:mm 'hrs'") ?? "";

    private bool HasValidExpiration =>
        _request.ExpiresAt > DateTimeOffset.UtcNow;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    protected override void OnInitialized()
    {
        SetDefaultExpiration();
    }

    private void Confirm()
    {
        if (!HasValidExpiration)
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(_request));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OpenDateTimeDialog()
    {
        var parameters = new DialogParameters
        {
            ["Value"] = ExpirationDate,
            ["Title"] = "Fecha de expiración"
        };

        var options = new DialogOptions
        {
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            NoHeader = true
        };

        var dialog = await _dialogService.ShowAsync<DateTimeDialog>(
            "",
            parameters,
            options
        );

        var result = await dialog.Result;

        if (!result.Canceled && result.Data is DateTime selected)
        {
            ExpirationDate = selected;
            _request.ExpiresAt = PaymentLinkDateTime.ToConfiguredOffset(selected, LocalizationOptions.Value);
        }
    }

    private void SetDefaultExpiration()
    {
        var expiration = PaymentLinkDateTime.CreateDefaultExpiration(PaymentLinkOptions.Value, LocalizationOptions.Value);
        _request.ExpiresAt = expiration;
        ExpirationDate = PaymentLinkDateTime.ToDisplayDateTime(expiration, LocalizationOptions.Value);
    }
}
