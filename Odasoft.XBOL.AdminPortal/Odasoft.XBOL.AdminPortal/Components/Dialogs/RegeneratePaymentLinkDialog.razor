@using Odasoft.XBOL.Business
@using Odasoft.XBOL.AdminPortal.Components.Pages

@inject AppLocalizer<Events> L
@inject IDialogService _dialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.subtitle2">¿Deseas regenerar el link de pago?</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid>
            <MudItem xs="12" class="d-flex align-center">
                <MudTextField Label="Fecha de expiración"
                              Value="@ExpirationDateText"
                              ReadOnly="true"
                              @onclick="OpenDateTimeDialog"
                              Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">CANCELAR</MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm">
            Confirmar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private PaymentLinkRequest _request = new();

    private DateTime? ExpirationDate { get; set; } = DateTime.Now;

    private string ExpirationDateText =>
        ExpirationDate?.ToString("dd/MM/yy - HH:mm 'hrs'") ?? "";

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(_request));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OpenDateTimeDialog()
    {
        var parameters = new DialogParameters
        {
            ["Value"] = ExpirationDate,
            ["Title"] = "Fecha de expiración"
        };

        var options = new DialogOptions
        {
            CloseButton = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            NoHeader = true
        };

        var dialog = await _dialogService.ShowAsync<DateTimeDialog>(
            "",
            parameters,
            options
        );

        var result = await dialog.Result;

        if (!result.Canceled && result.Data is DateTime selected)
        {
            ExpirationDate = selected;
            _request.ExpiresAt = selected;
        }
    }
}
