<style>
    .mud-dialog-title button.mud-icon-button {
        color: var(--mud-palette-secondary) !important;
    }
</style>

<MudDialog Class="@Class" ActionsClass="@ActionsClass" TitleClass="pb-2" Style="width: 400px; max-width: 100vw;">
    <TitleContent>
        @TitleContent
    </TitleContent>
    <DialogContent>
        @ChildContent
    </DialogContent>
    <DialogActions>
        @Actions
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public RenderFragment? TitleContent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public string Class { get; set; } = "py-4 pr-4";

    [Parameter]
    public string ActionsClass { get; set; } = "mt-2 d-flex justify-center flex-grow-1";
}
