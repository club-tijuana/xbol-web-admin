@using Odasoft.XBOL.AdminPortal.Services.Contracts
@inject IAuthService AuthService
@inject AntiforgeryStateProvider Antiforgery
@inject BrowserFormPostJsInterop FormPost
@inject AppLocalizer<ResetPasswordDialog> L

<MudDialog ActionsClass="mt-2 d-flex justify-center flex-grow-1" TitleClass="mud-typography-h5 pb-2" Style="width: 360px; max-width: calc(100vw - 32px);">
    <DialogContent>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-1 py-1 bg-primary-lighten rounded">
            @L["Instructions"]
        </MudText>

        @if (_isVerifying)
        {
            <div class="d-flex justify-center py-4">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isFormValid" Class="mt-2">
                <MudTextField @bind-Value="_newPassword"
                              Class="@PasswordInputClass"
                              Label="@L["NewPassword"]"
                              Variant="Variant.Outlined"
                              InputType="@_passwordInput"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_passwordInputIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              AdornmentAriaLabel="@L["TogglePasswordVisibility"]"
                              Required="true"
                              Margin="Margin.Dense"
                              Immediate="true"
                              RequiredError="@L["NewPasswordRequired"]"
                              Validation="@(new Func<string, IEnumerable<string>>(ValidatePassword))"
                              OnKeyDown="SubmitOnEnterAsync"
                              autocomplete="new-password" />

                <MudTextField @bind-Value="_confirmPassword"
                              Class="@PasswordInputClass"
                              Label="@L["ConfirmPassword"]"
                              Variant="Variant.Outlined"
                              InputType="@_passwordInput"
                              Required="true"
                              Margin="Margin.Dense"
                              Immediate="true"
                              RequiredError="@L["ConfirmPasswordRequired"]"
                              Validation="@(new Func<string, IEnumerable<string>>(ValidateConfirmPassword))"
                              OnKeyDown="SubmitOnEnterAsync"
                              autocomplete="new-password" />
            </MudForm>
        }

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                @_successMessage
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Tertiary"
                   Class="mb-4"
                   ButtonType="ButtonType.Button"
                   Disabled="@(!CanSubmit)"
                   OnClick="SubmitAsync">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" Class="me-2" />
            @L["Submit"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = default!;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _email = string.Empty;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
    private bool _isVerifying = true;
    private bool _isFormValid;
    private bool _isSubmitting;
    private bool _isValidCode;
    private bool _isShow;
    private string? _successMessage;
    private string? _errorMessage;
    private InputType _passwordInput = InputType.Password;

    [Parameter]
    public string OobCode { get; set; } = string.Empty;

    [Parameter]
    public string? ReturnUrl { get; set; }

    private bool CanSubmit =>
        _isValidCode
        && _isFormValid
        && !_isVerifying
        && !_isSubmitting
        && string.IsNullOrWhiteSpace(_successMessage);
    private string PasswordInputClass => _isShow ? "pb-4 reset-password-input show" : "pb-4 reset-password-input";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(OobCode))
        {
            _errorMessage = L["InvalidLink"];
            _isVerifying = false;
            return;
        }

        try
        {
            _email = await AuthService.VerifyPasswordResetAsync(OobCode);
            _isValidCode = true;
        }
        catch
        {
            _errorMessage = L["InvalidLink"];
        }
        finally
        {
            _isVerifying = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting || !_isValidCode || _isVerifying || !string.IsNullOrWhiteSpace(_successMessage))
            return;

        _successMessage = null;
        _errorMessage = null;

        await _form.ValidateAsync();
        if (!_form.IsValid || string.IsNullOrWhiteSpace(_email))
            return;

        _isSubmitting = true;

        var result = await AuthService.ResetPasswordAsync(_email, OobCode, _newPassword);

        if (!result.Succeeded || string.IsNullOrWhiteSpace(result.IdToken))
        {
            _errorMessage = L["Failed"];
            _isSubmitting = false;
            return;
        }

        _successMessage = L["Success"];

        var antiforgery = Antiforgery.GetAntiforgeryToken();
        if (antiforgery is null)
        {
            _errorMessage = L["Failed"];
            _isSubmitting = false;
            return;
        }

        await FormPost.PostAsync("auth/login", new Dictionary<string, string?>
        {
            [antiforgery.FormFieldName] = antiforgery.Value,
            ["idToken"] = result.IdToken,
            ["returnUrl"] = ReturnUrl
        });
    }

    private async Task SubmitOnEnterAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await SubmitAsync();
    }

    private IEnumerable<string> ValidatePassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            yield return L["NewPasswordRequired"];
            yield break;
        }

        if (value.Length < 8)
            yield return L["PasswordTooShort"];

        if (!value.Any(char.IsUpper))
            yield return L["PasswordUppercaseRequired"];

        if (!value.Any(char.IsDigit))
            yield return L["PasswordNumberRequired"];

        if (!value.Any(ch => !char.IsLetterOrDigit(ch)))
            yield return L["PasswordSymbolRequired"];
    }

    private IEnumerable<string> ValidateConfirmPassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            yield return L["ConfirmPasswordRequired"];
            yield break;
        }

        if (!string.Equals(value, _newPassword, StringComparison.Ordinal))
            yield return L["PasswordMismatch"];
    }

    private void TogglePasswordVisibility()
    {
        if (_isShow)
        {
            _isShow = false;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _isShow = true;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }
}
