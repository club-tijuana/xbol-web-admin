@using Odasoft.XBOL.AdminPortal.Components.Pages;
@using Odasoft.XBOL.AdminPortal.Components.Shared;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Common.Constants;

@implements IDisposable
@inject CartState CartState
@inject ISnackbar Snackbar
@inject AppLocalizer<Events> L

<SeatList Items="CartState.SelectedSeats"
          Chart="Chart"
          Title="TOTAL"
          Total="@CartState.TotalPrice.ToString(FormatConstants.CURRENCY)"
          OnClearAll="ClearAllCallback">
    <HeaderLeadingContent>
        @if (AllowPartialUpdate)
        {
            <MudCheckBox T="bool?"
                         Value="@CartState.AllSeatsSelected"
                         ValueChanged="@OnSelectAllChanged"
                         Color="Color.Primary"
                         TriState="true" />
        }
    </HeaderLeadingContent>
    <RowLeadingContent Context="item">
        @if (AllowPartialUpdate)
        {
            <MudCheckBox T="bool"
                         Value="@item.IsSelected"
                         ValueChanged="@( (bool isChecked) => OnItemCheckedChanged(item, isChecked) )"
                         Color="Color.Primary"
                         Disabled="@(item.IsSold == true)" />
        }
    </RowLeadingContent>
    <RowActionContent Context="item">
        @if (AllowPartialUpdate)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Price.ToString(FormatConstants.CURRENCY)</MudText>
            <MudIcon Class="@(item.IsSold == true ? "" : "invisible")" Icon="@Icons.Material.Filled.PriceCheck" Color="Color.Tertiary" />
        }
        else if (AllowRemoval)
        {
            <SeatListActions Price="@item.Price"
                             Tooltip="@L["Seats_RemoveSeat"]"
                             OnRemove="@(() => RemoveSeat(item.SeatId))" />
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Price.ToString(FormatConstants.CURRENCY)</MudText>
        }
    </RowActionContent>
    <FooterContent>
        @if (CartState.HoldExpirationTime.HasValue)
        {
            <MudStack Row="true" Justify="Justify.Center" Class="pa-4">
                <MudText Color="@(_timeLeft.TotalMinutes < 2 ? Color.Error : Color.Default)" Typo="Typo.caption">
                    @string.Format(L["Seats_TimeRemaining"], _timeLeft.ToString(@"mm\:ss"))
                </MudText>
            </MudStack>
        }
    </FooterContent>
</SeatList>

@code {
    [Parameter]
    public SeatingChart? Chart { get; set; }
    [Parameter]
    public bool AllowRemoval { get; set; } = true;
    [Parameter]
    public bool AllowPartialUpdate { get; set; }

    private System.Timers.Timer? _timer;
    private TimeSpan _timeLeft = TimeSpan.Zero;

    private EventCallback ClearAllCallback =>
        AllowRemoval && !AllowPartialUpdate && CartState.SelectedSeats.Any()
            ? EventCallback.Factory.Create(this, RemoveAllSeats)
            : default;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) => UpdateTimer();
        _timer.Start();
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
        _timer?.Stop();
        _timer?.Dispose();
    }

    private void UpdateTimer()
    {
        if (CartState.HoldExpirationTime.HasValue)
        {
            _timeLeft = CartState.HoldExpirationTime.Value - DateTime.UtcNow;
            if (_timeLeft.TotalSeconds <= 0)
            {
                _timeLeft = TimeSpan.Zero;
                Snackbar.Add(L["Seats_SessionExpired"], Severity.Warning);
                _timer?.Stop();
            }
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task RemoveSeat(string seatId)
    {
        if (Chart is not null)
        {
            await Chart.DeselectSeatAsync(seatId);
        }
        else
        {
            CartState.RemoveSelectedSeat(seatId);
        }
    }

    private async Task RemoveAllSeats()
    {
        if (Chart is not null)
        {
            await Chart.ClearSelection();
        }
        else
        {
            var seats = CartState.SelectedSeats.Select(x => x.SeatId).ToList();
            foreach (var item in seats)
            {
                CartState.RemoveSelectedSeat(item);
            }
        }
    }

    private async Task OnSelectAllChanged(bool? value)
    {
        bool isChecked = value ?? false;

        if (isChecked == true)
        {
            foreach (var item in CartState.SelectedSeats.ToList())
            {
                await AddSeat(item);
            }
        }
        else if (isChecked == false)
        {
            await RemoveAllSeats();
        }
    }

    private async Task AddSeat(SeatInfo seat)
    {
        if (Chart is not null)
        {
            await Chart.TrySelectObjectsAsync([seat.SeatId]);
        }
        else
        {
            CartState.AddSelectedSeat(seat);
        }
    }

    private async Task OnItemCheckedChanged(SeatInfo item, bool isChecked)
    {
        if (isChecked)
        {
            await AddSeat(item);
        }
        else
        {
            await RemoveSeat(item.SeatId);
        }
    }
}
