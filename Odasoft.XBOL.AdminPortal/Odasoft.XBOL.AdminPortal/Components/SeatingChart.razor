@using Microsoft.JSInterop
@using Odasoft.XBOL.AdminPortal.States
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject CartState CartState
@inject IAdminApiClient AdminApiClient

@if (_error)
{
    <MudAlert Severity="Severity.Error" Class="ma-4">@_errorMessage</MudAlert>
}
else
{
    <div id="@ChartId" style="height: 750px"></div>
}

@code {
    [Parameter]
    [EditorRequired]
    public string WorkspaceKey { get; set; }

    [Parameter]
    [EditorRequired]
    public string EventKey { get; set; }

    [Parameter] public string[]? Channels { get; set; }

    [Parameter]
    [EditorRequired]
    public long EventId { get; set; }

    private string ChartId = $"chart-{Guid.NewGuid()}";

    private DotNetObjectReference<SeatingChart>? _objRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _chart;
    private bool _error;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _objRef = DotNetObjectReference.Create(this);
                _module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./Components/SeatingChart.razor.js");

                ICollection<SeatPriceDTO> seatPrices = await AdminApiClient.GetEventSeatPricesAsync(EventId);

                var prices = seatPrices
                .GroupBy(item => item.Price)
                .Select(group => new
                {
                    objects = group.Select(x => x.SeatKey).ToList(),
                    price = group.Key
                }).ToList();

                var config = new
                {
                    workspaceKey = WorkspaceKey,
                    @event = EventKey,
                    session = "continue",
                    pricing = prices,
                    channels = Channels
                };

                _chart = await _module.InvokeAsync<IJSObjectReference>("renderChart", ChartId, config, _objRef);
            }
            catch (Exception ex)
            {
                _error = true;
                _errorMessage = "Error al cargar el mapa de asientos";
                Console.WriteLine($"SeatingChart error: {ex.Message}");
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task HandleSeatSelected(string seatId, int price, string? category = null)
    {
        SeatInfo seat = new SeatInfo
        {
            SeatId = seatId,
            Price = price,
            Category = category
        };

        CartState.AddSelectedSeat(seat);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleSeatDeselected(string seatId)
    {
        CartState.RemoveSelectedSeat(seatId);
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask<string?> GetHoldTokenAsync()
    {
        if (_module is null || _chart is null)
            return null;

        return await _module.InvokeAsync<string?>("getHoldToken", _chart);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null && _chart is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroyChart", _chart);
            }
            catch (JSDisconnectedException)
            {
                // Ignore - circuit is already disconnected
            }
        }

        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore - circuit is already disconnected
            }
        }

        _objRef?.Dispose();
        CartState.OnChange -= StateHasChanged;
    }
}
