@using Microsoft.JSInterop;
@using Odasoft.XBOL.AdminPortal.Components.Pages;
@using Odasoft.XBOL.AdminPortal.Components.Shared;
@using Odasoft.XBOL.AdminPortal.States;
@using Odasoft.XBOL.Business;
@using Odasoft.XBOL.Models.DTO;
@using System.Text.Json;
@using System.Text.Json.Serialization;

@inherits SeatsioChartBase

@inject CartState CartState
@inject IAdminClient AdminClient;
@inject ISnackbar Snackbar;
@inject ILogger<SeatingChart> Logger;
@inject AppLocalizer<Events> L;

<LoadingContainer HasError="_error" ErrorMessage="@_errorMessage" IsLoading="_loading">
    <PriceFilter Chart="this" Prices="Prices" />
</LoadingContainer>
<div id="@ChartId" style="height: 700px"></div>

@code {
    [Parameter]
    public IEnumerable<SeatsIoPriceResponse> Prices { get; set; } = [];

    [Parameter] public string[]? Channels { get; set; }

    [Parameter]
    public List<string> SelectedSeats { get; set; } = [];

    [Parameter]
    public EventCallback OnChartRendered { get; set; }

    [Parameter]
    public string Session { get; set; } = SESSION_NONE;

    [Parameter]
    public string? HoldToken { get; set; }

    private const string SESSION_CONTINUE = "continue";
    private const string SESSION_NONE = "none";
    private const string SESSION_MANUAL = "manual";

    protected override string ChartId => "event-manager";

    private DotNetObjectReference<SeatingChart>? _objRef;
    private bool _loading = true;
    private bool _error;
    private string? _errorMessage;

    private static long? _lastRenderedEventId;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _loading = true;
            try
            {
                _objRef = DotNetObjectReference.Create(this);
                _module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./Components/SeatingChart.razor.js");

                // Clear Seats.io session if switching events
                if (_lastRenderedEventId.HasValue && _lastRenderedEventId.Value != EventId)
                {
                    await _module.InvokeVoidAsync("clearSession");
                }
                _lastRenderedEventId = EventId;

                var options = new JsonSerializerOptions
                {
                    DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
                    PropertyNamingPolicy = JsonNamingPolicy.CamelCase
                };

                var jsonElement = JsonSerializer.SerializeToElement(Prices, options);

                var categoryFilter = new CategoryFilterSeatsIoConfig
                {
                    Enabled = true,
                    SortBy = "price",
                    MultiSelect = true,
                    ZoomOnSelect = true
                };

                var config = new
                {
                    secretKey = SecretKey,
                    @event = EventKey,
                    session = Session,
                    holdToken = HoldToken,
                    pricing = jsonElement,
                    channels = Channels,
                    categoryFilter = categoryFilter,
                    language = Language,
                    mode = "createOrder"
                };

                _chart = await _module.InvokeAsync<IJSObjectReference>("renderChart", ChartId, config, _objRef);

                // Only re-select programmatically when starting from a clean
                // session. With session="manual" the chart already renders the
                // seats held by the token; calling trySelectObjects on them
                // raises "object not in selectable status" from seats.io.
                if (Session == SESSION_NONE)
                {
                    await TrySelectObjectsAsync(SelectedSeats.ToArray());
                }
            }
            catch (Exception ex)
            {
                _error = true;
                _errorMessage = "Error al cargar el mapa de asientos";

                Logger.LogError(ex, "SeatingChart error");
                StateHasChanged();
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task NotifyError(string message)
    {
        Snackbar.Add(message, Severity.Warning);
    }

    [JSInvokable]
    public async Task HandleSeatSelected(string seatId, decimal price, long priceListItemId, string? category = null, string? selectedTicketType = null)
    {
        SeatInfo seat = new SeatInfo
        {
            SeatId = seatId,
            Price = price,
            PriceListItemId = priceListItemId,
            Category = category,
            SelectedTicketType = selectedTicketType,
            IsSelected = true
        };

        CartState.AddSelectedSeat(seat);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleSeatDeselected(string seatId)
    {
        CartState.RemoveSelectedSeat(seatId);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void HandleHoldSucceeded(List<string> objects, object ticketTypes)
    {
        // Valid holds confirmed by Seats.io
        CartState.SetHoldBusyState(false);
    }

    [JSInvokable]
    public void HandleHoldFailed(List<string> objects, object ticketTypes)
    {
        CartState.SetHoldBusyState(false);
        InvokeAsync(() => Snackbar.Add(L["Seats_HoldFailed"], Severity.Error));
    }

    [JSInvokable]
    public void HandleSessionExpired()
    {
        CartState.ClearCart();
        CartState.ClearTokenAsync();
    }

    [JSInvokable]
    public void HandleSessionInitialized(string holdToken, int expiresInSeconds)
    {
        CartState.SetHoldToken(holdToken, expiresInSeconds);
    }

    [JSInvokable]
    public void HandleHoldCallsInProgress()
    {
        CartState.SetHoldBusyState(true);
    }

    [JSInvokable]
    public void HandleHoldCallsComplete()
    {
        CartState.SetHoldBusyState(false);
    }

    public async ValueTask<string?> GetHoldTokenAsync()
    {
        if (_module is null || _chart is null)
            return null;

        return await _module.InvokeAsync<string?>("getHoldToken", _chart);
    }

    public async ValueTask<string[]> GetSelectedSeatsAsync()
    {
        if (_module is null || _chart is null)
            return [];

        return await _module.InvokeAsync<string[]>("getSelectedSeats", _chart);
    }

    public async ValueTask TrySelectObjectsAsync(string[] seats)
    {
        if (_module is null || _chart is null)
            return;

        await _module.InvokeAsync<string[]>("trySelectObjects", _chart, seats, _objRef);
    }

    public async ValueTask DoSelectObjectsAsync(string[] seats)
    {
        if (_module is null || _chart is null)
            return;

        await _module.InvokeAsync<string[]>("doSelectObjects", _chart, seats, _objRef);
    }

    public async ValueTask DeselectSeatsAsync(IEnumerable<string> seats)
    {
        if (_module is null || _chart is null)
            return;

        await _module.InvokeVoidAsync("deselectSeats", _chart, seats);
    }

    public override async ValueTask DisposeAsync()
    {
        await base.DisposeAsync();
        _objRef?.Dispose();
        CartState.OnChange -= StateHasChanged;
    }
}
