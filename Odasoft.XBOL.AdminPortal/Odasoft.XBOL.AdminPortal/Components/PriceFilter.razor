@using Odasoft.XBOL.Business;

<div class="d-flex mb-2">
    <MudNumericField @bind-Value="SelectedMinPrice" Class="mr-2" Label="Precio Mínimo" Variant="Variant.Outlined" Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.AttachMoney" DebounceInterval="_interval" OnDebounceIntervalElapsed="UpdateFilteredCategories"
                     ShrinkLabel Margin="Margin.Dense" Immediate="false" />

    <MudNumericField @bind-Value="SelectedMaxPrice" Label="Precio Máximo" Variant="Variant.Outlined" Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.AttachMoney" DebounceInterval="_interval" OnDebounceIntervalElapsed="UpdateFilteredCategories"
                     ShrinkLabel Margin="Margin.Dense" Immediate="false" />
</div>

@code {
    [Parameter]
    public SeatingChart? Chart { get; set; }

    [Parameter]
    public IEnumerable<SeatsIoPriceResponse> Prices { get; set; } = [];

    private int _interval = 500;

    private decimal _minPrice = 100;
    private decimal _maxPrice = 1000;

    public int SelectedMaxPrice { get; set; }

    public int SelectedMinPrice { get; set; }

    protected override void OnInitialized()
    {
        if (Prices == null || !Prices.Any())
        {
            _maxPrice = 0;
            _minPrice = 0;
        }
        else
        {
            _maxPrice = Prices.Max(p => p.Price ?? p.TicketTypes?.Select(t => t.Price).DefaultIfEmpty(0).Max() ?? 0);
            _minPrice = Prices.Min(p => p.Price ?? p.TicketTypes?.Select(t => t.Price).DefaultIfEmpty(0).Min() ?? 0);
        }

        SelectedMaxPrice = (int)_maxPrice;
        SelectedMinPrice = (int)_minPrice;
    }

    public async Task UpdateFilteredCategories()
    {
        if (Chart is null)
            return;

        var filteredCategories = Prices
            .Where(x => x.Category is not null)
            .Where(c => (c.Price >= SelectedMinPrice && c.Price <= SelectedMaxPrice) || (c.TicketTypes?.Any(x => x.Price >= SelectedMinPrice && x.Price <= SelectedMaxPrice) ?? false))
            .Select(c => c.Category)
            .ToArray();

        await Chart.ChangeConfig(new { filteredCategories = filteredCategories });

        await Chart.FocusFilteredCategories();
    }
}
