  "components": {
    "schemas": {
      "BookingRequest": {
        "required": [
          "eventId",
          "holdToken",
          "seats"
        ],
        "type": "object",
        "properties": {
          "seats": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "holdToken": {
            "type": "string"
          },
          "eventId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "BookingResult": {
        "type": "object",
        "properties": {
          "bookingId": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "tickets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EventListItem": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int64"
          },
          "scheduledStartDate": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "venueMapId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int64"
          },
          "venueName": {
            "type": "string",
            "nullable": true
          },
          "externalEventKey": {
            "type": "string",
            "nullable": true
          },
          "availableSeats": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          },
          "totalSeats": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PagedResponseOfEventListItem": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EventListItem"
            },
            "nullable": true
          },
          "totalCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "SeatPriceDTO": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number",
            "format": "double"
          },
          "seatKey": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VenueListItem": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VenueMapListItem": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int64"
          },
          "venueId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "externalMapKey": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
