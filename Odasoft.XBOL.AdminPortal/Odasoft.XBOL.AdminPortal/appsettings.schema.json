{
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/appsettings.json"
    }
  ],
  "properties": {
    "AdminApiClient": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "BaseAddress": {
          "type": "string",
          "description": "Base URL for the Admin API"
        }
      },
      "description": "Admin API client settings"
    },
    "Authentication": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "AllowedUsers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Email": {
                "type": "string",
                "description": "User email address"
              },
              "Password": {
                "type": "string",
                "description": "User password"
              }
            }
          },
          "description": "List of users allowed to log in to the admin portal"
        }
      },
      "description": "Portal authentication settings"
    },
    "SeatsIo": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "SecretKey": {
          "type": "string",
          "description": "Seats.io workspace secret key"
        }
      },
      "description": "Seats.io integration settings"
    },
    "Hosting": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "PathBase": {
          "type": [
            "string",
            "null"
          ],
          "description": "Public path prefix when hosted behind a reverse proxy (e.g. \u0022/admin\u0022). Leave empty when serving at the site root."
        },
        "ForwardedHeaders": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "Enabled": {
              "type": "boolean",
              "description": "Enable ForwardedHeadersMiddleware to honor X-Forwarded-Proto, X-Forwarded-Host, and X-Forwarded-For from the reverse proxy."
            },
            "KnownProxies": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Known proxy IP addresses allowed to set forwarded headers. Leave empty in container/ingress deployments to clear the defaults and trust any upstream (safe when the container is only reachable via the proxy)."
            },
            "KnownNetworks": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Known proxy networks in CIDR notation (e.g. \u002210.0.0.0/8\u0022) allowed to set forwarded headers. Leave empty to clear defaults."
            }
          },
          "description": "Forwarded headers handling for reverse-proxy deployments. Disabled by default."
        }
      },
      "description": "Hosting / reverse proxy settings"
    }
  },
  "type": "object"
}