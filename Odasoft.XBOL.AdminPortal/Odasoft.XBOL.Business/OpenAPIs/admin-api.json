        ],
        "summary": "Books the specified seat selection for the event and returns the identifiers of the booked seats.",
        "operationId": "BookSeatsAsync",
        "requestBody": {
          "description": "The booking request containing event and seat selection details. Cannot be null.",
          "content": {
            "application/json": {
              "schema": {
