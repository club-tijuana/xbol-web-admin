# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env
#
# En Docker, estas variables sobrescriben la configuración de appsettings.
# No subas el archivo .env al repositorio (debe estar en .gitignore).

# URL base de la API de administración (obligatorio)
AdminApiClient__BaseAddress=https://dev-web.admin.pwrticket.mx/

# Clave secreta de Seats.io (obligatorio)
SeatsIo__SecretKey=tu-secret-key-de-seats-io

# Usuarios permitidos para login (opcional si ya defines en appsettings).
# Puedes añadir más usuarios con __1__, __2__, etc.
Authentication__AllowedUsers__0__Email=admin@ejemplo.com
Authentication__AllowedUsers__0__Password=tu-password-seguro
